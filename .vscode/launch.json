{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Academy",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Academy/bin/Debug/net9.0/Academy.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Academy",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        }
    ]
}
