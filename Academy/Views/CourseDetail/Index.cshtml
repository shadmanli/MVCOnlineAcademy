@model Academy.ViewModels.Course.CourseDetailVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section css {
    <link rel="stylesheet" href="~/assets/css/courses-detail.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .live-indicator-dot {
            width: 12px;
            height: 12px;
            background-color: #00ff87;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 10px #00ff87, 0 0 20px #00ff87;
            animation: pulse-neon 1.5s infinite;
        }

        @@keyframes pulse-neon {
            0% { transform: scale(1); opacity: 1; box-shadow: 0 0 10px #00ff87; }
            50% { transform: scale(1.3); opacity: 0.7; box-shadow: 0 0 20px #00ff87, 0 0 30px #00ff87; }
            100% { transform: scale(1); opacity: 1; box-shadow: 0 0 10px #00ff87; }
        }

        .neon-btn-live {
            position: relative;
            background: rgba(0, 255, 135, 0.1);
            color: #00ff87;
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border: 1px solid #00ff87;
            box-shadow: 0 0 15px rgba(0, 255, 135, 0.2), inset 0 0 10px rgba(0, 255, 135, 0.1);
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            overflow: hidden;
        }

        .neon-btn-live:hover {
            background: rgba(0, 255, 135, 0.2);
            color: #fff;
            box-shadow: 0 0 25px rgba(0, 255, 135, 0.5), inset 0 0 15px rgba(0, 255, 135, 0.3);
            transform: translateY(-2px);
        }

        .neon-btn-live::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 135, 0.4), transparent);
            transition: left 0.5s;
        }

        .neon-btn-live:hover::before {
            left: 100%;
        }
    </style>
}

<main>

    <section id="hero-detail">
        <div class="hero-bg">
            <div class="container">

                <!-- BREADCRUMB -->
                <div class="breadcrumb">
                    <a href="#">Əsas Səhifə</a>
                    <span>›</span>
                    <a href="#">Kurslar</a>
                    <span>›</span>
                    <span style="color:rgba(255,255,255,0.65)">
                        @Model.Title
                    </span>
                </div>

                <div class="hero-layout">
                    <div class="hero-left">

                        <!-- CATEGORY -->
                        <div class="badge-row">
                            <span class="badge badge-cat">
                                ⚡ @Model.CategoryName
                            </span>
                            <span class="badge badge-level">Başlanğıc → Ekspert</span>
                            <span class="badge badge-live">🔴 CANLI DƏRS VAR</span>
                        </div>

                  
                        <h1>
                            @Model.Title:<br>
                            <span class="accent">Sıfırdan Ekspertə</span>
                        </h1>

            
                        <div class="meta-row">
                            <span class="stars">
                                @for(int i=0; i<5; i++)
                                {
                                    if(i < Math.Round(Model.Rating)) { <i class="fa-solid fa-star" style="color: #f1c40f;"></i> }
                                    else { <i class="fa-regular fa-star" style="color: #f1c40f;"></i> }
                                }
                            </span>
                            <span class="rating-txt"><strong>@Model.Rating</strong> (1,240 rəy)</span>
                            <span class="students-txt">· @Model.StudentCount+ tələbə qeydiyyatda</span>
                        </div>

               
                        <div class="teacher-row">
                            <div class="teacher-avatar">
                                @(Model.InstructorName != null ? Model.InstructorName.Substring(0, 1) : "U")
                            </div>
                            <div class="teacher-info">
                                <span>Müəllim</span>
                                <b>@Model.InstructorName</b>
                            </div>
                        </div>

                      
                        <div class="hero-stats">

                            <div class="stat"><span class="stat-num">@Model.Duration</span><span class="stat-lbl">Video</span></div>
                            <div class="stat"><span class="stat-num">6</span><span class="stat-lbl">Canli Zoom</span></div>
                            <div class="stat"><span class="stat-num">∞</span><span class="stat-lbl">Giriş</span></div>
                            <div class="stat"><span class="stat-num">5</span><span class="stat-lbl">Layihə</span></div>
                        </div>
                    </div>

         
                    <div style="width: 340px; flex-shrink: 0; position: sticky; top: 80px; display: flex; flex-direction: column; gap: 20px; z-index: 10;">
                        <div class="enroll-card" style="width: 100%; position: static;">
                            <div class="card-top">
                                <div class="price-row">
                                    <span class="price-main">₼@Model.Price</span>
                                    <span class="price-old">₼149</span>
                                    <span class="price-save">67% endirim!</span>
                                </div>

                                <div class="countdown-strip">
                                    <span class="fire">🔥</span>
                                    <span class="cd-text">Bu qiymət bitir:</span>
                                    <span id="countdownTimer">02:47:33</span>
                                </div>

                                <form asp-controller="Basket" asp-action="Add" method="post">
                                    <input type="hidden" name="courseId" value="@Model.Id" />
                                    <button type="submit" class="btn-enroll" style="width:100%; border:none; cursor:pointer;">🛒 Səbətə Əlavə Et</button>
                                </form>
                                <button class="btn-demo" id="demoPlayBtn" style="margin-top: 10px;">▶ Demo Dərsi İzlə (Pulsuz)</button>
                            </div>

                            <div class="card-divider"></div>


                            <ul class="card-features">
                                @if (Model.Features != null && Model.Features.Any())
                                {
                                    foreach (var feature in Model.Features)
                                    {
                                        <li><span class="feat-icon">✅</span> @feature</li>
                                    }
                                }
                                else
                                {
                                    <li><span class="feat-icon">📹</span> @Model.Duration HD video dərs</li>
                                    <li><span class="feat-icon">📁</span> İndirilə bilən qaynaqlar</li>
                                    <li><span class="feat-icon">🏆</span> Tamamlama sertifikatı</li>
                                    <li><span class="feat-icon">📱</span> Mobil & masaüstü giriş</li>
                                    <li><span class="feat-icon">♾️</span> Ömürlük giriş hüququ</li>
                                }
                            </ul>

                            <div class="money-back">
                                <span class="shield">🛡️</span>
                                <span><strong>30 günlük</strong> pulsuz iade zəmanəti</span>
                            </div>
                        </div>

                        <!-- LIVE CLASS CARD (PREMIUM DARK GREEN UI) -->
                        <div class="live-class-card" style="background: rgba(4, 47, 46, 0.85); backdrop-filter: blur(15px); border: 1px solid rgba(0, 255, 135, 0.2); border-radius: 20px; padding: 24px; box-shadow: 0 16px 40px rgba(0,0,0,0.2), inset 0 0 20px rgba(0,255,135,0.05); color: #fff;">
                            @if (Model.LiveClasses != null && Model.LiveClasses.Any())
                            {
                                <div style="display:flex; align-items:center; gap: 10px; margin-bottom: 16px;">
                                    <span class="live-indicator-dot"></span>
                                    <h4 style="margin:0; font-size: 18px; font-weight: 700; color: #fff;">Canlı Dərs</h4>
                                </div>
                                var lc = Model.LiveClasses.FirstOrDefault();
                                if (lc != null)
                                {
                                    bool isLive = lc.Status == Academy.Models.LiveSessionStatus.Live || (lc.Status == Academy.Models.LiveSessionStatus.Scheduled && DateTime.Now >= lc.ScheduledDate);
                                    bool isScheduled = !isLive && lc.Status == Academy.Models.LiveSessionStatus.Scheduled;

                                    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 12px; margin-bottom: 16px;">
                                        <h5 style="margin: 0 0 4px 0; font-size: 15px; color: #e2e8f0;">@lc.Title</h5>
                                        <p style="margin: 0; font-size: 13px; color: #94a3b8;"><i class="fa-regular fa-clock"></i> @lc.ScheduledDate.ToString("dd MMM yyyy, HH:mm")</p>
                                    </div>
                                    @if(isLive)
                                    {
                                        <a href="/meeting/@lc.RoomId" class="neon-btn-live w-100" style="display:flex; justify-content:center;">
                                            <i class="fa-solid fa-video"></i> Canlı Dərsə Qoşul
                                        </a>
                                    }
                                    else if(isScheduled)
                                    {
                                        <button disabled class="w-100" style="background:rgba(255,255,255,0.05); color:#94a3b8; border:1px solid rgba(255,255,255,0.1); padding: 12px; border-radius:8px; font-weight:600; font-size: 14px; cursor:not-allowed;">
                                            <i class="fa-solid fa-calendar-days"></i> Vaxtı Gözlənilir
                                        </button>
                                    }
                                }
                            }
                            else
                            {
                                <div style="display:flex; align-items:center; gap: 10px; margin-bottom: 12px;">
                                    <i class="fa-solid fa-video" style="color: rgba(255,255,255,0.4); font-size:18px;"></i>
                                    <h4 style="margin:0; font-size: 18px; font-weight: 700; color: #cbd5e1;">Canlı Dərs</h4>
                                </div>
                                <p style="font-size: 13px; color: #94a3b8; margin-bottom: 16px; line-height: 1.5;">Hazırda bu kurs üçün təyin edilmiş canlı dərs yoxdur.</p>
                                <a href="/meeting/index" class="w-100" style="display:flex; justify-content:center; background:rgba(255,255,255,0.05); color:#cbd5e1; border:1px solid rgba(255,255,255,0.1); padding: 10px; border-radius:8px; font-weight:600; font-size: 14px; text-decoration:none; transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'">
                                    Bütün Görüşlər
                                </a>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

   
    <div class="content-wrapper container">
        <div class="tab-content active" id="overview">
            <div class="tab-main">

                <h2 class="section-title">ℹ️ Kurs haqqında</h2>

                <p style="font-size:15px;color:#444;line-height:1.75;margin-bottom:24px">
                    @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                </p>

                @if (Model.Requirements != null && Model.Requirements.Any())
                {
                    <h2 class="section-title" style="margin-top: 30px;">📋 Tələblər</h2>
                    <ul style="list-style-type: none; padding-left: 0;">
                        @foreach (var req in Model.Requirements)
                        {
                            <li style="font-size: 15px; color: #444; margin-bottom: 10px; display: flex; align-items: start;">
                                <i class="fa-solid fa-check" style="color: #00c4a8; margin-right: 10px; margin-top: 3px;"></i>
                                <span>@req.Text</span>
                            </li>
                        }
                    </ul>
                }

                @if (Model.DemoLessons != null && Model.DemoLessons.Any())
                {
                    <div id="demoSection">
                        <h2 class="section-title" style="margin-top: 40px; margin-bottom: 20px;">🎬 Demo Dərslər (Ödənişsiz)</h2>

                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
                            @foreach (var demo in Model.DemoLessons)
                            {
                                <div style="background: #fff; border: 1px solid #eee; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                    <video controls preload="none" poster="/uploads/demothumbnails/@demo.ThumbnailUrl" style="width: 100%; aspect-ratio: 16/9; background: #000; object-fit: cover;">
                                        <source src="/uploads/demovideos/@demo.VideoUrl">
                                        Sizin brauzeriniz video dəstəkləmir.
                                    </video>
                                    <div style="padding: 15px;">
                                        <h4 style="font-size: 16px; margin-bottom: 8px; color: #222;">@demo.Title</h4>
                                        <p style="font-size: 13px; color: #666; margin-bottom: 12px; line-height: 1.4;">
                                            @demo.Description
                                        </p>
                                        <div style="display: flex; align-items: center; justify-content: space-between;">
                                            <span style="font-size: 12px; font-weight: 600; color: #00c4a8; background: #e0f7f4; padding: 4px 10px; border-radius: 20px;">
                                                ⏱ @demo.Duration Dəqiqə
                                            </span>
                                            <span style="font-size: 12px; font-weight: 500; color: #fff; background: var(--orange); padding: 4px 10px; border-radius: 20px;">
                                                Pulsuz İzlə
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.Videos != null && Model.Videos.Any())
                {
                    <h2 class="section-title" style="margin-top: 40px; margin-bottom: 20px;">🎥 Dərslər (Mündəricat)</h2>

                    var groupedVideos = Model.Videos.GroupBy(v => v.Level).OrderBy(g => g.Key);

                    <div class="curriculum-accordion" style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden;">
                    @foreach (var group in groupedVideos)
                    {
                        <div class="curriculum-group" style="border-bottom: 1px solid #ddd;">
                            <div class="group-header" style="background: #f8f9fa; padding: 15px 20px; cursor: pointer; font-weight: bold; display: flex; justify-content: space-between; align-items: center;">
                                <h3 style="margin: 0; font-size: 1.1rem; color: #333;">@group.Key Dərsləri</h3>
                                <span style="font-size: 0.9rem; color: #666;">@group.Count() dərs</span>
                            </div>
                            <div class="group-body" style="background: #fff; padding: 0;">
                                <ul style="list-style-type: none; padding-left: 0; margin: 0;">
                                    @foreach (var video in group)
                                    {
                                        <li style="padding: 15px 20px; border-top: 1px solid #eee;">
                                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
                                                <div style="display: flex; align-items: center;">
                                                    <i class="fa-solid fa-circle-play" style="color: #00c4a8; margin-right: 12px; font-size: 1.2rem;"></i>
                                                    <span style="font-weight: 500; font-size: 15px; color: #333;">@video.Title</span>
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrEmpty(video.Url))
                                            {
                                                <div style="margin-left: 30px; margin-top: 10px;">
                                                    <video style="width: 100%; max-width: 600px; border-radius: 12px; border: 1px solid #eee; box-shadow: 0 4px 15px rgba(0,0,0,0.1); background-color: #000;" controls preload="metadata">
                                                        <source src="/uploads/videos/@video.Url">
                                                        Sizin brauzeriniz video dəstəkləmir.
                                                    </video>
                                                </div>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                    </div>
                }

            </div>
        </div>

        <div class="tab-content" id="instructor">
            <div class="tab-main">
                <!-- Instructor Info Section (Similar to the original but might include improvements) -->
                <h2 class="section-title" style="margin-bottom: 24px;">👨‍🏫 Müəllim haqdında</h2>

                <div style="display: flex; align-items: flex-start; gap: 20px;">
                    <div class="teacher-avatar">
                        @(Model.InstructorName != null ? Model.InstructorName.Substring(0, 1) : "U")
                    </div>
                    <div>
                        <h3 style="margin: 0; font-size: 18px; color: #333;">@Model.InstructorName</h3>
                        <p style="font-size: 14px; color: #666; margin: 4px 0 12px;"></p>
                        <div class="social-links" style="display: flex; gap: 12px;">
                            <a href="https://twitter.com" target="_blank" class="social-link" style="font-size: 16px; color: #1da1f2;">
                                <i class="fa-brands fa-twitter"></i>
                            </a>
                            <a href="https://www.facebook.com" target="_blank" class="social-link" style="font-size: 16px; color: #1877f2;">
                                <i class="fa-brands fa-facebook-f"></i>
                            </a>
                            <a href="https://www.linkedin.com" target="_blank" class="social-link" style="font-size: 16px; color: #0077b5;">
                                <i class="fa-brands fa-linkedin-in"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <h3 style="margin-top: 30px; font-size: 16px; color: #333;">📚 Müəllimin Digər Kursları</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px; margin-top: 12px;">
                    @if (Model.OtherCourses != null)
                    {
                        @foreach (var otherCourse in Model.OtherCourses)
                        {
                            <div style="background: #fff; border: 1px solid #eee; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                <a href="/course-detail/@otherCourse.Id" style="text-decoration: none; color: #333;">
                                    <div style="position: relative;">
                                        <img src="/uploads/coursecovers/@otherCourse.ImageUrl" alt="@otherCourse.Title" style="width: 100%; height: 150px; object-fit: cover; border-bottom: 1px solid #eee;">
                                        <div style="padding: 15px;">
                                            <h4 style="font-size: 15px; margin: 0 0 8px;"></h4>
                                            <p style="font-size: 14px; color: #777; margin: 0;"></p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ===== REVIEWS SECTION ===== -->
    <div class="container" style="margin-top:60px;margin-bottom:60px;" id="reviews-section">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:30px;flex-wrap:wrap;gap:12px;">
            <h2 style="font-size:26px;font-weight:800;color:#1a1a2e;margin:0;">
                ⭐ Tələbə Rəyləri
            </h2>
            <div id="avg-rating-box" style="display:flex;align-items:center;gap:12px;"></div>
        </div>

        <!-- Rating Distribution -->
        <div id="rating-distribution" style="background:#f8f9fa;border-radius:16px;padding:24px;margin-bottom:32px;display:none;">
            <div style="display:flex;gap:32px;flex-wrap:wrap;align-items:center;">
                <div style="text-align:center;min-width:80px;">
                    <div id="avg-score" style="font-size:56px;font-weight:900;color:#1a1a2e;line-height:1;"></div>
                    <div id="avg-stars" style="margin:8px 0;"></div>
                    <div style="font-size:13px;color:#666;" id="total-reviews-txt"></div>
                </div>
                <div style="flex:1;min-width:200px;" id="star-bars"></div>
            </div>
        </div>

        <!-- Reviews List -->
        <div id="reviews-list" style="display:flex;flex-direction:column;gap:16px;">
            <div style="text-align:center;padding:40px;color:#999;">
                <div class="spinner-border text-primary" style="width:2rem;height:2rem;"></div>
            </div>
        </div>

        <!-- Write Review Form -->
        <div id="review-form-section" style="margin-top:40px;background:linear-gradient(135deg,#667eea15,#764ba215);border:1px solid #667eea30;border-radius:20px;padding:32px;">
            <h3 style="font-size:20px;font-weight:700;margin-bottom:20px;color:#1a1a2e;">✍️ Rəyinizi Yazın</h3>
            <div id="review-form-msg"></div>
            <div id="review-form-inner">
                <!-- Star Rating -->
                <div style="margin-bottom:20px;">
                    <label style="font-weight:600;color:#333;display:block;margin-bottom:10px;">Reytinq seçin:</label>
                    <div id="star-selector" style="display:flex;gap:8px;">
                        @for (int s = 1; s <= 5; s++)
                        {
                            <i class="fa fa-star star-btn" data-val="@s"
                               style="font-size:32px;color:#ddd;cursor:pointer;transition:all 0.2s;"></i>
                        }
                    </div>
                    <input type="hidden" id="selectedRating" value="0" />
                </div>
                <!-- Message -->
                <div style="margin-bottom:20px;">
                    <label style="font-weight:600;color:#333;display:block;margin-bottom:8px;">Rəyiniz:</label>
                    <textarea id="reviewMessage" rows="4" placeholder="Bu kurs haqqında fikirlərinizi yazın (minimum 10 simvol)..."
                              style="width:100%;padding:14px;border:1px solid #ddd;border-radius:12px;font-size:14px;resize:vertical;outline:none;transition:border 0.2s;"
                              onfocus="this.style.borderColor='#667eea'" onblur="this.style.borderColor='#ddd'"></textarea>
                </div>
                <button id="submitReviewBtn" onclick="submitReview(@Model.Id)"
                        style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;border:none;padding:14px 32px;border-radius:12px;font-weight:700;font-size:15px;cursor:pointer;transition:all 0.3s;"
                        onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa fa-paper-plane me-2"></i>Rəy Göndər
                </button>
            </div>
        </div>
    </div>

</main>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        const conn = new signalR.HubConnectionBuilder()
            .withUrl("/liveclasshub")
            .withAutomaticReconnect()
            .build();
        conn.on("ClassStatusChanged", () => location.reload());
        conn.start().catch(err => console.error(err));
    </script>
    <script>
        // Star selector
        const stars = document.querySelectorAll('.star-btn');
        stars.forEach(function(star) {
            star.addEventListener('mouseover', function() {
                const val = parseInt(this.dataset.val);
                stars.forEach(function(s, i) {
                    s.style.color = i < val ? '#f59e0b' : '#ddd';
                    s.style.transform = i < val ? 'scale(1.2)' : 'scale(1)';
                });
            });
            star.addEventListener('mouseout', function() {
                const selected = parseInt(document.getElementById('selectedRating').value);
                stars.forEach(function(s, i) {
                    s.style.color = i < selected ? '#f59e0b' : '#ddd';
                    s.style.transform = 'scale(1)';
                });
            });
            star.addEventListener('click', function() {
                const val = parseInt(this.dataset.val);
                document.getElementById('selectedRating').value = val;
                stars.forEach(function(s, i) {
                    s.style.color = i < val ? '#f59e0b' : '#ddd';
                });
            });
        });

        // Load reviews
        function loadReviews(courseId) {
            fetch('/Review/CourseReviews?courseId=' + courseId)
                .then(r => r.json())
                .then(function(reviews) {
                    renderReviews(reviews);
                    renderDistribution(reviews);
                });
        }

        function renderStars(rating, size) {
            size = size || 14;
            let html = '';
            for (let i = 1; i <= 5; i++) {
                html += '<i class="fa fa-star" style="color:' + (i <= rating ? '#f59e0b' : '#ddd') + ';font-size:' + size + 'px;"></i>';
            }
            return html;
        }

        function renderReviews(reviews) {
            const container = document.getElementById('reviews-list');
            if (!reviews.length) {
                container.innerHTML = '<div style="text-align:center;padding:40px;color:#999;"><i class="fa fa-star" style="font-size:40px;display:block;margin-bottom:12px;"></i><p>Hələ rəy yoxdur. İlk rəyi siz yazın!</p></div>';
                return;
            }
            container.innerHTML = reviews.map(function(r) {
                return '<div style="background:#fff;border:1px solid #f0f0f0;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,0.05);animation:fadeInUp 0.4s ease;">' +
                    '<div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;">' +
                        '<div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:18px;flex-shrink:0;">' +
                            r.name[0].toUpperCase() +
                        '</div>' +
                        '<div style="flex:1;">' +
                            '<div style="font-weight:700;color:#1a1a2e;">' + r.name + '</div>' +
                            '<div>' + renderStars(r.rating) + '</div>' +
                        '</div>' +
                        '<div style="font-size:12px;color:#999;">' + r.date + '</div>' +
                    '</div>' +
                    '<p style="color:#555;font-size:14px;line-height:1.7;margin:0;">' + r.message + '</p>' +
                '</div>';
            }).join('');
        }

        function renderDistribution(reviews) {
            if (!reviews.length) return;
            const dist = document.getElementById('rating-distribution');
            dist.style.display = 'block';

            const avg = reviews.reduce(function(s, r) { return s + r.rating; }, 0) / reviews.length;
            document.getElementById('avg-score').textContent = avg.toFixed(1);
            document.getElementById('avg-stars').innerHTML = renderStars(Math.round(avg), 18);
            document.getElementById('total-reviews-txt').textContent = reviews.length + ' rəy';

            document.getElementById('avg-rating-box').innerHTML =
                '<span style="font-size:28px;font-weight:900;color:#1a1a2e;">' + avg.toFixed(1) + '</span>' +
                renderStars(Math.round(avg), 20) +
                '<span style="color:#666;font-size:14px;">(' + reviews.length + ' rəy)</span>';

            let barsHtml = '';
            for (let s = 5; s >= 1; s--) {
                const cnt = reviews.filter(function(r) { return r.rating === s; }).length;
                const pct = reviews.length ? Math.round(cnt / reviews.length * 100) : 0;
                barsHtml += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">' +
                    '<span style="font-size:13px;color:#666;width:40px;">' + s + ' ⭐</span>' +
                    '<div style="flex:1;background:#e9ecef;border-radius:99px;height:8px;overflow:hidden;">' +
                        '<div style="width:' + pct + '%;background:linear-gradient(90deg,#f59e0b,#f97316);height:100%;border-radius:99px;transition:width 0.8s ease;"></div>' +
                    '</div>' +
                    '<span style="font-size:13px;color:#666;width:30px;">' + cnt + '</span>' +
                '</div>';
            }
            document.getElementById('star-bars').innerHTML = barsHtml;
        }

        function submitReview(courseId) {
            const rating = parseInt(document.getElementById('selectedRating').value);
            const message = document.getElementById('reviewMessage').value;
            const msgEl = document.getElementById('review-form-msg');
            const btn = document.getElementById('submitReviewBtn');

            if (rating === 0) {
                msgEl.innerHTML = '<div style="color:#e74c3c;margin-bottom:12px;font-weight:600;">⚠️ Zəhmət olmasa reytinq seçin.</div>';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Göndərilir...';

            const token = document.querySelector('input[name="__RequestVerificationToken"]');

            fetch('/Review/Submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token ? token.value : ''
                },
                body: 'courseId=' + courseId + '&rating=' + rating + '&message=' + encodeURIComponent(message)
            })
            .then(r => r.json())
            .then(function(res) {
                if (res.success) {
                    msgEl.innerHTML = '<div style="background:#d1fae5;color:#065f46;padding:14px 20px;border-radius:12px;margin-bottom:16px;font-weight:600;">✅ ' + res.message + '</div>';
                    document.getElementById('review-form-inner').style.opacity = '0.5';
                    document.getElementById('review-form-inner').style.pointerEvents = 'none';
                } else {
                    msgEl.innerHTML = '<div style="background:#fee2e2;color:#991b1b;padding:14px 20px;border-radius:12px;margin-bottom:16px;font-weight:600;">❌ ' + res.message + '</div>';
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa fa-paper-plane me-2"></i>Rəy Göndər';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            loadReviews(@Model.Id);
        });
    </script>
    @Html.AntiForgeryToken()
}