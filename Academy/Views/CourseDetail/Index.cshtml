@model Academy.ViewModels.Course.CourseDetailVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section css {
    <link rel="stylesheet" href="~/assets/css/courses-detail.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .live-indicator-dot {
            width: 12px;
            height: 12px;
            background-color: #00ff87;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 10px #00ff87, 0 0 20px #00ff87;
            animation: pulse-neon 1.5s infinite;
        }

        @@keyframes pulse-neon {
            0% { transform: scale(1); opacity: 1; box-shadow: 0 0 10px #00ff87; }
            50% { transform: scale(1.3); opacity: 0.7; box-shadow: 0 0 20px #00ff87, 0 0 30px #00ff87; }
            100% { transform: scale(1); opacity: 1; box-shadow: 0 0 10px #00ff87; }
        }

        .neon-btn-live {
            position: relative;
            background: rgba(0, 255, 135, 0.1);
            color: #00ff87;
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            border: 1px solid #00ff87;
            box-shadow: 0 0 15px rgba(0, 255, 135, 0.2), inset 0 0 10px rgba(0, 255, 135, 0.1);
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            overflow: hidden;
        }

        .neon-btn-live:hover {
            background: rgba(0, 255, 135, 0.2);
            color: #fff;
            box-shadow: 0 0 25px rgba(0, 255, 135, 0.5), inset 0 0 15px rgba(0, 255, 135, 0.3);
            transform: translateY(-2px);
        }

        .neon-btn-live::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 135, 0.4), transparent);
            transition: left 0.5s;
        }

        .neon-btn-live:hover::before {
            left: 100%;
        }
    </style>
}

<main>

    <section id="hero-detail">
        <div class="hero-bg">
            <div class="container">

                <!-- BREADCRUMB -->
                <div class="breadcrumb">
                    <a href="#">Əsas Səhifə</a>
                    <span>›</span>
                    <a href="#">Kurslar</a>
                    <span>›</span>
                    <span style="color:rgba(255,255,255,0.65)">
                        @Model.Title
                    </span>
                </div>

                <div class="hero-layout">
                    <div class="hero-left">

                        <!-- CATEGORY -->
                        <div class="badge-row">
                            <span class="badge badge-cat">
                                ⚡ @Model.CategoryName
                            </span>
                            <span class="badge badge-level">Başlanğıc → Ekspert</span>
                        </div>

                  
                        <h1>
                            @Model.Title:<br>
                            <span class="accent">Sıfırdan Ekspertə</span>
                        </h1>

            
                        <div class="meta-row">
                            <span class="stars">
                                @for(int i=0; i<5; i++)
                                {
                                    if(i < Math.Round(Model.Rating)) { <i class="fa-solid fa-star" style="color: #f1c40f;"></i> }
                                    else { <i class="fa-regular fa-star" style="color: #f1c40f;"></i> }
                                }
                            </span>
                            <span class="rating-txt"><strong>@Model.Rating.ToString("0.0")</strong> rəy</span>
                            <span class="students-txt">· @Model.StudentCount tələbə qeydiyyatda</span>
                        </div>

               
                        <div class="teacher-row">
                            <div class="teacher-avatar">
                                @(Model.InstructorName != null ? Model.InstructorName.Substring(0, 1) : "U")
                            </div>
                            <div class="teacher-info">
                                <span>Müəllim</span>
                                <b>@Model.InstructorName</b>
                            </div>
                        </div>

                      
                        <div class="hero-stats">
                            <div class="stat"><span class="stat-num">@(Model.Videos?.Count ?? 0)</span><span class="stat-lbl">Video</span></div>
                            <div class="stat"><span class="stat-num">∞</span><span class="stat-lbl">Giriş</span></div>
                            <div class="stat"><span class="stat-num">5</span><span class="stat-lbl">Layihə</span></div>
                        </div>
                    </div>

         
                    <div style="width: 340px; flex-shrink: 0; position: sticky; top: 80px; display: flex; flex-direction: column; gap: 20px; z-index: 10;">
                        <div class="enroll-card" style="width: 100%; position: static;">
                            <div class="card-top">
                                <div class="price-row">
                                    <span class="price-main">₼@Model.Price</span>
                                    <span class="price-old">₼149</span>
                                    <span class="price-save">67% endirim!</span>
                                </div>

                                <div class="countdown-strip">
                                    <span class="fire">🔥</span>
                                    <span class="cd-text">Bu qiymət bitir:</span>
                                    <span id="countdownTimer">02:47:33</span>
                                </div>

                                <form asp-controller="Basket" asp-action="Add" method="post">
                                    <input type="hidden" name="courseId" value="@Model.Id" />
                                    <button type="submit" class="btn-enroll" style="width:100%; border:none; cursor:pointer;">🛒 Səbətə Əlavə Et</button>
                                </form>
                                <button class="btn-demo" id="demoPlayBtn" style="margin-top: 10px;">▶ Demo Dərsi İzlə (Pulsuz)</button>
                            </div>

                            <div class="card-divider"></div>


                            <ul class="card-features">
                                @if (Model.Features != null && Model.Features.Any())
                                {
                                    foreach (var feature in Model.Features)
                                    {
                                        <li><span class="feat-icon">✅</span> @feature</li>
                                    }
                                }
                                else
                                {
                                    <li><span class="feat-icon">📹</span> @(Model.Videos?.Count ?? 0) HD video dərs</li>
                                    <li><span class="feat-icon">📁</span> İndirilə bilən qaynaqlar</li>
                                    <li><span class="feat-icon">🏆</span> Tamamlama sertifikatı</li>
                                    <li><span class="feat-icon">📱</span> Mobil & masaüstü giriş</li>
                                    <li><span class="feat-icon">♾️</span> Ömürlük giriş hüququ</li>
                                }
                            </ul>

                            <div class="money-back">
                                <span class="shield">🛡️</span>
                                <span><strong>30 günlük</strong> pulsuz iade zəmanəti</span>
                            </div>
                        </div>
                        <!-- LIVE CLASS CARD -->
                        @if (Model.LiveClasses != null && Model.LiveClasses.Any() && (ViewBag.IsPurchased ?? false))
                        {
                            var lc = Model.LiveClasses.FirstOrDefault(x =>
                                x.Status != Academy.Models.LiveSessionStatus.Ended &&
                                x.Status != Academy.Models.LiveSessionStatus.Canceled);

                            if (lc != null)
                            {
                                bool isLive = lc.Status == Academy.Models.LiveSessionStatus.Live ||
                                    (lc.Status == Academy.Models.LiveSessionStatus.Scheduled && DateTime.Now >= lc.ScheduledDate);

                                <div style="background:rgba(4,47,46,0.9);border:1px solid rgba(0,255,135,0.2);border-radius:20px;padding:24px;margin-top:16px;box-shadow:0 16px 40px rgba(0,0,0,0.2);">
                                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
                                        <span class="live-indicator-dot"></span>
                                        <h4 style="margin:0;font-size:16px;font-weight:700;color:#fff;">Canlı Dərs</h4>
                                    </div>
                                    <div style="background:rgba(0,0,0,0.2);border-radius:12px;padding:12px;margin-bottom:16px;">
                                        <h5 style="margin:0 0 4px;font-size:14px;color:#e2e8f0;">@lc.Title</h5>
                                        @if (!string.IsNullOrEmpty(lc.Topic))
                                        {
                                            <p style="margin:0 0 4px;font-size:12px;color:#94a3b8;">📌 @lc.Topic</p>
                                        }
                                        <p style="margin:0;font-size:12px;color:#94a3b8;"><i class="fa-regular fa-clock"></i> @lc.ScheduledDate.ToString("dd MMM yyyy, HH:mm")</p>
                                    </div>
                                    @if (isLive)
                                    {
                                        <a href="/meeting/@lc.RoomId" class="neon-btn-live" style="width:100%;justify-content:center;">
                                            <i class="fa-solid fa-video"></i> Canlı Dərsə Qoşul
                                        </a>
                                    }
                                    else
                                    {
                                        <button disabled style="width:100%;background:rgba(255,255,255,0.05);color:#94a3b8;border:1px solid rgba(255,255,255,0.1);padding:12px;border-radius:8px;font-weight:600;font-size:14px;cursor:not-allowed;">
                                            <i class="fa-solid fa-calendar-days"></i> @lc.ScheduledDate.ToString("dd MMM, HH:mm")-də başlayır
                                        </button>
                                    }
                                </div>
                            }
                        }

                        <!-- CERTIFICATE SECTION -->
                        @if (ViewBag.IsPurchased ?? false)
                        {
                            <div id="certSection" style="margin-top:16px;"></div>
                            <script>
                            (function() {
                                fetch('/Certificate/Check/@Model.Id')
                                    .then(function(r){return r.json();})
                                    .then(function(d){
                                        var sec = document.getElementById('certSection');
                                        if (!sec) return;
                                        if (d.hasCert) {
                                            sec.innerHTML = '<div style="background:rgba(0,196,168,0.08);border:1px solid rgba(0,196,168,0.2);border-radius:16px;padding:18px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;"><div><div style="font-size:13px;font-weight:700;color:#00c4a8;margin-bottom:3px;">🏆 Sertifikat Alınıb</div><div style="font-size:11px;color:#64748b;font-family:monospace;">' + d.certNumber + '</div></div><a href="/Certificate/View/' + d.certNumber + '" style="padding:9px 18px;background:linear-gradient(135deg,#00c4a8,#0ea5e9);color:#fff;border-radius:10px;font-size:12px;font-weight:700;text-decoration:none;">Bax</a></div>';
                                        } else if (d.eligible) {
                                            sec.innerHTML = '<button id="claimBtn" onclick="claimCert(@Model.Id)" style="width:100%;padding:14px;background:linear-gradient(135deg,#00c4a8,#0ea5e9);color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;"><i class="fa-solid fa-certificate"></i> Sertifikatı Əldə Et</button>';
                                        } else {
                                            sec.innerHTML = '<div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:16px 18px;"><div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:6px;">📋 Sertifikat Şərtləri</div><div style="font-size:12px;color:#94a3b8;"><div style="margin-bottom:4px;">' + (d.paid ? '✅' : '❌') + ' Kurs alınıb</div><div>' + (d.pct === 100 ? '✅' : '⏳ ' + d.pct + '%') + ' Videolar (' + d.watchedCount + '/' + d.totalVideos + ')</div></div></div>';
                                        }
                                    }).catch(function(){});
                            })();

                            function claimCert(courseId) {
                                var btn = document.getElementById('claimBtn');
                                if(btn){btn.disabled=true;btn.textContent='Yüklənir...';}
                                fetch('/Certificate/Claim',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'courseId='+courseId})
                                .then(function(r){return r.json();})
                                .then(function(d){
                                    if(d.success){
                                        document.getElementById('certSection').innerHTML='<div style="background:rgba(0,196,168,0.1);border:1px solid rgba(0,196,168,0.25);border-radius:14px;padding:16px 18px;text-align:center;"><div style="font-size:16px;font-weight:800;color:#00c4a8;margin-bottom:8px;">🎉 Sertifikat Verildi!</div><div style="font-size:11px;color:#64748b;font-family:monospace;margin-bottom:12px;">'+d.certNumber+'</div><a href="/Certificate/View/'+d.certNumber+'" style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:linear-gradient(135deg,#00c4a8,#0ea5e9);color:#fff;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;">Sertifikata Bax</a></div>';
                                    } else {
                                        if(btn){btn.disabled=false;btn.textContent='Sertifikatı Əldə Et';}
                                        alert(d.message);
                                    }
                                });
                            }
                            </script>
                        }
                    </div>

                </div>
            </div>
        </div>
    </section>

   
    <div class="content-wrapper container">
        <div class="tab-content active" id="overview">
            <div class="tab-main">

                <h2 class="section-title">ℹ️ Kurs haqqında</h2>

                <p style="font-size:15px;color:#444;line-height:1.75;margin-bottom:24px">
                    @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                </p>

                @if (Model.Requirements != null && Model.Requirements.Any())
                {
                    <h2 class="section-title" style="margin-top: 30px;">📋 Tələblər</h2>
                    <ul style="list-style-type: none; padding-left: 0;">
                        @foreach (var req in Model.Requirements)
                        {
                            <li style="font-size: 15px; color: #444; margin-bottom: 10px; display: flex; align-items: start;">
                                <i class="fa-solid fa-check" style="color: #00c4a8; margin-right: 10px; margin-top: 3px;"></i>
                                <span>@req.Text</span>
                            </li>
                        }
                    </ul>
                }

                @if (Model.DemoLessons != null && Model.DemoLessons.Any())
                {
                    <div id="demoSection">
                        <h2 class="section-title" style="margin-top: 40px; margin-bottom: 20px;">🎬 Demo Dərslər (Ödənişsiz)</h2>

                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
                            @foreach (var demo in Model.DemoLessons)
                            {
                                <div style="background: #fff; border: 1px solid #eee; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                    <video controls preload="none" poster="/uploads/demothumbnails/@demo.ThumbnailUrl" style="width: 100%; aspect-ratio: 16/9; background: #000; object-fit: cover;">
                                        <source src="/uploads/demovideos/@demo.VideoUrl">
                                        Sizin brauzeriniz video dəstəkləmir.
                                    </video>
                                    <div style="padding: 15px;">
                                        <h4 style="font-size: 16px; margin-bottom: 8px; color: #222;">@demo.Title</h4>
                                        <p style="font-size: 13px; color: #666; margin-bottom: 12px; line-height: 1.4;">
                                            @demo.Description
                                        </p>
                                        <div style="display: flex; align-items: center; justify-content: space-between;">
                                            <span style="font-size: 12px; font-weight: 600; color: #00c4a8; background: #e0f7f4; padding: 4px 10px; border-radius: 20px;">
                                                ⏱ @demo.Duration Dəqiqə
                                            </span>
                                            <span style="font-size: 12px; font-weight: 500; color: #fff; background: var(--orange); padding: 4px 10px; border-radius: 20px;">
                                                Pulsuz İzlə
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Model.Videos != null && Model.Videos.Any())
                {
                    bool isPurchased = ViewBag.IsPurchased ?? false;
                    List<int> watchedIds = ViewBag.WatchedVideoIds as List<int> ?? new List<int>();
                    int? lastWatchedId = ViewBag.LastWatchedVideoId as int?;
                    int totalVids = Model.Videos.Count;
                    int watchedCount = watchedIds.Count;
                    int progressPct = totalVids > 0 ? (int)Math.Round((double)watchedCount / totalVids * 100) : 0;
                    var groupedVideos = Model.Videos.GroupBy(v => v.Level).OrderBy(g => g.Key);

                    <h2 class="section-title" style="margin-top:40px;margin-bottom:20px;">
                        🎥 Dərslər (Mündəricat)
                        @if (isPurchased && totalVids > 0)
                        {
                            <span style="margin-left:12px;font-size:13px;font-weight:600;color:#00c4a8;">@watchedCount/@totalVids izlənildi</span>
                        }
                    </h2>

                    @if (isPurchased && totalVids > 0)
                    {
                        <!-- Progress bar -->
                        <div style="background:#f1f5f9;border-radius:99px;height:8px;margin-bottom:20px;overflow:hidden;">
                            <div style="width:@progressPct%;background:linear-gradient(90deg,#00c4a8,#0ea5e9);height:100%;border-radius:99px;transition:width 0.5s ease;"></div>
                        </div>
                        @if (lastWatchedId.HasValue)
                        {
                            var lastVid = Model.Videos.FirstOrDefault(v => v.Id == lastWatchedId.Value);
                            if (lastVid != null)
                            {
                                <div style="background:rgba(0,196,168,0.07);border:1px solid rgba(0,196,168,0.2);border-radius:12px;padding:12px 18px;margin-bottom:20px;display:flex;align-items:center;gap:12px;font-size:14px;">
                                    <i class="fa-solid fa-circle-play" style="color:#00c4a8;font-size:18px;"></i>
                                    <div>
                                        <span style="font-weight:700;color:#0f172a;">Davam et:</span>
                                        <span style="color:#475569;margin-left:6px;">@lastVid.Title</span>
                                    </div>
                                </div>
                            }
                        }
                    }

                    @if (!isPurchased)
                    {
                        <!-- Locked banner -->
                        <div style="background:linear-gradient(135deg,#0f172a,#1e293b);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:28px;margin-bottom:20px;text-align:center;">
                            <i class="fa-solid fa-lock" style="font-size:36px;color:#f59e0b;margin-bottom:12px;display:block;"></i>
                            <h4 style="font-size:18px;font-weight:800;color:#f8fafc;margin-bottom:8px;">Bu bölmə kilidlidir</h4>
                            <p style="font-size:14px;color:#94a3b8;margin-bottom:20px;">Bütün dərslərə baxmaq üçün kursu satın alın.</p>
                            <form asp-controller="Basket" asp-action="Add" method="post" style="display:inline;">
                                <input type="hidden" name="courseId" value="@Model.Id" />
                                <button type="submit" style="background:linear-gradient(135deg,#ff6d34,#e8551f);color:#fff;border:none;padding:13px 32px;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 16px rgba(255,109,52,0.3);">
                                    <i class="fa-solid fa-cart-shopping"></i> Səbətə Əlavə Et
                                </button>
                            </form>
                        </div>
                    }


                    <div class="curriculum-accordion" style="border:1px solid #e8edf3;border-radius:16px;overflow:hidden;">
                    @foreach (var group in groupedVideos)
                    {
                        <div class="curriculum-group" style="border-bottom:1px solid #e8edf3;">
                            <div class="group-header" style="background:#f8fafc;padding:16px 20px;cursor:pointer;font-weight:700;display:flex;justify-content:space-between;align-items:center;" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'">
                                <h3 style="margin:0;font-size:15px;color:#0f172a;">@group.Key Dərsləri</h3>
                                <div style="display:flex;align-items:center;gap:12px;">
                                    @if (isPurchased)
                                    {
                                        int gWatched = group.Count(v => watchedIds.Contains(v.Id));
                                        <span style="font-size:12px;color:#64748b;">@gWatched/@group.Count() izlənildi</span>
                                    }
                                    <span style="font-size:12px;color:#64748b;background:#e8edf3;padding:3px 10px;border-radius:99px;">@group.Count() dərs</span>
                                    @if (!isPurchased)
                                    {
                                        <i class="fa-solid fa-lock" style="color:#f59e0b;font-size:13px;"></i>
                                    }
                                </div>
                            </div>
                            <div class="group-body" style="background:#fff;display:block;">
                                <ul style="list-style:none;padding:0;margin:0;">
                                    @foreach (var video in group)
                                    {
                                        bool isWatched = watchedIds.Contains(video.Id);
                                        bool isLast = video.Id == lastWatchedId;

                                        <li style="padding:14px 20px;border-top:1px solid #f1f5f9;background:@(isLast ? "rgba(0,196,168,0.04)" : "transparent")">
                                            <div style="display:flex;align-items:center;justify-content:space-between;">
                                                <div style="display:flex;align-items:center;gap:12px;">
                                                    @if (isPurchased)
                                                    {
                                                        if (isWatched)
                                                        {
                                                            <i class="fa-solid fa-circle-check" style="color:#00c4a8;font-size:16px;"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="fa-regular fa-circle-play" style="color:#94a3b8;font-size:16px;"></i>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-lock" style="color:#f59e0b;font-size:14px;"></i>
                                                    }
                                                    <span style="font-weight:500;font-size:14px;color:@(isWatched ? "#64748b" : "#0f172a");@(isWatched ? "text-decoration:line-through;" : "")">@video.Title</span>
                                                    @if (isLast)
                                                    {
                                                        <span style="font-size:11px;font-weight:700;color:#00c4a8;background:rgba(0,196,168,0.1);padding:2px 8px;border-radius:99px;">Davam et</span>
                                                    }
                                                </div>
                                                @if (isPurchased && isWatched)
                                                {
                                                    <span style="font-size:11px;color:#00c4a8;font-weight:600;">✓ İzlənildi</span>
                                                }
                                            </div>

                                            @if (isPurchased && !string.IsNullOrEmpty(video.Url))
                                            {
                                                <div style="margin-left:28px;margin-top:12px;">
                                                    <video data-video-id="@video.Id" data-course-id="@Model.Id"
                                                           style="width:100%;max-width:600px;border-radius:12px;border:1px solid #e8edf3;box-shadow:0 4px 15px rgba(0,0,0,0.08);"
                                                           controls preload="metadata"
                                                           onended="markVideoWatched(@video.Id, @Model.Id, this)">
                                                        <source src="/uploads/videos/@video.Url">
                                                    </video>
                                                </div>
                                            }
                                            else if (!isPurchased)
                                            {
                                                <div style="margin-left:28px;margin-top:10px;padding:12px 16px;background:#fafafa;border:1px dashed #e2e8f0;border-radius:10px;display:flex;align-items:center;gap:8px;font-size:13px;color:#94a3b8;">
                                                    <i class="fa-solid fa-lock" style="color:#f59e0b;"></i>
                                                    Bu dərs kilidlidir. Kursu satın alaraq baxın.
                                                </div>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                    </div>
                }

            </div>
        </div>

        <div class="tab-content" id="instructor">
            <div class="tab-main">
                <!-- Instructor Info Section (Similar to the original but might include improvements) -->
                <h2 class="section-title" style="margin-bottom: 24px;">👨‍🏫 Müəllim haqdında</h2>

                <div style="display: flex; align-items: flex-start; gap: 20px;">
                    <div class="teacher-avatar">
                        @(Model.InstructorName != null ? Model.InstructorName.Substring(0, 1) : "U")
                    </div>
                    <div>
                        <h3 style="margin: 0; font-size: 18px; color: #333;">@Model.InstructorName</h3>
                        <p style="font-size: 14px; color: #666; margin: 4px 0 12px;"></p>
                        <div class="social-links" style="display: flex; gap: 12px;">
                            <a href="https://twitter.com" target="_blank" class="social-link" style="font-size: 16px; color: #1da1f2;">
                                <i class="fa-brands fa-twitter"></i>
                            </a>
                            <a href="https://www.facebook.com" target="_blank" class="social-link" style="font-size: 16px; color: #1877f2;">
                                <i class="fa-brands fa-facebook-f"></i>
                            </a>
                            <a href="https://www.linkedin.com" target="_blank" class="social-link" style="font-size: 16px; color: #0077b5;">
                                <i class="fa-brands fa-linkedin-in"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <h3 style="margin-top: 30px; font-size: 16px; color: #333;">📚 Müəllimin Digər Kursları</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 16px; margin-top: 12px;">
                    @if (Model.OtherCourses != null)
                    {
                        @foreach (var otherCourse in Model.OtherCourses)
                        {
                            <div style="background: #fff; border: 1px solid #eee; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                                <a href="/course-detail/@otherCourse.Id" style="text-decoration: none; color: #333;">
                                    <div style="position: relative;">
                                        <img src="/uploads/coursecovers/@otherCourse.ImageUrl" alt="@otherCourse.Title" style="width: 100%; height: 150px; object-fit: cover; border-bottom: 1px solid #eee;">
                                        <div style="padding: 15px;">
                                            <h4 style="font-size: 15px; margin: 0 0 8px;"></h4>
                                            <p style="font-size: 14px; color: #777; margin: 0;"></p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ===== REVIEWS SECTION ===== -->
    <div class="container" style="margin-top:60px;margin-bottom:60px;" id="reviews-section">

        <div class="reviews-header">
            <h2 class="reviews-title">
                <i class="fa-solid fa-star" style="color:#fbbf24;font-size:22px;"></i>
                Tələbə Rəyləri
            </h2>
            <div id="avg-rating-box"></div>
        </div>

        <!-- Rating Distribution -->
        <div id="rating-distribution" class="rating-overview" style="display:none;"></div>

        <!-- Reviews List -->
        <div id="reviews-list" style="display:flex;flex-direction:column;gap:16px;margin-top:24px;">
            <div style="text-align:center;padding:40px;color:#999;">
                <i class="fa-solid fa-spinner fa-spin" style="font-size:28px;color:#00c4a8;"></i>
            </div>
        </div>

        <!-- Write Review Form -->
        <div class="review-write-wrap">
            <h3 class="review-write-title">
                <i class="fa-solid fa-pen-to-square"></i> Rəyinizi Yazın
            </h3>
            <div id="review-form-msg"></div>
            <div id="review-form-inner">
                <div class="review-star-row">
                    <label class="review-star-label">Reytinq seçin:</label>
                    <div id="star-selector" style="display:flex;gap:8px;margin-top:8px;">
                        @for (int s = 1; s <= 5; s++)
                        {
                            <i class="fa fa-star star-btn" data-val="@s"
                               style="font-size:32px;color:#334155;cursor:pointer;transition:all 0.2s;"></i>
                        }
                    </div>
                    <input type="hidden" id="selectedRating" value="0" />
                </div>
                <div class="review-msg-row">
                    <label class="review-star-label">Rəyiniz:</label>
                    <textarea id="reviewMessage" rows="4"
                              placeholder="Bu kurs haqqında fikirlərinizi yazın..."
                              class="review-textarea"></textarea>
                </div>
                <button id="submitReviewBtn" onclick="submitReview(@Model.Id)" class="review-submit-btn">
                    <i class="fa fa-paper-plane"></i> Rəy Göndər
                </button>
            </div>
        </div>

    </div>

    <style>
    .reviews-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .reviews-title {
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0;
        font-family: 'DM Sans', sans-serif;
    }
    .review-write-wrap {
        margin-top: 48px;
        background: #040814;
        border: 1px solid rgba(0,196,168,0.15);
        border-radius: 20px;
        padding: 36px;
        position: relative;
        overflow: hidden;
    }
    .review-write-wrap::before {
        content: '';
        position: absolute;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(0,196,168,0.07) 0%, transparent 70%);
        border-radius: 50%;
        top: -100px; right: -80px;
        pointer-events: none;
    }
    .review-write-title {
        font-size: 20px;
        font-weight: 700;
        color: #f8fafc;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: 'Inter', sans-serif;
    }
    .review-star-label {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255,255,255,0.5);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        display: block;
        margin-bottom: 6px;
        font-family: 'Inter', sans-serif;
    }
    .review-star-row { margin-bottom: 20px; }
    .review-msg-row { margin-bottom: 20px; }
    .review-textarea {
        width: 100%;
        padding: 14px 16px;
        background: rgba(255,255,255,0.05);
        border: 1.5px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        color: #f8fafc;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        resize: vertical;
        outline: none;
        transition: all 0.25s ease;
        box-sizing: border-box;
        margin-top: 8px;
    }
    .review-textarea::placeholder { color: rgba(255,255,255,0.2); }
    .review-textarea:focus {
        border-color: #00c4a8;
        background: rgba(0,196,168,0.06);
        box-shadow: 0 0 0 3px rgba(0,196,168,0.12);
    }
    .review-submit-btn {
        background: linear-gradient(135deg, #00c4a8, #0ea5e9);
        color: #fff;
        border: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s ease;
        box-shadow: 0 4px 16px rgba(0,196,168,0.3);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .review-submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,196,168,0.45);
    }
    .review-submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }
    /* Review cards */
    .review-card {
        background: #fff;
        border: 1px solid #e8edf3;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transition: box-shadow 0.2s;
    }
    .review-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .reviewer { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .rev-avatar {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 700; font-size: 14px; flex-shrink: 0;
    }
    .reviewer-info strong { font-size: 15px; color: #0f172a; display: block; }
    .reviewer-info .rev-meta {
        font-size: 12px; color: #94a3b8;
        display: flex; align-items: center; gap: 6px; margin-top: 3px;
    }
    .rev-stars { color: #fbbf24; font-size: 13px; }
    .review-card p { font-size: 14px; color: #475569; line-height: 1.65; }
    /* Rating overview */
    .rating-overview {
        background: #fff;
        border: 1px solid #e8edf3;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 0;
    }
    </style>

</main>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        const conn = new signalR.HubConnectionBuilder()
            .withUrl("/liveclasshub")
            .withAutomaticReconnect()
            .build();
        conn.on("ClassStatusChanged", () => location.reload());
        conn.start().catch(err => console.error(err));
    </script>
    <script>
        // Star selector
        const stars = document.querySelectorAll('.star-btn');
        stars.forEach(function(star) {
            star.addEventListener('mouseover', function() {
                const val = parseInt(this.dataset.val);
                stars.forEach(function(s, i) {
                    s.style.color = i < val ? '#fbbf24' : '#334155';
                    s.style.transform = i < val ? 'scale(1.2)' : 'scale(1)';
                });
            });
            star.addEventListener('mouseout', function() {
                const selected = parseInt(document.getElementById('selectedRating').value);
                stars.forEach(function(s, i) {
                    s.style.color = i < selected ? '#fbbf24' : '#334155';
                    s.style.transform = 'scale(1)';
                });
            });
            star.addEventListener('click', function() {
                const val = parseInt(this.dataset.val);
                document.getElementById('selectedRating').value = val;
                stars.forEach(function(s, i) {
                    s.style.color = i < val ? '#fbbf24' : '#334155';
                });
            });
        });

        // Load reviews
        function loadReviews(courseId) {
            fetch('/Review/CourseReviews?courseId=' + courseId)
                .then(r => r.json())
                .then(function(reviews) {
                    renderReviews(reviews);
                    renderDistribution(reviews);
                });
        }

        function renderStars(rating, size) {
            size = size || 14;
            let html = '';
            for (let i = 1; i <= 5; i++) {
                html += '<i class="fa fa-star" style="color:' + (i <= rating ? '#f59e0b' : '#ddd') + ';font-size:' + size + 'px;"></i>';
            }
            return html;
        }

        function renderReviews(reviews) {
            const container = document.getElementById('reviews-list');
            if (!reviews.length) {
                container.innerHTML = '<div style="text-align:center;padding:48px;color:#94a3b8;background:#fff;border:1px solid #e8edf3;border-radius:16px;">' +
                    '<i class="fa fa-star" style="font-size:40px;display:block;margin-bottom:12px;color:#cbd5e1;"></i>' +
                    '<p style="font-size:15px;font-weight:600;">Hələ rəy yoxdur. İlk rəyi siz yazın!</p></div>';
                return;
            }
            const colors = ['linear-gradient(135deg,#00c4a8,#0ea5e9)','linear-gradient(135deg,#ff6d34,#e8551f)','linear-gradient(135deg,#6366f1,#8b5cf6)','linear-gradient(135deg,#f59e0b,#d97706)'];
            container.innerHTML = reviews.map(function(r, idx) {
                return '<div class="review-card">' +
                    '<div class="reviewer">' +
                        '<div class="rev-avatar" style="background:' + colors[idx % colors.length] + ';">' +
                            r.name[0].toUpperCase() +
                        '</div>' +
                        '<div class="reviewer-info">' +
                            '<strong>' + r.name + '</strong>' +
                            '<div class="rev-meta">' +
                                '<span class="rev-stars">' + renderStars(r.rating) + '</span>' +
                                '<span>·</span><span>' + r.date + '</span>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<p>' + r.message + '</p>' +
                '</div>';
            }).join('');
        }

        function renderDistribution(reviews) {
            if (!reviews.length) return;
            const dist = document.getElementById('rating-distribution');
            dist.style.display = 'block';

            const avg = reviews.reduce(function(s, r) { return s + r.rating; }, 0) / reviews.length;

            document.getElementById('avg-rating-box').innerHTML =
                '<span style="font-size:26px;font-weight:900;color:#0f172a;">' + avg.toFixed(1) + '</span>' +
                '<span style="margin:0 4px;">' + renderStars(Math.round(avg), 18) + '</span>' +
                '<span style="color:#64748b;font-size:13px;">(' + reviews.length + ' rəy)</span>';

            let distHtml = '<div style="display:flex;gap:28px;align-items:center;flex-wrap:wrap;">' +
                '<div style="text-align:center;min-width:80px;">' +
                    '<div style="font-size:52px;font-weight:900;color:#0f172a;line-height:1;font-family:\'DM Sans\',sans-serif;">' + avg.toFixed(1) + '</div>' +
                    '<div style="color:#fbbf24;font-size:18px;margin:6px 0;">' + renderStars(Math.round(avg), 18) + '</div>' +
                    '<div style="font-size:12px;color:#94a3b8;">' + reviews.length + ' rəy</div>' +
                '</div>' +
                '<div style="flex:1;min-width:180px;">';
            for (let s = 5; s >= 1; s--) {
                const cnt = reviews.filter(function(r) { return r.rating === s; }).length;
                const pct = reviews.length ? Math.round(cnt / reviews.length * 100) : 0;
                distHtml += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">' +
                    '<span style="font-size:12px;color:#64748b;width:36px;">' + s + ' <i class="fa fa-star" style="color:#fbbf24;font-size:11px;"></i></span>' +
                    '<div style="flex:1;background:#f1f5f9;border-radius:99px;height:7px;overflow:hidden;">' +
                        '<div style="width:' + pct + '%;background:linear-gradient(90deg,#fbbf24,#f59e0b);height:100%;border-radius:99px;transition:width 0.8s ease;"></div>' +
                    '</div>' +
                    '<span style="font-size:12px;color:#94a3b8;width:24px;">' + cnt + '</span>' +
                '</div>';
            }
            distHtml += '</div></div>';
            dist.innerHTML = distHtml;
        }

        function submitReview(courseId) {
            const rating = parseInt(document.getElementById('selectedRating').value);
            const message = document.getElementById('reviewMessage').value;
            const msgEl = document.getElementById('review-form-msg');
            const btn = document.getElementById('submitReviewBtn');

            if (rating === 0) {
                msgEl.innerHTML = '<div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#fca5a5;padding:12px 16px;border-radius:10px;margin-bottom:14px;font-size:13px;font-weight:600;">⚠️ Zəhmət olmasa reytinq seçin.</div>';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Göndərilir...';

            const token = document.querySelector('input[name="__RequestVerificationToken"]');

            fetch('/Review/Submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token ? token.value : ''
                },
                body: 'courseId=' + courseId + '&rating=' + rating + '&message=' + encodeURIComponent(message)
            })
            .then(r => r.json())
            .then(function(res) {
                if (res.success) {
                    msgEl.innerHTML = '<div style="background:rgba(0,196,168,0.1);border:1px solid rgba(0,196,168,0.25);color:#6ee7b7;padding:12px 16px;border-radius:10px;margin-bottom:14px;font-size:13px;font-weight:600;"><i class="fa fa-circle-check"></i> ' + res.message + '</div>';
                    document.getElementById('review-form-inner').style.opacity = '0.5';
                    document.getElementById('review-form-inner').style.pointerEvents = 'none';
                } else {
                    msgEl.innerHTML = '<div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#fca5a5;padding:12px 16px;border-radius:10px;margin-bottom:14px;font-size:13px;font-weight:600;"><i class="fa fa-circle-xmark"></i> ' + res.message + '</div>';
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa fa-paper-plane"></i> Rəy Göndər';
                }
            });
        }

        // Mark video as watched when it ends
        function markVideoWatched(videoId, courseId, videoEl) {
            fetch('/CourseDetail/MarkWatched', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'videoId=' + videoId + '&courseId=' + courseId
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    // İkon yenilə
                    var li = videoEl.closest('li');
                    if (li) {
                        var icon = li.querySelector('i.fa-regular');
                        if (icon) {
                            icon.className = 'fa-solid fa-circle-check';
                            icon.style.color = '#00c4a8';
                        }
                        var titleEl = li.querySelector('span[style*="font-weight:500"]');
                        if (titleEl) {
                            titleEl.style.textDecoration = 'line-through';
                            titleEl.style.color = '#64748b';
                        }
                    }
                    // Progress bar yenilə
                    if (res.percent !== undefined) {
                        var bar = document.querySelector('[style*="linear-gradient(90deg,#00c4a8"]');
                        if (bar) bar.style.width = res.percent + '%';
                        var counter = document.querySelector('[style*="izlənildi"]');
                        if (counter) counter.textContent = res.watchedCount + '/' + res.totalVideos + ' izlənildi';
                    }
                }
            })
            .catch(() => {});
        }
    </script>
    @Html.AntiForgeryToken()
}