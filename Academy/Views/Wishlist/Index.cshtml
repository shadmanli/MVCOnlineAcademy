@{
    ViewData["Title"] = "Wishlist";
}

@section css {
    <style>
        /* --- Fix Header Visibility & Design for Wishlist Page matching Basket --- */
        header, #top-bar {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
            padding: 12px 0;
        }

        #top-bar .menu-list li a:hover {
            color: #ff6d34 !important;
            transition: 0.3s;
        }
        /* ------------------------------------------- */
    </style>
}

<section id="wishlist-page" style="padding: 60px 0; min-height: 50vh;">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 style="font-weight: 700; color: #2d3748;">Sizin Wishlist (<span id="wishlist-page-count">0</span>)</h2>
                <p style="color: #718096; max-width: 600px; margin: 0 auto; margin-top:70px;">Bəyəndiyiniz və izləmək istədiyiniz kursları burada saxlaya bilərsiniz.</p>
            </div>
        </div>

        <div class="row" id="wishlist-container" style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;margin-top:30px;">
          
        </div>

        <div id="empty-wishlist" style="display: none; text-align: center; margin-top: 40px;">
            <i class="far fa-heart" style="font-size: 80px; color: #cbd5e0; margin-bottom: 20px;"></i>
            <h3>Wishlist-iniz boşdur</h3>
            <p>Hələ heç bir kurs əlavə etməmisiniz. Maraqlandığınız kurslara göz atın!</p>
            <a href="/Course/Index" style="display: inline-block; padding: 10px 25px; background: #00bfa6; color: white; border-radius: 6px; text-decoration: none; font-weight: 600; margin-top: 15px;">Kurslara Göz At</a>
        </div>
    </div>
</section>