@model Academy.Models.LiveClass
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Room | @Model?.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #022c22;
            --panel-dark: #064e3b;
            --border-dark: #047857;
            --accent: #00ff87;
            --accent-glow: rgba(0, 255, 135, 0.4);
            --text-main: #f8fafc;
            --text-muted: #a7f3d0;
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background-image: radial-gradient(circle at 10% 20%, rgba(0,255,135,0.05), transparent 40%),
                              radial-gradient(circle at 90% 80%, rgba(0,255,135,0.1), transparent 40%);
        }
        #loadingOverlay {
            position: fixed; inset: 0;
            background: rgba(2,44,34,0.92); backdrop-filter: blur(15px);
            z-index: 9999; display: flex; flex-direction: column;
            align-items: center; justify-content: center; transition: opacity 0.6s ease;
        }
        .loader-ring {
            width: 80px; height: 80px;
            border: 4px solid rgba(0,255,135,0.1); border-left-color: var(--accent);
            border-radius: 50%; animation: spin 1s linear infinite;
            margin-bottom: 24px; box-shadow: 0 0 20px var(--accent-glow);
        }
        #loadingOverlay h2 { font-weight:600; font-size:24px; letter-spacing:0.5px; text-shadow:0 0 10px var(--accent-glow); }
        #loadingOverlay p  { color:var(--text-muted); font-size:15px; margin-top:8px; }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .room-header {
            display:flex; justify-content:space-between; align-items:center;
            padding:12px 24px; background-color:rgba(6,78,59,0.6); backdrop-filter:blur(10px);
            border-bottom:1px solid rgba(0,255,135,0.1); height:70px; z-index:10;
        }
        .header-info { display:flex; align-items:center; gap:16px; }
        .header-info .shield { color:var(--accent); font-size:20px; filter:drop-shadow(0 0 8px var(--accent-glow)); }
        .header-info h2 { font-size:18px; font-weight:600; margin:0; }
        .header-info p  { font-size:13px; color:var(--text-muted); margin:0; }
        .course-badge { background:rgba(0,255,135,0.1); color:#00ff87; padding:6px 12px; border-radius:8px; font-size:12px; border:1px solid rgba(0,255,135,0.3); font-weight:600; }
        .header-actions { display:flex; gap:12px; align-items:center; }
        .badge-rec { background:rgba(239,68,68,0.15); color:var(--danger); padding:4px 12px; border-radius:12px; font-size:12px; font-weight:600; display:flex; align-items:center; gap:6px; animation:pulse-red 2s infinite; }
        @@keyframes pulse-red { 0%,100%{opacity:1;} 50%{opacity:0.5;} }
        .room-main { flex:1; display:flex; overflow:hidden; position:relative; }
        .video-container { flex:1; padding:24px; display:flex; flex-direction:column; gap:20px; }
        .speaker-view {
            flex:1; background:#000; border-radius:20px; position:relative; overflow:hidden;
            display:flex; align-items:center; justify-content:center;
            box-shadow:0 10px 40px rgba(0,0,0,0.5),inset 0 0 0 1px rgba(0,255,135,0.2);
        }
        .name-tag { position:absolute; bottom:20px; left:20px; background:rgba(2,44,34,0.7); backdrop-filter:blur(10px); padding:8px 16px; border-radius:12px; font-size:14px; border:1px solid rgba(0,255,135,0.2); display:flex; align-items:center; gap:8px; z-index:2; }
        .mic-status { color:var(--success); }
        .mic-status.muted { color:var(--danger); }
        .participants-grid { display:flex; gap:12px; height:140px; overflow-x:auto; padding-bottom:8px; }
        .participants-grid::-webkit-scrollbar { height:6px; }
        .participants-grid::-webkit-scrollbar-thumb { background:var(--border-dark); border-radius:3px; }
        .grid-video { min-width:220px; height:100%; background:var(--panel-dark); border-radius:12px; position:relative; display:flex; align-items:center; justify-content:center; border:1px solid var(--border-dark); }
        .side-panel { width:320px; background-color:var(--panel-dark); border-left:1px solid var(--border-dark); display:flex; flex-direction:column; transition:transform 0.3s cubic-bezier(0.4,0,0.2,1),margin 0.3s; }
        .side-panel.hidden { transform:translateX(100%); margin-right:-320px; }
        .panel-header { display:flex; border-bottom:1px solid var(--border-dark); background:var(--bg-dark); }
        .panel-tab { flex:1; padding:16px 0; text-align:center; background:transparent; border:none; color:var(--text-muted); font-size:13px; font-weight:600; cursor:pointer; transition:0.2s; }
        .panel-tab:hover { color:var(--text-main); }
        .panel-tab.active { color:var(--accent); border-bottom:2px solid var(--accent); }
        .panel-body { flex:1; padding:16px; overflow-y:auto; display:flex; flex-direction:column; }
        .chat-list { flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:16px; margin-bottom:16px; }
        .msg { display:flex; flex-direction:column; gap:4px; }
        .msg-header { display:flex; justify-content:space-between; font-size:12px; color:var(--text-muted); }
        .msg-bubble { background:var(--bg-dark); padding:10px 14px; border-radius:12px; border-bottom-left-radius:4px; font-size:13px; line-height:1.5; border:1px solid var(--border-dark); }
        .msg.me { align-items:flex-end; }
        .msg.me .msg-bubble { background:var(--accent); color:#022c22; border-color:transparent; border-bottom-left-radius:12px; border-bottom-right-radius:4px; }
        .chat-input-wrapper { display:flex; gap:8px; }
        .chat-input { flex:1; background:var(--bg-dark); border:1px solid var(--border-dark); border-radius:8px; padding:10px 14px; color:white; outline:none; font-size:13px; transition:border 0.3s; }
        .chat-input:focus { border-color:var(--accent); }
        .btn-send { background:var(--accent); color:#022c22; border:none; width:40px; border-radius:8px; cursor:pointer; transition:0.2s; }
        .btn-send:hover { background:#00cc6e; }
        .typing-indicator { font-size:11px; color:var(--accent); margin-top:4px; display:none; }
        .system-msg { text-align:center; font-size:11px; color:var(--text-muted); opacity:0.7; margin:8px 0; }
        .chat-badge { position:absolute; top:-5px; right:-5px; background:var(--danger); color:white; border-radius:50%; font-size:10px; width:16px; height:16px; display:flex; align-items:center; justify-content:center; opacity:0; transition:0.3s; }
        .chat-badge.show { opacity:1; }
        .user-list { display:none; flex-direction:column; gap:12px; }
        .user-item { display:flex; align-items:center; justify-content:space-between; background:var(--bg-dark); padding:10px 12px; border-radius:8px; }
        .user-info { display:flex; align-items:center; gap:10px; font-size:14px; }
        .user-avatar { width:32px; height:32px; background:rgba(255,255,255,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; }
        .user-controls { display:flex; gap:12px; color:var(--text-muted); font-size:14px; }
        .bottom-bar { height:80px; background-color:var(--panel-dark); border-top:1px solid var(--border-dark); display:flex; justify-content:space-between; align-items:center; padding:0 32px; z-index:10; }
        .control-group { display:flex; gap:10px; align-items:center; }
        .ctrl-btn { background:transparent; border:1px solid transparent; color:var(--text-main); width:48px; height:48px; border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; transition:all 0.2s; font-size:18px; }
        .ctrl-btn:hover { background:rgba(255,255,255,0.05); }
        .ctrl-btn.active { color:var(--accent); background:rgba(0,255,135,0.1); }
        .ctrl-btn.danger { color:var(--danger); background:rgba(239,68,68,0.1); }
        .ctrl-btn.danger:hover { background:rgba(239,68,68,0.2); }
        .ctrl-btn-text { background:var(--danger); color:white; border:none; padding:0 20px; height:40px; border-radius:8px; font-weight:600; font-size:14px; cursor:pointer; transition:0.2s; }
        .ctrl-btn-text:hover { background:#dc2626; }
        .share-btn { color:var(--success); }
        @@keyframes slideIn { from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);} }
        @@keyframes fadeIn  { from{opacity:0;}to{opacity:1;} }
    </style>
</head>
<body>

    <div id="loadingOverlay">
        <div class="loader-ring"></div>
        <h2>Otağa Qoşulur...</h2>
        <p>Təhlükəsiz bağlantı qurulur, zəhmət olmasa gözləyin.</p>
    </div>

    <header class="room-header">
        <div class="header-info">
            <i class="fa-solid fa-shield-halved shield"></i>
            <div>
                <h2>@Model?.Title</h2>
                <p>Müəllim: @Model?.Instructor?.FullName &bull; <span id="timer">00:00:00</span> &bull; <i class="fa-solid fa-users"></i> <span id="participantCount">1</span></p>
            </div>
            <span class="course-badge">@Model?.Course?.Title</span>
        </div>
        <div class="header-actions">
            <div class="badge-rec"><i class="fa-solid fa-circle"></i> REC</div>
        </div>
    </header>

    <main class="room-main">
        <div class="video-container">
            <div class="speaker-view" style="padding:0;position:relative;">
                <video id="localVideo" autoplay muted playsinline style="width:100%;height:100%;object-fit:cover;"></video>
                <div class="name-tag">
                    <i class="fa-solid fa-microphone-slash mic-status muted" id="localMicIcon"></i>
                    @(ViewBag.CurrentFullName) @((ViewBag.IsTeacher != null && ViewBag.IsTeacher) ? "(Host)" : "") (Siz)
                    <span id="localHandIcon" style="margin-left:5px;display:none;">✋</span>
                </div>
            </div>
            <div class="participants-grid" id="remoteVideosGrid"></div>
        </div>

        <aside class="side-panel" id="sidePanel">
            <div class="panel-header">
                <button class="panel-tab active" onclick="switchTab('chat',event)"><i class="fa-regular fa-comment-dots"></i> Chat</button>
                <button class="panel-tab" onclick="switchTab('users',event)"><i class="fa-solid fa-user-group"></i> İştirakçılar</button>
            </div>
            <div class="panel-body">
                <div id="tabChat" style="display:flex;flex-direction:column;height:100%;">
                    <div class="chat-list" id="chatList"></div>
                    <div class="typing-indicator" id="typingIndicator"></div>
                    <div class="chat-input-wrapper">
                        <input type="text" class="chat-input" id="chatInput" placeholder="Mesaj yaz...">
                        <button class="btn-send" id="btnSend"><i class="fa-solid fa-paper-plane"></i></button>
                    </div>
                </div>
                <div id="tabUsers" class="user-list">
                    <div class="user-item">
                        <div class="user-info">
                            <div class="user-avatar">@(Model?.Instructor?.FullName?.FirstOrDefault().ToString())</div>
                            <span>@(Model?.Instructor?.FullName) (Host)</span>
                        </div>
                        <div class="user-controls">
                            <i class="fa-solid fa-microphone"></i>
                            <i class="fa-solid fa-video"></i>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </main>

    <footer class="bottom-bar">
        <div class="control-group">
            <button class="ctrl-btn danger" id="micBtn" onclick="toggleMic()" title="Mikrofonu Aç/Bağla">
                <i class="fa-solid fa-microphone-slash"></i>
            </button>
            <button class="ctrl-btn danger" id="camBtn" onclick="toggleCamera()" title="Kameranı Aç/Bağla">
                <i class="fa-solid fa-video-slash"></i>
            </button>
        </div>
        <div class="control-group">
            <button class="ctrl-btn share-btn" id="shareBtn" title="Ekran Paylaş" onclick="toggleScreenShare()">
                <i class="fa-solid fa-display"></i>
            </button>
            <button class="ctrl-btn" id="handRaiseBtn" title="Əl Qaldır" onclick="toggleHandRaise()">
                <i class="fa-regular fa-hand"></i>
            </button>
            <button class="ctrl-btn active" id="chatBtn" onclick="togglePanel()" style="position:relative;">
                <i class="fa-solid fa-message"></i>
                <div class="chat-badge" id="unreadBadge">0</div>
            </button>
        </div>
        <div class="control-group">
            <form action="/CourseDetail/Index/@Model?.CourseId" method="get" style="margin:0;">
                <button type="submit" class="ctrl-btn-text">Tərk Et</button>
            </form>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const roomId        = "@Model?.RoomId";
        const currentUserId = "@ViewBag.CurrentUserId";
        const fullName      = "@Html.Raw(ViewBag.CurrentFullName)";
        const isTeacher     = @((ViewBag.IsTeacher != null && (bool)ViewBag.IsTeacher) ? "true" : "false");

        let localStream     = null;
        let screenStream    = null;
        let isMicOn         = false;
        let isCameraOn      = false;
        let isScreenSharing = false;
        let isHandRaised    = false;
        let unreadCount     = 0;
        let typingTimeout   = null;
        let totalParticipants = 1;
        const peers   = {};
        const rtcConfig = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/liveclasshub")
            .withAutomaticReconnect([0,2000,5000,10000,20000])
            .build();

        const chatList         = document.getElementById('chatList');
        const chatInput        = document.getElementById('chatInput');
        const btnSend          = document.getElementById('btnSend');
        const typingIndicator  = document.getElementById('typingIndicator');
        const remoteVideosGrid = document.getElementById('remoteVideosGrid');

        let seconds = 0;
        setInterval(() => {
            seconds++;
            const h = String(Math.floor(seconds/3600)).padStart(2,'0');
            const m = String(Math.floor((seconds%3600)/60)).padStart(2,'0');
            const s = String(seconds%60).padStart(2,'0');
            document.getElementById('timer').innerText = `${h}:${m}:${s}`;
        }, 1000);

        window.addEventListener('load', () => {
            setTimeout(() => {
                const ov = document.getElementById('loadingOverlay');
                ov.style.opacity = '0';
                setTimeout(() => { ov.style.display = 'none'; }, 600);
            }, 1500);
        });

        function scrollToBottom() { chatList.scrollTop = chatList.scrollHeight; }

        function switchTab(tab, e) {
            document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
            if (e && e.currentTarget) e.currentTarget.classList.add('active');
            document.getElementById('tabChat').style.display  = tab==='chat'  ? 'flex' : 'none';
            document.getElementById('tabUsers').style.display = tab==='users' ? 'flex' : 'none';
            if (tab==='chat') {
                unreadCount=0;
                const b=document.getElementById('unreadBadge'); b.innerText='0'; b.classList.remove('show');
                scrollToBottom();
            }
        }

        function togglePanel() {
            document.getElementById('sidePanel').classList.toggle('hidden');
            document.getElementById('chatBtn').classList.toggle('active');
        }

        function updateParticipantCount(n) { document.getElementById('participantCount').innerText=n; }

        function appendMessage(sender,text,time,isMe,senderIsTeacher) {
            const d=document.createElement('div');
            d.className=`msg ${isMe?'me':''}`;
            const hc=senderIsTeacher?'color:var(--accent);font-weight:bold;':'color:var(--text-muted);';
            const badge=senderIsTeacher?' <i class="fa-solid fa-graduation-cap" style="font-size:10px;margin-left:4px;"></i>':'';
            const safe=text.replace(/</g,'&lt;').replace(/>/g,'&gt;');
            d.innerHTML=`<div class="msg-header"><span style="${hc}">${sender}${badge}</span><span>${time}</span></div><div class="msg-bubble" style="animation:slideIn 0.3s ease;">${safe}</div>`;
            chatList.appendChild(d); scrollToBottom();
            const ph=document.getElementById('sidePanel').classList.contains('hidden');
            const ch=document.getElementById('tabChat').style.display==='none';
            if(!isMe&&(ph||ch)){unreadCount++;const b=document.getElementById('unreadBadge');b.innerText=unreadCount>9?'9+':unreadCount;b.classList.add('show');}
        }

        function appendSystemMessage(text,time) {
            const el=document.createElement('div');
            el.className='system-msg'; el.style.animation='fadeIn 0.5s ease';
            el.innerHTML=`<span>${text}</span>${time?` <span style="font-size:9px;opacity:0.5;margin-left:4px;">${time}</span>`:''}`;
            chatList.appendChild(el); scrollToBottom();
        }

        async function sendMessage() {
            const text=chatInput.value.trim(); if(!text)return;
            chatInput.value='';
            try { await connection.invoke("SendMessage",roomId,text,fullName,isTeacher); }
            catch(err){ appendSystemMessage("Mesaj göndərilə bilmədi.",""); }
        }

        btnSend.addEventListener('click',sendMessage);
        chatInput.addEventListener('keypress',(e)=>{
            if(e.key==='Enter'){e.preventDefault();sendMessage();}
            else {
                connection.invoke("UserTyping",roomId,fullName,true).catch(()=>{});
                clearTimeout(typingTimeout);
                typingTimeout=setTimeout(()=>connection.invoke("UserTyping",roomId,fullName,false).catch(()=>{}),2000);
            }
        });

        async function initLocalMedia() {
            try {
                localStream=await navigator.mediaDevices.getUserMedia({video:{width:{ideal:1280},height:{ideal:720}},audio:true});
                document.getElementById('localVideo').srcObject=localStream;
                localStream.getAudioTracks().forEach(t=>t.enabled=false);
                localStream.getVideoTracks().forEach(t=>t.enabled=false);
                isMicOn=false; isCameraOn=false;
            } catch(err){ appendSystemMessage('Kamera/mikrofon icazəsi verilmədi. Yalnız chat işləyəcək.',''); }
        }

        async function toggleMic() {
            const btn=document.getElementById('micBtn');
            if(!localStream){await initLocalMedia();} if(!localStream)return;
            isMicOn=!isMicOn;
            localStream.getAudioTracks().forEach(t=>t.enabled=isMicOn);
            const icon=btn.querySelector('i');
            if(isMicOn){btn.classList.remove('danger');icon.className='fa-solid fa-microphone';document.getElementById('localMicIcon').className='fa-solid fa-microphone mic-status';}
            else{btn.classList.add('danger');icon.className='fa-solid fa-microphone-slash';document.getElementById('localMicIcon').className='fa-solid fa-microphone-slash mic-status muted';}
            connection.invoke('ToggleMic',roomId,isMicOn).catch(()=>{});
        }

        async function toggleCamera() {
            const btn=document.getElementById('camBtn');
            if(!localStream){await initLocalMedia();} if(!localStream)return;
            isCameraOn=!isCameraOn;
            localStream.getVideoTracks().forEach(t=>t.enabled=isCameraOn);
            const icon=btn.querySelector('i');
            if(isCameraOn){btn.classList.remove('danger');icon.className='fa-solid fa-video';}
            else{btn.classList.add('danger');icon.className='fa-solid fa-video-slash';}
            connection.invoke('ToggleVideo',roomId,isCameraOn).catch(()=>{});
        }

        async function toggleScreenShare() {
            const btn=document.getElementById('shareBtn');
            if(isScreenSharing){
                if(screenStream){screenStream.getTracks().forEach(t=>t.stop());screenStream=null;}
                if(localStream){
                    document.getElementById('localVideo').srcObject=localStream;
                    const vt=localStream.getVideoTracks()[0];
                    if(vt){Object.values(peers).forEach(pc=>{const s=pc.getSenders().find(s=>s.track&&s.track.kind==='video');if(s)s.replaceTrack(vt);});}
                }
                isScreenSharing=false; btn.style.color='var(--success)';
                connection.invoke('ToggleScreenShare',roomId,false).catch(()=>{});
                appendSystemMessage('Ekran paylaşması dayandırıldı.','');
            } else {
                try {
                    screenStream=await navigator.mediaDevices.getDisplayMedia({video:true,audio:false});
                    document.getElementById('localVideo').srcObject=screenStream;
                    const st=screenStream.getVideoTracks()[0];
                    Object.values(peers).forEach(pc=>{const s=pc.getSenders().find(s=>s.track&&s.track.kind==='video');if(s)s.replaceTrack(st);});
                    st.onended=()=>toggleScreenShare();
                    isScreenSharing=true; btn.style.color='var(--accent)';
                    connection.invoke('ToggleScreenShare',roomId,true).catch(()=>{});
                    appendSystemMessage('Ekranınızı paylaşırsınız.','');
                } catch(err){ if(err.name!=='NotAllowedError') appendSystemMessage('Ekran paylaşması xətası: '+err.message,''); }
            }
        }

        async function toggleHandRaise() {
            isHandRaised=!isHandRaised;
            document.getElementById('handRaiseBtn').style.color=isHandRaised?'var(--warning)':'';
            document.getElementById('localHandIcon').style.display=isHandRaised?'inline':'none';
            connection.invoke('RaiseHand',roomId).catch(()=>{});
        }

        function setupRemoteVideo(user) {
            if(document.getElementById('grid-card-'+user.connectionId))return;
            const card=document.createElement('div');
            card.className='grid-video'; card.id='grid-card-'+user.connectionId;
            const hl=user.isTeacher?' (Host)':'';
            card.innerHTML=`<video id="video-${user.connectionId}" autoplay playsinline style="width:100%;height:100%;object-fit:cover;border-radius:12px;"></video><div class="name-tag" style="font-size:11px;padding:4px 8px;bottom:8px;left:8px;"><i class="fa-solid fa-microphone mic-status" id="mic-icon-${user.connectionId}"></i>${user.fullName}${hl}<span id="hand-icon-${user.connectionId}" style="margin-left:5px;display:none;">✋</span></div>`;
            remoteVideosGrid.appendChild(card);
        }

        function removeRemoteVideo(cid) { const c=document.getElementById('grid-card-'+cid); if(c)c.remove(); }

        async function createPeerConnection(remoteUser, isInitiator) {
            const pc=new RTCPeerConnection(rtcConfig);
            peers[remoteUser.connectionId]=pc;
            if(localStream) localStream.getTracks().forEach(t=>pc.addTrack(t,localStream));
            pc.onicecandidate=ev=>{ if(ev.candidate) connection.invoke("SendIceCandidate",remoteUser.connectionId,JSON.stringify(ev.candidate)).catch(()=>{}); };
            pc.ontrack=ev=>{ const v=document.getElementById('video-'+remoteUser.connectionId); if(v&&ev.streams[0])v.srcObject=ev.streams[0]; };
            pc.onconnectionstatechange=()=>{ if(pc.connectionState==='failed')pc.restartIce(); };
            if(isInitiator){
                const offer=await pc.createOffer({offerToReceiveAudio:true,offerToReceiveVideo:true});
                await pc.setLocalDescription(offer);
                await connection.invoke("SendOffer",remoteUser.connectionId,JSON.stringify(pc.localDescription));
            }
            return pc;
        }

        function setHandRaise(cid,raised,name){
            const isLocal=cid===connection.connectionId;
            const icon=isLocal?document.getElementById('localHandIcon'):document.getElementById('hand-icon-'+cid);
            if(icon)icon.style.display=raised?'inline':'none';
            if(raised&&isTeacher&&!isLocal)appendSystemMessage(name+' əl qaldırdı ✋','');
        }

        connection.on("ReceiveMessage",(id,sender,text,time,sIT)=>appendMessage(sender,text,time,sender===fullName,sIT));
        connection.on("ReceiveSystemMessage",(text,time)=>appendSystemMessage(text,time));
        connection.on("UserTypingStatus",(cid,name,typing)=>{ if(name===fullName)return; typingIndicator.innerText=typing?`${name} yazır...`:''; typingIndicator.style.display=typing?'block':'none'; });
        connection.on("ParticipantJoined",async user=>{ appendSystemMessage(user.fullName+" otağa qoşuldu.",""); totalParticipants++; updateParticipantCount(totalParticipants); setupRemoteVideo(user); await createPeerConnection(user,true); });
        connection.on("ParticipantLeft",cid=>{ if(peers[cid]){peers[cid].close();delete peers[cid];} removeRemoteVideo(cid); totalParticipants=Math.max(1,totalParticipants-1); updateParticipantCount(totalParticipants); appendSystemMessage("Bir iştirakçı ayrıldı.",""); });
        connection.on("UpdateParticipants",users=>{ totalParticipants=users.length; updateParticipantCount(totalParticipants); users.forEach(u=>{ if(u.connectionId!==connection.connectionId){setupRemoteVideo(u);if(u.handRaised)setHandRaise(u.connectionId,true,u.fullName);} }); });
        connection.on("ReceiveOffer",async(cid,sdp)=>{ let pc=peers[cid]; if(!pc)pc=await createPeerConnection({connectionId:cid,fullName:"İştirakçı"},false); await pc.setRemoteDescription(new RTCSessionDescription(JSON.parse(sdp))); const ans=await pc.createAnswer(); await pc.setLocalDescription(ans); await connection.invoke("SendAnswer",cid,JSON.stringify(pc.localDescription)); });
        connection.on("ReceiveAnswer",async(cid,sdp)=>{ const pc=peers[cid]; if(pc)await pc.setRemoteDescription(new RTCSessionDescription(JSON.parse(sdp))); });
        connection.on("ReceiveIceCandidate",async(cid,cand)=>{ const pc=peers[cid]; if(pc){try{await pc.addIceCandidate(new RTCIceCandidate(JSON.parse(cand)));}catch(e){}} });
        connection.on("HandRaised",(cid,raised)=>{ const card=document.getElementById('grid-card-'+cid); const name=card?card.querySelector('.name-tag').innerText.split('✋')[0].trim():"İştirakçı"; setHandRaise(cid,raised,name); if(cid===connection.connectionId)document.getElementById('handRaiseBtn').style.color=raised?'var(--warning)':''; });
        connection.on("MicToggled",(cid,state)=>{ const icon=document.getElementById('mic-icon-'+cid); if(icon)icon.className=state?'fa-solid fa-microphone mic-status':'fa-solid fa-microphone-slash mic-status muted'; });
        connection.on("VideoToggled",(cid,state)=>{ const c=document.getElementById('grid-card-'+cid); if(c)c.style.opacity=state?'1':'0.6'; });
        connection.on("KickedOut",()=>{ alert('Müəllim sizi otaqdan çıxardı.'); window.location.href='/'; });
        connection.on("ClassStatusChanged",(rId,status)=>{ if(status==='Ended'){appendSystemMessage('Dərs bitirildi.','');setTimeout(()=>{window.location.href='/CourseDetail/Index/@Model?.CourseId';},3000);} });
        connection.on("ScreenShareToggled",(cid,name,sharing)=>{ if(cid!==connection.connectionId)appendSystemMessage(sharing?name+' ekranını paylaşır 🖥️':name+' ekran paylaşmasını dayandırdı.',''); });
        connection.onreconnecting(()=>appendSystemMessage("Yenidən qoşulma cəhdi...",""));
        connection.onreconnected(()=>appendSystemMessage("Bağlantı bərpa edildi.",""));
        connection.onclose(()=>appendSystemMessage("Bağlantı kəsildi. Səhifəni yeniləyin.",""));

        async function startConnection() {
            try {
                await connection.start();
                chatList.innerHTML='';
                appendSystemMessage("Çata qoşuldunuz. Söhbət şifrələnib.","");
                await initLocalMedia();
                await connection.invoke("JoinRoom",roomId,currentUserId,fullName,isTeacher);
            } catch(err){
                console.error("SignalR xətası:",err);
                appendSystemMessage("Bağlantı xətası. 5 saniyə sonra yenidən cəhd edilir...","");
                setTimeout(startConnection,5000);
            }
        }

        startConnection();
    </script>
</body>
</html>
