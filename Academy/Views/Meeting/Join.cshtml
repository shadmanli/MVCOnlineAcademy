@model Academy.Models.LiveClass
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Room | @Model?.Title</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        :root {
            --bg-dark: #022c22;       /* Dark Emerald */
            --panel-dark: #064e3b;    /* Deeper Emerald */
            --border-dark: #047857;   /* Emerald 700 */
            --accent: #00ff87;        /* Neon Cyan / Green */
            --accent-glow: rgba(0, 255, 135, 0.4);
            --text-main: #f8fafc;
            --text-muted: #a7f3d0;    /* Muted green */
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background-image: radial-gradient(circle at 10% 20%, rgba(0, 255, 135, 0.05), transparent 40%),
                              radial-gradient(circle at 90% 80%, rgba(0, 255, 135, 0.1), transparent 40%);
        }

        /* --- LOADING SCREEN --- */
        #loadingOverlay {
            position: fixed;
            inset: 0;
            background: rgba(2, 44, 34, 0.9);
            backdrop-filter: blur(15px);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.6s ease;
        }

        .loader-ring {
            width: 80px;
            height: 80px;
            border: 4px solid rgba(0, 255, 135, 0.1);
            border-left-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 24px;
            box-shadow: 0 0 20px var(--accent-glow);
        }

        #loadingOverlay h2 { font-weight: 600; font-size: 24px; letter-spacing: 0.5px; text-shadow: 0 0 10px var(--accent-glow); }
        #loadingOverlay p { color: var(--text-muted); font-size: 15px; margin-top: 8px; }

        @@keyframes spin { to { transform: rotate(360deg); } }

        /* --- HEADER --- */
        .room-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 24px;
            background-color: rgba(6, 78, 59, 0.6);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,255,135,0.1);
            height: 70px;
            z-index: 10;
        }

        .header-info { display: flex; align-items: center; gap: 16px; }
        .header-info .shield { color: var(--accent); font-size: 20px; filter: drop-shadow(0 0 8px var(--accent-glow)); }
        .header-info h2 { font-size: 18px; font-weight: 600; margin: 0; text-shadow: 0 0 5px rgba(255,255,255,0.2); }
        .header-info p { font-size: 13px; color: var(--text-muted); margin: 0; }
        .course-badge { background: rgba(0,255,135,0.1); color:#00ff87; padding: 6px 12px; border-radius: 8px; font-size: 12px; border: 1px solid rgba(0,255,135,0.3); font-weight: 600;}

        .header-actions { display: flex; gap: 12px; align-items: center; }

        .badge-rec {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            animation: pulse-red 2s infinite;
        }

        @@keyframes pulse-red {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        /* --- MAIN LAYOUT --- */
        .room-main {
            flex: 1;
            display: flex;
            overflow: hidden;
            position: relative;
        }

        /* VIDEO AREA */
        .video-container {
            flex: 1;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: transparent;
            transition: all 0.3s ease;
        }

        /* Speaker View (Main) */
        .speaker-view {
            flex: 1;
            background: #000;
            border-radius: 20px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(0,255,135,0.2);
        }

        .speaker-avatar {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(6, 78, 59, 1), rgba(4, 120, 87, 1));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            color: var(--accent);
            border: 2px solid var(--accent);
            box-shadow: 0 0 30px var(--accent-glow);
            animation: pulse-avatar 2s infinite ease-in-out;
        }
        
        @@keyframes pulse-avatar {
            0% { box-shadow: 0 0 0 0 rgba(0, 255, 135, 0.4); }
            70% { box-shadow: 0 0 0 20px rgba(0, 255, 135, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 255, 135, 0); }
        }

        .name-tag {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background: rgba(2, 44, 34, 0.7);
            backdrop-filter: blur(10px);
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 14px;
            border: 1px solid rgba(0,255,135,0.2);
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 2;
        }

        .mic-status { color: var(--success); }
        .mic-status.muted { color: var(--danger); }

        /* Grid View (Others) */
        .participants-grid {
            display: flex;
            gap: 12px;
            height: 140px;
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .participants-grid::-webkit-scrollbar { height: 6px; }
        .participants-grid::-webkit-scrollbar-thumb { background: var(--border-dark); border-radius: 3px; }

        .grid-video {
            min-width: 220px;
            height: 100%;
            background: var(--panel-dark);
            border-radius: 12px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-dark);
        }

        /* --- SIDE PANEL --- */
        .side-panel {
            width: 320px;
            background-color: var(--panel-dark);
            border-left: 1px solid var(--border-dark);
            display: flex;
            flex-direction: column;
            transform: translateX(0);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), margin 0.3s;
        }

        .side-panel.hidden {
            transform: translateX(100%);
            margin-right: -320px;
        }

        .panel-header {
            display: flex;
            border-bottom: 1px solid var(--border-dark);
            background: var(--bg-dark);
        }

        .panel-tab {
            flex: 1;
            padding: 16px 0;
            text-align: center;
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }
        .panel-tab:hover { color: var(--text-main); }
        .panel-tab.active { color: var(--accent); border-bottom: 2px solid var(--accent); }

        .panel-body { flex: 1; padding: 16px; overflow-y: auto; display: flex; flex-direction: column; }

        /* Chat */
        .chat-list { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 16px; margin-bottom: 16px; }
        .msg { display: flex; flex-direction: column; gap: 4px; }
        .msg-header { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); }
        .msg-bubble { background: var(--bg-dark); padding: 10px 14px; border-radius: 12px; border-bottom-left-radius: 4px; font-size: 13px; line-height: 1.5; border: 1px solid var(--border-dark); }
        .msg.me { align-items: flex-end; }
        .msg.me .msg-bubble { background: var(--accent); color: white; border-color: transparent; border-bottom-left-radius: 12px; border-bottom-right-radius: 4px; }

        .chat-input-wrapper { display: flex; gap: 8px; }
        .chat-input { flex: 1; background: var(--bg-dark); border: 1px solid var(--border-dark); border-radius: 8px; padding: 10px 14px; color: white; outline: none; font-size: 13px; transition: border 0.3s; }
        .chat-input:focus { border-color: var(--accent); }
        .btn-send { background: var(--accent); color: white; border: none; width: 40px; border-radius: 8px; cursor: pointer; transition: 0.2s; }
        .btn-send:hover { background: #2563eb; }

        .typing-indicator { font-size: 11px; color: var(--accent); margin-top: 4px; display: none; }
        .system-msg { text-align: center; font-size: 11px; color: var(--text-muted); opacity: 0.7; margin: 8px 0; }

        .chat-scroll-to-bottom {
            position: absolute; bottom: 60px; right: 10px; background: rgba(0,255,135,0.2); border: 1px solid var(--accent); color: var(--accent); border-radius: 50%; width: 30px; height: 30px; display: none; align-items: center; justify-content: center; cursor: pointer; z-index: 10;
        }

        .chat-badge {
            position: absolute; top: -5px; right: -5px; background: var(--danger); color: white; border-radius: 50%; font-size: 10px; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.3s;
        }
        .chat-badge.show { opacity: 1; }

        /* Participants List */
        .user-list { display: none; flex-direction: column; gap: 12px; }
        .user-item { display: flex; align-items: center; justify-content: space-between; background: var(--bg-dark); padding: 10px 12px; border-radius: 8px; }
        .user-info { display: flex; align-items: center; gap: 10px; font-size: 14px; }
        .user-avatar { width: 32px; height: 32px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; }
        .user-controls { display: flex; gap: 12px; color: var(--text-muted); font-size: 14px; }

        /* --- BOTTOM CONTROLS --- */
        .bottom-bar {
            height: 80px;
            background-color: var(--panel-dark);
            border-top: 1px solid var(--border-dark);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 32px;
            z-index: 10;
        }

        .control-group { display: flex; gap: 10px; align-items: center; }

        .ctrl-btn {
            background: transparent;
            border: 1px solid transparent;
            color: var(--text-main);
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 18px;
        }

        .ctrl-btn:hover { background: rgba(255,255,255,0.05); }
        .ctrl-btn.active { color: var(--accent); background: rgba(59, 130, 246, 0.1); }

        .ctrl-btn.danger {
            color: var(--danger);
            background: rgba(239, 68, 68, 0.1);
        }
        .ctrl-btn.danger:hover { background: rgba(239, 68, 68, 0.2); }

        .ctrl-btn-text {
            background: var(--danger);
            color: white;
            border: none;
            padding: 0 20px;
            height: 40px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: 0.2s;
        }
        .ctrl-btn-text:hover { background: #dc2626; box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }

        /* Screen Share Specific */
        .share-btn { color: var(--success); }
        .share-btn:hover { background: rgba(16, 185, 129, 0.1); }

    </style>
</head>
<body>

    <!-- Loading Screen -->
    <div id="loadingOverlay">
        <div class="loader-ring"></div>
        <h2>Ota?a Qo?ulur...</h2>
        <p>T?hlük?siz ba?lant? qurulur, z?hm?t olmasa gözl?yin.</p>
    </div>

    <!-- Header -->
    <header class="room-header">
        <div class="header-info">
            <i class="fa-solid fa-shield-halved shield"></i>
            <div>
                <h2>@Model?.Title</h2>
                <p>Müəllim: @Model?.Instructor?.FullName &bull; <span id="timer">00:00:00</span> &bull; <i class="fa-solid fa-users"></i> <span id="participantCount">1</span></p>
            </div>
            <span class="course-badge">@Model?.Course?.Title</span>
        </div>
        <div class="header-actions">
            <div class="badge-rec"><i class="fa-solid fa-circle"></i> REC</div>
            <button class="ctrl-btn" style="width:auto; height:36px; padding: 0 12px; font-size: 14px; border:1px solid var(--border-dark);">
                <i class="fa-solid fa-expand"></i>
            </button>
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="room-main">

        <!-- Video Grid -->
        <div class="video-container">
            <!-- Main Speaker / Local Camera -->
            <div class="speaker-view" style="padding: 0; position: relative;">
                <video id="localVideo" autoplay muted playsinline style="width: 100%; height: 100%; object-fit: cover; border: none;"></video>
                <div class="name-tag">
                    <i class="fa-solid fa-microphone mic-status" id="localMicIcon"></i> 
                    @(ViewBag.CurrentFullName) @((ViewBag.IsTeacher != null && ViewBag.IsTeacher) ? "(Host)" : "") (Siz)
                    <span id="localHandIcon" style="margin-left: 5px; display: none;">✋</span>
                </div>
            </div>

            <!-- Other Participants Grid -->
            <div class="participants-grid" id="remoteVideosGrid">
                <!-- Real participants will be added here dynamically -->
            </div>
        </div>

        <!-- Chat / Participants Panel -->
        <aside class="side-panel" id="sidePanel">
            <div class="panel-header">
                <button class="panel-tab active" onclick="switchTab('chat')"><i class="fa-regular fa-comment-dots"></i> Chat</button>
                <button class="panel-tab" onclick="switchTab('users')"><i class="fa-solid fa-user-group"></i> ??tirakç?lar</button>
            </div>

            <div class="panel-body">
                <!-- Chat Window -->
                <div id="tabChat" style="display: flex; flex-direction: column; height: 100%;">
                    <div class="chat-list">
                        <!-- Messages will appear here -->
                    </div>
                    <div class="chat-input-wrapper">
                        <input type="text" class="chat-input" placeholder="Mesaj yaz...">
                        <button class="btn-send"><i class="fa-solid fa-paper-plane"></i></button>
                    </div>
                    <div class="typing-indicator">...</div>
                    <div class="system-msg">Siz? qo?ulmaq üçün icaz? gözl?nilir...</div>
                </div>

                <!-- Users Window -->
                <div id="tabUsers" class="user-list">
                    <div class="user-item">
                        <div class="user-info">
                            <div class="user-avatar">@(Model?.Instructor?.FullName?.FirstOrDefault().ToString())</div>
                            <span>@(Model?.Instructor?.FullName) (Host)</span>
                        </div>
                        <div class="user-controls">
                            <i class="fa-solid fa-microphone"></i>
                            <i class="fa-solid fa-video"></i>
                        </div>
                    </div>
                    <div class="user-item">
                        <div class="user-info">
                            <div class="user-avatar">S</div>
                            <span>S?n</span>
                        </div>
                        <div class="user-controls">
                            <i class="fa-solid fa-microphone-slash" style="color:var(--danger)"></i>
                            <i class="fa-solid fa-video-slash" style="color:var(--danger)"></i>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

    </main>

    <!-- Bottom Controls -->
    <footer class="bottom-bar">

        <div class="control-group">
            <button class="ctrl-btn danger" id="micBtn" onclick="toggleState(this, 'fa-microphone', 'fa-microphone-slash')" title="Mikrofonu Aç/Ba?la">
                <i class="fa-solid fa-microphone-slash"></i>
            </button>
            <button class="ctrl-btn danger" id="camBtn" onclick="toggleState(this, 'fa-video', 'fa-video-slash')" title="Kameran? Aç/Ba?la">
                <i class="fa-solid fa-video-slash"></i>
            </button>
        </div>

        <div class="control-group">
            <button class="ctrl-btn share-btn" title="Ekran Paylaş" onclick="toggleScreenShare()">
                <i class="fa-solid fa-display"></i>
            </button>
            <button class="ctrl-btn" title="Əl Qaldır" onclick="toggleHandRaise()" id="handRaiseBtn">
                <i class="fa-regular fa-hand"></i>
            </button>
            <button class="ctrl-btn active" id="chatBtn" onclick="togglePanel()" title="Paneli Aç/Bağla" style="position:relative;">
                <i class="fa-solid fa-message"></i>
                <div class="chat-badge" id="unreadBadge">0</div>
            </button>
        </div>

        <div class="control-group">
            <form action="/CourseDetail/Index/@Model?.CourseId" method="get" style="margin:0;">
                <button type="submit" class="ctrl-btn-text">
                    T?rk Et
                </button>
            </form>
        </div>

    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        // 1. Smooth Loading
        window.addEventListener('load', () => {
            setTimeout(() => {
                const overlay = document.getElementById('loadingOverlay');
                overlay.style.opacity = '0';
                setTimeout(() => { overlay.style.display = 'none'; }, 600);
            }, 1500); // Süni gecikm? (ba?lant? qurulur hissi üçün)
        });

        // 2. Timer Logic
        let seconds = 0;
        setInterval(() => {
            seconds++;
            const hrs = String(Math.floor(seconds / 3600)).padStart(2, '0');
            const mins = String(Math.floor((seconds % 3600) / 60)).padStart(2, '0');
            const secs = String(seconds % 60).padStart(2, '0');
            document.getElementById('timer').innerText = `${hrs}:${mins}:${secs}`;
        }, 1000);

        // 3. UI Toggles
        function toggleState(btn, iconOn, iconOff) {
            const icon = btn.querySelector('i');
            if (btn.classList.contains('danger')) {
                // Turn ON
                btn.classList.remove('danger');
                icon.classList.remove(iconOff);
                icon.classList.add(iconOn);
            } else {
                // Turn OFF
                btn.classList.add('danger');
                icon.classList.remove(iconOn);
                icon.classList.add(iconOff);
            }
        }

        // Toggle Panel
        function togglePanel() {
            const panel = document.getElementById('sidePanel');
            const btn = document.getElementById('chatBtn');
            panel.classList.toggle('hidden');
            btn.classList.toggle('active');
        }

        // Switch Tabs (Chat / Users)
        function switchTab(tab) {
            document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
            document.getElementById('tabChat').style.display = (tab === 'chat') ? 'flex' : 'none';
            document.getElementById('tabUsers').style.display = (tab === 'users') ? 'flex' : 'none';

            if(tab === 'chat') {
                unreadCount = 0;
                document.getElementById('unreadBadge').classList.remove('show');
                document.getElementById('unreadBadge').innerText = '0';
                scrollToBottom();
            }

            event.currentTarget.classList.add('active');
        }

        // ==========================================
        // REALTIME CHAT SYSTEM (SignalR)
        // ==========================================
        const roomId = "@Model?.RoomId";
        const currentUserId = "@ViewBag.CurrentUserId";
        const fullName = "@Html.Raw(ViewBag.CurrentFullName)";
        const isTeacher = @(ViewBag.IsTeacher?.ToString().ToLower() ?? "false"); 

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/liveclasshub")
            .withAutomaticReconnect([0, 2000, 5000, 10000, 20000])
            .build();

        const chatList = document.querySelector('.chat-list');
        const chatInput = document.querySelector('.chat-input');
        const btnSend = document.querySelector('.btn-send');
        const typingIndicator = document.querySelector('.typing-indicator');
        let unreadCount = 0;
        let typingTimeout;

        // Auto Scroll
        function scrollToBottom() {
            chatList.scrollTop = chatList.scrollHeight;
        }

        // Add Message to UI
        function appendMessage(sender, text, time, isMe, isTeacherMsg) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `msg ${isMe ? 'me' : ''}`;
            
            const headerColor = isTeacherMsg ? 'color:var(--accent); font-weight:bold;' : 'color:var(--text-muted);';
            const badge = isTeacherMsg ? ' <i class="fa-solid fa-graduation-cap" style="font-size:10px; margin-left:4px;" title="Mü?llim"></i>' : '';

            msgDiv.innerHTML = `
                <div class="msg-header"><span style="${headerColor}">${sender}${badge}</span> <span>${time}</span></div>
                <div class="msg-bubble" style="animation: slideIn 0.3s ease;">${text.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</div>
            `;
            chatList.appendChild(msgDiv);
            scrollToBottom();

            // Unread count
            const panelHidden = document.getElementById('sidePanel').classList.contains('hidden');
            const chatNotActive = document.getElementById('tabChat').style.display === 'none';
            if (!isMe && (panelHidden || chatNotActive)) {
                unreadCount++;
                const badgeEl = document.getElementById('unreadBadge');
                badgeEl.innerText = unreadCount > 9 ? '9+' : unreadCount;
                badgeEl.classList.add('show');
                
                // Play notification sound if needed
            }
        }

        function appendSystemMessage(text, time) {
            const msgDiv = document.createElement('div');
            msgDiv.className = 'system-msg';
            msgDiv.style.animation = "fadeIn 0.5s ease";
            msgDiv.innerHTML = `<span>${text}</span> <span style="font-size:9px; opacity:0.5; margin-left:4px;">${time}</span>`;
            chatList.appendChild(msgDiv);
            scrollToBottom();
        }

        // Send Message
        async function sendMessage() {
            const text = chatInput.value.trim();
            if (!text) return;

            chatInput.value = '';
            
            try {
                // Optimistic UI update can go here, but since SignalR is fast, we rely on server loopback for exact sync
                // Or we handle loopback on server and filter. The server currently broadcasts to the group.
                await connection.invoke("SendMessage", roomId, text, fullName, isTeacher);
            } catch (err) {
                console.error("X?ta ba? verdi: ", err);
                appendSystemMessage("Mesaj gönd?ril? bilm?di. Ba?lant?n? yoxlay?n.", "");
            }
        }

        // Listeners
        btnSend.addEventListener('click', sendMessage);
        chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                sendMessage();
            } else {
                connection.invoke("UserTyping", roomId, fullName, true);
                clearTimeout(typingTimeout);
                typingTimeout = setTimeout(() => {
                    connection.invoke("UserTyping", roomId, fullName, false);
                }, 2000);
            }
        });

        // Socket Events
        connection.on("ReceiveMessage", (msgId, sender, text, time, senderIsTeacher) => {
            const isMe = sender === fullName; // simple check
            appendMessage(sender, text, time, isMe, senderIsTeacher);
        });

        connection.on("ReceiveSystemMessage", (text, time) => {
            appendSystemMessage(text, time);
        });

        connection.on("UserTypingStatus", (connId, typerName, isTyping) => {
            if (typerName === fullName) return;
            if (isTyping) {
                typingIndicator.innerText = `${typerName} yazır...`;
                typingIndicator.style.display = 'block';
            } else {
                typingIndicator.style.display = 'none';
            }
        });

        const peers = {}; 
        const rtcConfig = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };
        const remoteVideosGrid = document.getElementById('remoteVideosGrid');

        function setupRemoteVideo(user) {
            if(document.getElementById('grid-card-' + user.connectionId)) return;
            
            const card = document.createElement('div');
            card.className = 'grid-video';
            card.id = 'grid-card-' + user.connectionId;
            
            let hostLabel = user.isTeacher ? " (Host)" : "";
            
            card.innerHTML = `
                <video id="video-${user.connectionId}" autoplay playsinline style="width:100%; height:100%; object-fit:cover; border-radius:12px;"></video>
                <div class="name-tag" style="font-size:11px; padding: 4px 8px; bottom:8px; left:8px;">
                    <i class="fa-solid fa-microphone mic-status" id="mic-icon-${user.connectionId}"></i> 
                    ${user.fullName}${hostLabel}
                    <span id="hand-icon-${user.connectionId}" style="margin-left: 5px; display: none;">✋</span>
                </div>
            `;
            
            if (isTeacher && !user.isTeacher) {
                card.innerHTML += `<button onclick="connection.invoke('LowerHand', roomId, '${user.connectionId}')" id="lower-hand-btn-${user.connectionId}" style="position:absolute; top:8px; right:8px; display:none; background:red; color:white; border:none; border-radius:4px; font-size:10px; padding:4px; cursor:pointer;">Əli İndir</button>`;
            }
            
            remoteVideosGrid.appendChild(card);
        }

        function removeRemoteVideo(connectionId) {
            const card = document.getElementById('grid-card-' + connectionId);
            if(card) card.remove();
        }

        let totalParticipants = 1;
        function updateParticipantCount(count) {
            document.getElementById('participantCount').innerText = count;
        }

        async function createPeerConnection(remoteUser, isInitiator) {
            const pc = new RTCPeerConnection(rtcConfig);
            peers[remoteUser.connectionId] = pc;

            if (localStream) {
                localStream.getTracks().forEach(track => pc.addTrack(track, localStream));
            }

            // ICE candidate — yeni SendIceCandidate metodu
            pc.onicecandidate = event => {
                if (event.candidate) {
                    connection.invoke("SendIceCandidate", remoteUser.connectionId,
                        JSON.stringify(event.candidate));
                }
            };

            pc.ontrack = event => {
                const remoteVideo = document.getElementById('video-' + remoteUser.connectionId);
                if (remoteVideo && event.streams[0]) {
                    remoteVideo.srcObject = event.streams[0];
                }
            };

            pc.onconnectionstatechange = () => {
                if (pc.connectionState === 'failed') {
                    pc.restartIce();
                }
            };

            if (isInitiator) {
                const offer = await pc.createOffer({ offerToReceiveAudio: true, offerToReceiveVideo: true });
                await pc.setLocalDescription(offer);
                // Yeni SendOffer metodu
                await connection.invoke("SendOffer", remoteUser.connectionId,
                    JSON.stringify(pc.localDescription));
            }

            return pc;
        }

        connection.on("ParticipantJoined", async (user) => {
            appendSystemMessage(user.fullName + " otağa qoşuldu.", "");
            totalParticipants++;
            updateParticipantCount(totalParticipants);
            setupRemoteVideo(user);
            await createPeerConnection(user, true);
        });

        connection.on("UpdateParticipants", (users) => {
            totalParticipants = users.length;
            updateParticipantCount(totalParticipants);
            users.forEach(user => {
                if (user.connectionId !== connection.connectionId) {
                    setupRemoteVideo(user);
                    if(user.handRaised) {
                        setHandRaise(user.connectionId, true, user.fullName);
                    }
                }
            });
        });

        connection.on("ParticipantLeft", (connId) => {
            if (peers[connId]) {
                peers[connId].close();
                delete peers[connId];
            }
            removeRemoteVideo(connId);
            totalParticipants = Math.max(1, totalParticipants - 1);
            updateParticipantCount(totalParticipants);
            appendSystemMessage("Bir iştirakçı otaqdan ayrıldı.", "");
        });

        // ── WebRTC Signal Handlers ─────────────────────────────────
        connection.on("ReceiveOffer", async (fromConnectionId, sdpStr) => {
            let pc = peers[fromConnectionId];
            if (!pc) {
                pc = await createPeerConnection({ connectionId: fromConnectionId, fullName: "İştirakçı" }, false);
            }
            const sdp = JSON.parse(sdpStr);
            await pc.setRemoteDescription(new RTCSessionDescription(sdp));
            const answer = await pc.createAnswer();
            await pc.setLocalDescription(answer);
            await connection.invoke("SendAnswer", fromConnectionId,
                JSON.stringify(pc.localDescription));
        });

        connection.on("ReceiveAnswer", async (fromConnectionId, sdpStr) => {
            const pc = peers[fromConnectionId];
            if (pc) {
                const sdp = JSON.parse(sdpStr);
                await pc.setRemoteDescription(new RTCSessionDescription(sdp));
            }
        });

        connection.on("ReceiveIceCandidate", async (fromConnectionId, candidateStr) => {
            const pc = peers[fromConnectionId];
            if (pc) {
                try {
                    const candidate = JSON.parse(candidateStr);
                    await pc.addIceCandidate(new RTCIceCandidate(candidate));
                } catch(e) { console.warn('ICE candidate xətası:', e); }
            }
        });

        // Köhnə ReceiveSignal — geriyə uyğunluq üçün saxla
        connection.on("ReceiveSignal", async (fromConnectionId, signalStr) => {
            const signal = JSON.parse(signalStr);
            let pc = peers[fromConnectionId];
            if (!pc) {
                pc = await createPeerConnection({ connectionId: fromConnectionId, fullName: "İştirakçı" }, false);
            }
            if (signal.type === 'offer') {
                await pc.setRemoteDescription(new RTCSessionDescription(signal.sdp));
                const answer = await pc.createAnswer();
                await pc.setLocalDescription(answer);
                connection.invoke("SendSignal", fromConnectionId, JSON.stringify({ type: 'answer', sdp: pc.localDescription }));
            } else if (signal.type === 'answer') {
                await pc.setRemoteDescription(new RTCSessionDescription(signal.sdp));
            } else if (signal.type === 'candidate') {
                await pc.addIceCandidate(new RTCIceCandidate(signal.candidate));
            }
        });

        // Connection Handling
        connection.onreconnecting(error => {
            appendSystemMessage("Bağlantı qopdu. Yenidən qoşulma cəhdi...", "");
        });

        connection.onreconnected(connectionId => {
            appendSystemMessage("Bağlantı bərpa edildi.", "");
        });

        connection.onclose(error => {
            appendSystemMessage("Bağlantı tamamilə kəsildi. Səhifəni yeniləyin.", "");
        });

        function setHandRaise(connId, isRaised, name) {
            const icon = connId === connection.connectionId ? document.getElementById('localHandIcon') : document.getElementById('hand-icon-' + connId);
            const btn = document.getElementById('lower-hand-btn-' + connId);
            if (icon) icon.style.display = isRaised ? 'inline' : 'none';
            if (btn) btn.style.display = isRaised ? 'block' : 'none';
            
            if (isRaised && isTeacher && connId !== connection.connectionId) {
                appendSystemMessage(name + " əl qaldırdı ✋", "");
            }
        }

        connection.on("HandRaised", (connId, isRaised) => {
            // Find participant logic is a bit manual but we can just update UI directly
            // Full name isn't passed in HandRaised, but we can pass it if we need, or just lookup
            const gridCard = document.getElementById('grid-card-' + connId);
            const pName = gridCard ? gridCard.querySelector('.name-tag').innerText.replace(' (Host)', '').trim() : "İştirakçı";
            setHandRaise(connId, isRaised, pName);
            
            if (connId === connection.connectionId) {
                const btn = document.getElementById('handRaiseBtn');
                if (isRaised) btn.classList.add('active');
                else btn.classList.remove('active');
            }
        });

        function toggleHandRaise() {
            connection.invoke("RaiseHand", roomId);
        }

        let isScreenSharing = false;
        async function toggleScreenShare() {
            if (!isTeacher) return;
            try {
                if (!isScreenSharing) {
                    const displayStream = await navigator.mediaDevices.getDisplayMedia({ video: true });
                    const screenTrack = displayStream.getVideoTracks()[0];
                    
                    screenTrack.onended = () => {
                        stopScreenShare();
                    };

                    Object.values(peers).forEach(pc => {
                        const sender = pc.getSenders().find(s => s.track.kind === 'video');
                        if (sender) sender.replaceTrack(screenTrack);
                    });

                    document.getElementById('localVideo').srcObject = displayStream;
                    isScreenSharing = true;
                    document.querySelector('.share-btn').classList.add('active');
                    
                } else {
                    stopScreenShare();
                }
            } catch (err) {
                console.error("Screen share error", err);
            }
        }

        async function stopScreenShare() {
            const videoTrack = localStream.getVideoTracks()[0];
            Object.values(peers).forEach(pc => {
                const sender = pc.getSenders().find(s => s.track.kind === 'video');
                if (sender) sender.replaceTrack(videoTrack);
            });
            document.getElementById('localVideo').srcObject = localStream;
            isScreenSharing = false;
            document.querySelector('.share-btn').classList.remove('active');
        }

        // Inject simple keyframes dynamically
        const style = document.createElement('style');
        style.innerHTML = `
            @@keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
            @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        `;
        document.head.appendChild(style);

        // ==========================================
        // LOCAL CAMERA VIDEO & START CONNECTION
        // ==========================================
        let localStream;
        let audioContext;
        let analyser;
        let microphone;
        let pId;

        async function startCamera() {
            try {
                localStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
                const localVideo = document.getElementById('localVideo');
                if (localVideo) {
                    localVideo.srcObject = localStream;
                }
                
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                analyser = audioContext.createAnalyser();
                microphone = audioContext.createMediaStreamSource(localStream);
                microphone.connect(analyser);
                analyser.fftSize = 256;
                const bufferLength = analyser.frequencyBinCount;
                const dataArray = new Uint8Array(bufferLength);
                
                function detectMicLevel() {
                    analyser.getByteFrequencyData(dataArray);
                    let sum = 0;
                    for (let i = 0; i < bufferLength; i++) sum += dataArray[i];
                    let average = sum / bufferLength;
                    
                    const micIcon = document.getElementById('localMicIcon');
                    if (micIcon) {
                        if (average > 10) micIcon.style.opacity = '0.5';
                        else micIcon.style.opacity = '1';
                    }
                    pId = requestAnimationFrame(detectMicLevel);
                }
                detectMicLevel();

                // Start Connection after camera is ready
                connection.start()
                    .then(() => {
                        chatList.innerHTML = '';
                        appendSystemMessage("Çata qoşuldunuz. Söhbət şifrələnib.", "");
                        return connection.invoke("JoinRoom", roomId, currentUserId, fullName, isTeacher);
                    })
                    .catch(err => console.error(err));

            } catch (err) {
                console.error("Camera error: ", err);
                appendSystemMessage("Kamera və ya mikrofona icazə verilmədi.", "");
            }
        }

        startCamera();

    </script>

        // ── Local Media (Camera + Mic) ────────────────────────────
        let localStream = null;
        let screenStream = null;
        let isMicOn = false;
        let isCameraOn = false;
        let isScreenSharing = false;
        let isHandRaised = false;

        async function initLocalMedia() {
            try {
                localStream = await navigator.mediaDevices.getUserMedia({
                    video: { width: { ideal: 1280 }, height: { ideal: 720 } },
                    audio: true
                });
                document.getElementById('localVideo').srcObject = localStream;

                // Default: mic off, camera off
                localStream.getAudioTracks().forEach(t => t.enabled = false);
                localStream.getVideoTracks().forEach(t => t.enabled = false);

                isMicOn = false;
                isCameraOn = false;
            } catch (err) {
                console.warn('Kamera/mikrofon icazəsi alınmadı:', err.message);
                appendSystemMessage('Kamera/mikrofon icazəsi verilmədi. Yalnız chat işləyəcək.', '');
            }
        }

        // Mikrofon açma/bağlama
        async function toggleMic() {
            const btn = document.getElementById('micBtn');
            if (!localStream) { await initLocalMedia(); }
            if (!localStream) return;

            isMicOn = !isMicOn;
            localStream.getAudioTracks().forEach(t => t.enabled = isMicOn);

            const icon = btn.querySelector('i');
            if (isMicOn) {
                btn.classList.remove('danger');
                icon.className = 'fa-solid fa-microphone';
                document.getElementById('localMicIcon').className = 'fa-solid fa-microphone mic-status';
            } else {
                btn.classList.add('danger');
                icon.className = 'fa-solid fa-microphone-slash';
                document.getElementById('localMicIcon').className = 'fa-solid fa-microphone-slash mic-status muted';
            }

            try {
                await connection.invoke('ToggleMic', roomId, isMicOn);
            } catch(e) {}
        }

        // Kamera açma/bağlama
        async function toggleCamera() {
            const btn = document.getElementById('camBtn');
            if (!localStream) { await initLocalMedia(); }
            if (!localStream) return;

            isCameraOn = !isCameraOn;
            localStream.getVideoTracks().forEach(t => t.enabled = isCameraOn);

            const icon = btn.querySelector('i');
            if (isCameraOn) {
                btn.classList.remove('danger');
                icon.className = 'fa-solid fa-video';
            } else {
                btn.classList.add('danger');
                icon.className = 'fa-solid fa-video-slash';
            }

            try {
                await connection.invoke('ToggleVideo', roomId, isCameraOn);
            } catch(e) {}
        }

        // Ekran paylaşması
        async function toggleScreenShare() {
            const btn = document.querySelector('.share-btn');
            if (isScreenSharing) {
                // Dayandır
                if (screenStream) {
                    screenStream.getTracks().forEach(t => t.stop());
                    screenStream = null;
                }
                // Kameranı yenidən göstər
                if (localStream) {
                    document.getElementById('localVideo').srcObject = localStream;
                    Object.values(peers).forEach(pc => {
                        const videoSender = pc.getSenders().find(s => s.track && s.track.kind === 'video');
                        if (videoSender && localStream.getVideoTracks()[0]) {
                            videoSender.replaceTrack(localStream.getVideoTracks()[0]);
                        }
                    });
                }
                isScreenSharing = false;
                btn.style.color = 'var(--success)';
                btn.title = 'Ekran Paylaş';
                try { await connection.invoke('ToggleScreenShare', roomId, false); } catch(e) {}
                appendSystemMessage('Ekran paylaşması dayandırıldı.', '');
            } else {
                try {
                    screenStream = await navigator.mediaDevices.getDisplayMedia({ video: true, audio: false });
                    document.getElementById('localVideo').srcObject = screenStream;

                    // Bütün peer-lərə ekran stream-i göndər
                    const screenTrack = screenStream.getVideoTracks()[0];
                    Object.values(peers).forEach(pc => {
                        const videoSender = pc.getSenders().find(s => s.track && s.track.kind === 'video');
                        if (videoSender) videoSender.replaceTrack(screenTrack);
                    });

                    // İstifadəçi ekranı özü bağlarsa
                    screenTrack.onended = () => { toggleScreenShare(); };

                    isScreenSharing = true;
                    btn.style.color = 'var(--accent)';
                    btn.title = 'Ekran Paylaşmasını Dayandır';
                    try { await connection.invoke('ToggleScreenShare', roomId, true); } catch(e) {}
                    appendSystemMessage('Ekranınızı paylaşırsınız.', '');
                } catch (err) {
                    if (err.name !== 'NotAllowedError') {
                        appendSystemMessage('Ekran paylaşması xətası: ' + err.message, '');
                    }
                }
            }
        }

        // Əl qaldırma
        async function toggleHandRaise() {
            isHandRaised = !isHandRaised;
            const btn = document.getElementById('handRaiseBtn');
            btn.style.color = isHandRaised ? 'var(--warning)' : '';
            document.getElementById('localHandIcon').style.display = isHandRaised ? 'inline' : 'none';

            try {
                await connection.invoke('RaiseHand', roomId);
            } catch(e) {}
        }

        // Ekran paylaşması başladı/bitdi bildirişi
        connection.on('ScreenShareToggled', (connId, name, isSharing) => {
            if (connId !== connection.connectionId) {
                appendSystemMessage(
                    isSharing ? name + ' ekranını paylaşır 🖥️' : name + ' ekran paylaşmasını dayandırdı.',
                    ''
                );
            }
        });

        // Mic/Video toggle bildirişləri
        connection.on('MicToggled', (connId, state) => {
            const icon = document.getElementById('mic-icon-' + connId);
            if (icon) {
                icon.className = state
                    ? 'fa-solid fa-microphone mic-status'
                    : 'fa-solid fa-microphone-slash mic-status muted';
            }
        });

        connection.on('VideoToggled', (connId, state) => {
            // Video grid-dəki kart-ın opacity-ni dəyiş
            const card = document.getElementById('grid-card-' + connId);
            if (card) {
                card.style.opacity = state ? '1' : '0.6';
            }
        });

        // Otaqdan çıxarılma
        connection.on('KickedOut', () => {
            alert('Müəllim sizi otaqdan çıxardı.');
            window.location.href = '/';
        });

        // Dərs başladı/bitdi
        connection.on('ClassStatusChanged', (rId, status) => {
            if (status === 'Ended') {
                appendSystemMessage('Dərs müəllim tərəfindən bitirildi.', '');
                setTimeout(() => {
                    window.location.href = '/CourseDetail/Index/@Model?.CourseId';
                }, 3000);
            }
        });

        // Mic/Camera düymələrini yeni funksiyalara bağla
        document.getElementById('micBtn').onclick = toggleMic;
        document.getElementById('camBtn').onclick = toggleCamera;

        // ── SignalR başlat ────────────────────────────────────────
        async function startConnection() {
            try {
                await connection.start();
                await initLocalMedia();
                await connection.invoke('JoinRoom', roomId, currentUserId, fullName, isTeacher);
            } catch (err) {
                console.error('SignalR bağlantı xətası:', err);
                appendSystemMessage('Bağlantı xətası. 5 saniyə sonra yenidən cəhd edilir...', '');
                setTimeout(startConnection, 5000);
            }
        }

        startConnection();
    </script>
</body>
</html>
