<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inzara Academy</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />



    <link rel="stylesheet" href="~/assets/css/home.css">


    @RenderSection("css", required: false)
</head>

<body>
@await Component.InvokeAsync("Header")

            @RenderBody()

    @await Component.InvokeAsync("Footer")

    <div class="modal" id="loginModal">
        <div class="modal-box login-box">
            <span class="closeBtn">✕</span>

            <h2>Inzara <span>Academy</span></h2>
            <h3>Xoş gəldin👋</h3>
            <span>
                Hesabına daxil ol və öyrənməyə davam et
            </span>
            <div class="tabs">
                <button type="button" class="active">Daxil Ol</button>
                <button type="button" onclick="openRegister()">Qeydiyyat</button>
            </div>

            @if (TempData["LoginError"] != null)
            {
                <div class="auth-alert auth-alert-error">
                    <i class="fa fa-exclamation-circle me-2"></i>@TempData["LoginError"]
                </div>
            }
            @if (TempData["LoginSuccess"] != null)
            {
                <div class="auth-alert auth-alert-success">
                    <i class="fa fa-check-circle me-2"></i>@TempData["LoginSuccess"]
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post" class="login-form">
                <label>E-poçt</label>
                <input type="email" name="Email" placeholder="ornek@email.com" required>

                <label>Şifrə</label>
                <input type="password" name="Password" placeholder="********" required>

                <div class="login-extra">
                    <label><input type="checkbox" name="RememberMe" value="true"> Məni xatırla</label>
                    <a href="#">Şifrəni unutdun?</a>
                </div>

                <button type="submit" class="main-btn">Daxil ol</button>
            </form>
        </div>
    </div>



    <div class="modal" id="registerModal">
        <div class="modal-box register-box">
            <span class="closeBtn">✕</span>

            <h2>Inzara <span>Academy</span></h2>
            <h3>Hesab yarat ✨</h3>
            <p>Pulsuz qeydiyyatdan keç, 340+ kursdan yararlan</p>

            <div class="tabs">
                <button type="button" onclick="openLogin()">Daxil Ol</button>
                <button type="button" class="active">Qeydiyyat</button>
            </div>

            @if (TempData["RegisterError"] != null)
            {
                <div class="auth-alert auth-alert-error">
                    <i class="fa fa-exclamation-circle me-2"></i>@TempData["RegisterError"]
                </div>
            }
            @if (TempData["RegisterSuccess"] != null)
            {
                <div class="auth-alert auth-alert-success">
                    <i class="fa fa-check-circle me-2"></i>@TempData["RegisterSuccess"]
                </div>
            }

            <form asp-controller="Account" asp-action="Register" method="post" class="register-form">
                <label>Ad və Soyad</label>
                <input type="text" name="FullName" placeholder="Tam adınız" required>

                <label>E-poçt</label>
                <input type="email" name="Email" placeholder="ornek@email.com" required>

                <label>Şifrə</label>
                <input type="password" name="Password" placeholder="********" required>

                <label>Şifrəni Təsdiqləyin</label>
                <input type="password" name="ConfirmPassword" placeholder="********" required>

                <button type="submit" class="main-btn">Qeydiyyatdan keç</button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="~/assets/js/home.js"></script>
    <script src="~/assets/js/wishlist.js"></script>
    <script src="~/assets/js/animations.js"></script>

    <!-- Modal açma/bağlama — bütün səhifələrdə işləsin -->
    <script>
        (function () {
            var loginModal    = document.getElementById('loginModal');
            var registerModal = document.getElementById('registerModal');

            // Login düyməsi (header-dəki user ikonu)
            var loginBtn = document.getElementById('loginBtn');
            if (loginBtn) {
                loginBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    openLogin();
                });
            }

            // Bağla düymələri
            document.querySelectorAll('.closeBtn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (loginModal)    loginModal.classList.remove('active');
                    if (registerModal) registerModal.classList.remove('active');
                });
            });

            // Modal xaricinə klikləndikdə bağla
            window.addEventListener('click', function (e) {
                if (e.target === loginModal)    loginModal.classList.remove('active');
                if (e.target === registerModal) registerModal.classList.remove('active');
            });
        })();

        function openLogin() {
            var loginModal    = document.getElementById('loginModal');
            var registerModal = document.getElementById('registerModal');
            if (registerModal) registerModal.classList.remove('active');
            if (loginModal)    loginModal.classList.add('active');
        }

        function openRegister() {
            var loginModal    = document.getElementById('loginModal');
            var registerModal = document.getElementById('registerModal');
            if (loginModal)    loginModal.classList.remove('active');
            if (registerModal) registerModal.classList.add('active');
        }
    </script>

    @if (TempData["OpenLoginModal"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                document.getElementById('loginModal').classList.add('active');
            });
        </script>
    }
    @if (TempData["OpenRegisterModal"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                document.getElementById('registerModal').classList.add('active');
            });
        </script>
    }

    @if (TempData["Warning"] != null)
    {
        <div id="custom-toast" class="custom-toast">
            <span class="t-icon">⚠️</span>
            <span>@Html.Raw(TempData["Warning"])</span>
        </div>
        <style>
            .custom-toast {
                position: fixed;
                bottom: 28px;
                left: 50%;
                transform: translateX(-50%) translateY(100px);
                background: #0c2320;
                color: white;
                padding: 14px 24px;
                border-radius: 12px;
                border: 1px solid rgba(0,196,168,0.3);
                font-size: 14px;
                font-weight: 600;
                z-index: 9999;
                transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
                display: flex;
                align-items: center;
                gap: 10px;
                box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            }
            .custom-toast.show {
                transform: translateX(-50%) translateY(0);
            }
        </style>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toast = document.getElementById("custom-toast");
                setTimeout(function() {
                    toast.classList.add("show");
                }, 100);

                setTimeout(function() {
                    toast.classList.remove("show");
                }, 3000);
            });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>

</html>