@inject Microsoft.AspNetCore.Identity.UserManager<Academy.Models.AppUser> UserManager

<header>
    <section id="top-bar">
        <div class="navbar">
            <div class="nav-logo">
                <a href="home.html"><img src="~/assets/images/logo-light.png" alt=""></a>
            </div>

            <div class="hamburger">
                <i class="fa-solid fa-bars"></i>
            </div>
            <div class="menu-common">
                <nav class="menu-list">
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="About" asp-action="Index">About</a></li>
                        <li><a asp-controller="Course" asp-action="Index">Courses</a></li>
                        <li><a asp-controller="Teacher" asp-action="Index">Teachers</a></li>
                        <li><a asp-controller="Blog" asp-action="Index">Blog</a></li>
                        <li><a asp-controller="Contact" asp-action="Index"> Contact</a></li>
                    </ul>

                </nav>
                <div class="icons">
                    <a href="#" id="search-toggle">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </a>

                    <a asp-controller="Basket" asp-action="Index"><i class="fa-solid fa-cart-shopping"></i></a>

                    <div class="login-register" style="display: flex; align-items: center; gap: 10px;">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var user = await UserManager.GetUserAsync(User);
                            <span style="color: white; font-weight: 500;">@user?.FullName</span>
                            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                <button type="submit" class="log-first" style="background: none; border: none; cursor: pointer; color: white;">
                                    <i class="fa-solid fa-sign-out-alt"></i> Çıxış
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="log-first" id="loginBtn"><i class="fa-regular fa-user"></i></button>
                        }
                    </div>
                </div>
                <div id="search-panel" class="search-panel">
                    <input type="text" placeholder="Search...">
                    <button id="close-search">✕</button>
                </div>

            </div>
        </div>
    </section>
</header>