
@model IEnumerable<FeatureVM>

<section id="about-card">
    <div class="card-common">


        @foreach(var item in Model)
        {
            <div class="card">
                <div class="icon-box">
                    <i class="fa-solid fa-paper-plane"></i>
                </div>
                <h4>@item.Title</h4>
                <p>@item.Description</p>
                <div class="card-bg"></div>
            </div>

        }
      


    </div>
</section>