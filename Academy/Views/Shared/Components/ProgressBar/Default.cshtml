
@model MissionVM


<section id="Mission">
    <div class="mission-parts">
        <div class="mission-left">
            <span>OUR MISSION</span>
            <h1>@Model.Title</h1>
            <p>@Model.Description</p>

            <div class="skills">


                <div class="skill">
                    <div class="skill-top">
                        <span>Experience</span>
                        <p>70%</p>
                    </div>
                    <div class="progress">
                        <div class="progress-bar" data-percent="70"></div>
                    </div>

                </div>


                <div class="skill">
                    <div class="skill-top">
                        <span>Motivation</span>
                        <p>90%</p>
                    </div>
                    <div class="progress">
                        <div class="progress-bar" data-percent="90"></div>
                    </div>

                </div>


                <div class="skill">
                    <div class="skill-top">
                        <span>Quality</span>
                        <p>90%</p>
                    </div>
                    <div class="progress">
                        <div class="progress-bar" data-percent="90"></div>
                    </div>

                </div>
            </div>
        </div>

        <div class="image-mission">
            <img src="@Url.Content("~/uploads/mission/" + Model.Image)" alt="">
        </div>
    </div>
</section>