@model IEnumerable<StatisticVM>

@if (Model != null && Model.Any())
{
<section id="Numbers">
<style>
#Numbers {
    padding: 0 20px 80px;
    background: var(--bg-base, #080b14);
}

.numbers-wrap {
    max-width: 1100px;
    margin: 0 auto;
    background: linear-gradient(135deg, #0a1628 0%, #0d1f3c 50%, #071520 100%);
    border: 1px solid rgba(0,196,168,0.15);
    border-radius: 24px;
    padding: 56px 48px;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: repeat(@(Model.Count()), 1fr);
    gap: 0;
}

/* Dekorativ blob-lar */
.numbers-wrap::before {
    content: '';
    position: absolute;
    width: 300px; height: 300px;
    background: rgba(0,196,168,0.08);
    border-radius: 50%;
    top: -80px; left: -80px;
    filter: blur(60px);
    pointer-events: none;
}

.numbers-wrap::after {
    content: '';
    position: absolute;
    width: 250px; height: 250px;
    background: rgba(99,102,241,0.07);
    border-radius: 50%;
    bottom: -60px; right: -60px;
    filter: blur(50px);
    pointer-events: none;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 20px 24px;
    position: relative;
    z-index: 1;
}

/* Ayırıcı xətt — son element xaricində */
.stat-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0; top: 20%; bottom: 20%;
    width: 1px;
    background: rgba(255,255,255,0.07);
}

.stat-icon {
    width: 52px; height: 52px;
    background: rgba(0,196,168,0.1);
    border: 1px solid rgba(0,196,168,0.2);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; color: #00c4a8;
    margin-bottom: 16px;
    transition: all 0.3s ease;
}

.stat-item:hover .stat-icon {
    background: rgba(0,196,168,0.18);
    box-shadow: 0 0 20px rgba(0,196,168,0.2);
    transform: translateY(-2px);
}

.stat-num {
    font-size: clamp(32px, 4vw, 46px);
    font-weight: 900;
    background: linear-gradient(135deg, #ffffff 0%, #00c4a8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -1px;
    font-family: 'Inter', 'Plus Jakarta Sans', sans-serif;
    font-variant-numeric: tabular-nums;
}

.stat-label {
    font-size: 14px;
    font-weight: 600;
    color: #94a3b8;
    letter-spacing: 0.02em;
}

@@media (max-width: 768px) {
    .numbers-wrap {
        grid-template-columns: 1fr 1fr;
        padding: 36px 24px;
        gap: 16px;
    }
    .stat-item:not(:last-child)::after { display: none; }
    .stat-item { padding: 16px; }
}

@@media (max-width: 480px) {
    .numbers-wrap { grid-template-columns: 1fr; }
}
</style>

    <div class="numbers-wrap">
        @{ 
            var statIcons = new[] { "fa-users", "fa-graduation-cap", "fa-book-open", "fa-trophy", "fa-star", "fa-chart-line" };
            int si = 0;
        }
        @foreach (var item in Model)
        {
            var icon = statIcons[si % statIcons.Length];
            <div class="stat-item">
                <div class="stat-icon">
                    <i class="fa-solid @icon"></i>
                </div>
                <div class="stat-num" data-countup data-target="@item.Count">@item.Count</div>
                <div class="stat-label">@item.Title</div>
            </div>
            si++;
        }
    </div>
</section>
}
