@model List<Academy.ViewComponents.Home.TrendingCategoryVM>

@{
    // Hər kateqoriyaya rəng təyin et
    var colors = new[] { "orange", "green", "light-green", "yellow", "blue", "purple", "pink", "teal" };
    var icons  = new[] {
        "fa-code", "fa-palette", "fa-language", "fa-flask",
        "fa-chart-line", "fa-music", "fa-camera", "fa-globe",
        "fa-brain", "fa-laptop", "fa-pen-nib", "fa-calculator"
    };
}

<section id="many-card">
    <div class="container">
        <div class="header">
            <div class="title">
                <span>BROWSE TOP</span>
                <h2>Trending Categories</h2>
            </div>
            <a asp-controller="Course" asp-action="Index" class="view-all">Hamısına Bax</a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="carousel-wrapper">
                <button class="prev-btn">❮</button>
                <div class="carousel">
                    <div class="cards">
                        @{ int idx = 0; }
                        @foreach (var cat in Model)
                        {
                            var colorClass = colors[idx % colors.Length];
                            var iconClass  = icons[idx % icons.Length];
                            var courseText = cat.CourseCount == 1 ? "1 Kurs" : $"{cat.CourseCount} Kurs";
                            <a href="/Course?categoryId=@cat.Id" class="card @colorClass" style="text-decoration:none;">
                                <i class="fa-solid @iconClass" style="font-size:28px;margin-bottom:10px;"></i>
                                <h4 style="word-break: break-word;">@cat.Name</h4>
                                <span>@courseText</span>
                            </a>
                            idx++;
                        }
                    </div>
                </div>
                <button class="next-btn">❯</button>
            </div>
        }
        else
        {
            <div style="text-align:center;padding:40px;color:#64748b;">
                <i class="fa-solid fa-tags" style="font-size:36px;margin-bottom:12px;display:block;"></i>
                <p>Hələ kateqoriya əlavə edilməyib.</p>
            </div>
        }
    </div>
</section>
