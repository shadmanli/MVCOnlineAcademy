@model IEnumerable<Academy.ViewModels.ContactSection.ContactSectionVM>

@{
    var contactSection = Model.FirstOrDefault();
}

<style>
@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

#our-contact {
    width: 100%;
    background: #f8fafc;
    padding: 80px 32px;
    font-family: 'Inter', sans-serif;
}

.common-container {
    max-width: 1100px;
    margin: 0 auto;
}

.common-first {
    text-align: center;
    margin-bottom: 56px;
}

.common-first span {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #00c4a8;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
}

.common-first span::before,
.common-first span::after {
    content: '';
    display: inline-block;
    width: 24px; height: 2px;
    background: linear-gradient(90deg, #00c4a8, #0ea5e9);
    border-radius: 2px;
}

.common-first h1 {
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
}

.common-first p {
    font-size: 15px;
    color: #64748b;
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto;
}

/* Cards */
.common-cardly {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
}

.card-number {
    background: #ffffff;
    border: 1px solid #e8edf3;
    border-radius: 20px;
    padding: 36px 28px;
    text-align: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    transition: all 0.3s ease;
}

.card-number:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,196,168,0.1);
    border-color: rgba(0,196,168,0.2);
}

.card-icon-wrap {
    width: 64px; height: 64px;
    background: rgba(0,196,168,0.08);
    border: 1px solid rgba(0,196,168,0.15);
    border-radius: 18px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    transition: all 0.3s ease;
}

.card-number:hover .card-icon-wrap {
    background: rgba(0,196,168,0.15);
    box-shadow: 0 0 20px rgba(0,196,168,0.15);
}

.card-icon-wrap i {
    font-size: 26px;
    color: #00c4a8;
}

.card-number h3 {
    font-size: 17px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
}

.card-number p {
    font-size: 14px;
    color: #64748b;
    line-height: 1.65;
}

@@media (max-width: 640px) {
    #our-contact { padding: 60px 16px; }
    .common-cardly { grid-template-columns: 1fr; }
}
</style>

<section id="our-contact">
    <div class="common-container">
        <div class="common-first">
            <span>OUR CONTACTS</span>
            <h1>@contactSection?.Title</h1>
            <p>@contactSection?.SubTitle</p>
        </div>

        <div class="common-cardly">
            @foreach (var sec in Model)
            {
                @foreach (var item in sec.Items)
                {
                    <div class="card-number">
                        <div class="card-icon-wrap">
                            <i class="fa-regular fa-map"></i>
                        </div>
                        <h3>@item.Description</h3>
                        <p>@item.Address</p>
                    </div>
                }
            }
        </div>
    </div>
</section>
