<style>
@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

#feedback-part {
    width: 100%;
    background: linear-gradient(135deg, #00c4a8 0%, #00a896 50%, #008f80 100%);
    padding: 80px 32px;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
}

#feedback-part::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
}

#feedback-part::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    background: rgba(255,255,255,0.06);
    border-radius: 50%;
    top: -150px; right: -100px;
    filter: blur(60px);
    pointer-events: none;
}

.fb-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 60px;
    position: relative;
    z-index: 1;
}

/* ── Left side: info cards ── */
.fb-left {
    display: flex;
    gap: 60px;
    flex-wrap: wrap;
}

.fb-info-card {
    position: relative;
    max-width: 240px;
}

.fb-icon-wrap {
    width: 72px; height: 72px;
    background: rgba(255,255,255,0.15);
    border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.3s ease;
}

.fb-info-card:hover .fb-icon-wrap {
    background: rgba(255,255,255,0.22);
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.12);
}

.fb-icon-wrap i {
    font-size: 28px;
    color: #ffffff;
}

.fb-info-card h3 {
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
}

.fb-info-card p {
    color: rgba(255,255,255,0.75);
    font-size: 14px;
    line-height: 1.65;
    margin: 0 0 14px;
}

.fb-info-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap 0.2s ease;
}

.fb-info-link::after { content: '+'; font-size: 16px; font-weight: 900; }
.fb-info-card:hover .fb-info-link { gap: 8px; }

/* ── Right side: CTA card ── */
.fb-right { flex-shrink: 0; }

.fb-cta-card {
    width: 320px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 24px;
    padding: 36px 30px;
    backdrop-filter: blur(12px);
    text-align: center;
    box-shadow: 0 24px 60px rgba(0,0,0,0.12);
}

.fb-cta-icon {
    width: 64px; height: 64px;
    background: rgba(255,255,255,0.2);
    border-radius: 18px;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px;
    color: #fff;
    margin: 0 auto 20px;
    border: 1px solid rgba(255,255,255,0.3);
}

.fb-cta-card h3 {
    font-size: 20px;
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
}

.fb-cta-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    line-height: 1.65;
    margin: 0 0 24px;
}

.fb-cta-stats {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.15);
}

.fb-cta-stat strong {
    display: block;
    font-size: 22px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.03em;
}

.fb-cta-stat span {
    font-size: 11px;
    color: rgba(255,255,255,0.65);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
}

.fb-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px;
    background: #ff6d34;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 700;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 6px 20px rgba(255,109,52,0.4);
    letter-spacing: 0.02em;
}

.fb-cta-btn:hover {
    background: #e8551f;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255,109,52,0.5);
    color: #fff;
}

/* ── Responsive ── */
@@media (max-width: 992px) {
    .fb-inner { flex-direction: column; align-items: flex-start; gap: 40px; }
    .fb-right { width: 100%; }
    .fb-cta-card { width: 100%; max-width: 420px; }
}

@@media (max-width: 640px) {
    #feedback-part { padding: 60px 20px; }
    .fb-left { gap: 36px; }
    .fb-info-card { max-width: 100%; }
}
</style>

<section id="feedback-part">
    <div class="fb-inner">

        <!-- ── Left: info cards ── -->
        <div class="fb-left">
            <div class="fb-info-card">
                <div class="fb-icon-wrap">
                    <i class="fa-solid fa-rocket"></i>
                </div>
                <h3>Learn Anything</h3>
                <p>Join millions of people from around the world learning together. Try it now!</p>
                <a href="/Course" class="fb-info-link">View More</a>
            </div>

            <div class="fb-info-card">
                <div class="fb-icon-wrap">
                    <i class="fa-solid fa-earth-americas"></i>
                </div>
                <h3>Learn Together</h3>
                <p>Join millions of people from around world learning together. Try it now!</p>
                <a href="/Course" class="fb-info-link">View More</a>
            </div>
        </div>

        <!-- ── Right: CTA card ── -->
        <div class="fb-right">
            <div class="fb-cta-card">
                <div class="fb-cta-icon">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <h3>Öyrənməyə Başla</h3>
                <p>Peşəkar müəllimlərdən öyrən, karyeranı inkişaf etdir.</p>

                <div class="fb-cta-stats">
                    <div class="fb-cta-stat">
                        <strong>50K+</strong>
                        <span>Tələbə</span>
                    </div>
                    <div class="fb-cta-stat">
                        <strong>200+</strong>
                        <span>Kurs</span>
                    </div>
                    <div class="fb-cta-stat">
                        <strong>98%</strong>
                        <span>Məmnun</span>
                    </div>
                </div>

                <a href="/Course" class="fb-cta-btn">
                    <i class="fa-solid fa-arrow-right"></i>
                    Kurslara Bax
                </a>
            </div>
        </div>

    </div>
</section>
