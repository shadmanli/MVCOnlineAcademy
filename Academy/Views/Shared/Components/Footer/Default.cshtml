<style>
@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

/* ══════════════════════════════
   PREMIUM FOOTER
══════════════════════════════ */
#footer {
    width: 100%;
    background: #040814;
    font-family: 'Inter', sans-serif;
    border-top: 1px solid rgba(255,255,255,0.06);
    position: relative;
    overflow: hidden;
}

/* Ambient background blobs */
#footer::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    background: rgba(0,196,168,0.05);
    border-radius: 50%;
    top: -200px; left: -150px;
    filter: blur(80px);
    pointer-events: none;
}

#footer::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    background: rgba(255,109,52,0.04);
    border-radius: 50%;
    bottom: -100px; right: -100px;
    filter: blur(80px);
    pointer-events: none;
}

.footer-common {
    position: relative;
    z-index: 1;
}

/* ── Main grid ── */
.footer-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 32px 0;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 60px;
}

/* ── Brand column ── */
.footer-brand {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.footer-logo-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
}

.footer-logo-mark {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, #00c4a8 0%, #0ea5e9 50%, #6366f1 100%);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 19px; color: #fff;
    box-shadow: 0 0 24px rgba(0,196,168,0.3);
    flex-shrink: 0;
}

.footer-logo-name {
    display: flex;
    flex-direction: column;
    line-height: 1;
}

.footer-logo-name .fl1 {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
}

.footer-logo-name .fl1 em { color: #00c4a8; font-style: normal; }
.footer-logo-name .fl1 span { color: #ffffff; }
.footer-logo-name .fl1 b  { color: #6366f1; font-weight: 800; }

.footer-logo-name .fl2 {
    font-size: 9px;
    font-weight: 600;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-top: 3px;
}

.footer-tagline {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    max-width: 280px;
}

.footer-contact-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.footer-contact-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
}

.fc-icon {
    width: 34px; height: 34px;
    background: rgba(0,196,168,0.08);
    border: 1px solid rgba(0,196,168,0.15);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    color: #00c4a8;
    font-size: 13px;
    flex-shrink: 0;
    margin-top: 1px;
}

.fc-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.fc-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ff6d34;
}

.fc-value {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
}

/* Social icons */
.footer-socials {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.footer-social-btn {
    width: 36px; height: 36px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.45);
    font-size: 14px;
    text-decoration: none;
    transition: all 0.2s ease;
}

.footer-social-btn:hover {
    background: rgba(0,196,168,0.12);
    border-color: rgba(0,196,168,0.25);
    color: #00c4a8;
    transform: translateY(-2px);
}

/* ── Column headings ── */
.footer-col h4 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    margin: 0 0 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: relative;
}

.footer-col h4::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0;
    width: 32px; height: 2px;
    background: linear-gradient(90deg, #00c4a8, #0ea5e9);
    border-radius: 2px;
}

/* ── Link lists ── */
.footer-link-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.footer-link-list li a {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    padding: 7px 0;
    transition: all 0.2s ease;
    font-weight: 400;
}

.footer-link-list li a::before {
    content: '';
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(0,196,168,0.3);
    flex-shrink: 0;
    transition: all 0.2s ease;
}

.footer-link-list li a:hover {
    color: #00c4a8;
    padding-left: 6px;
}

.footer-link-list li a:hover::before {
    background: #00c4a8;
}

/* ── Map column ── */
.footer-map-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
}

.footer-map-wrap img {
    width: 100%;
    height: 190px;
    object-fit: cover;
    display: block;
    filter: brightness(0.7) saturate(0.8);
    transition: all 0.35s ease;
}

.footer-map-wrap:hover img {
    filter: brightness(0.85) saturate(1);
}

.footer-map-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(4,8,20,0.7) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 16px;
}

.footer-map-pin {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
}

.footer-map-pin i { color: #ff6d34; }

/* ── Bottom bar ── */
.footer-bottom {
    margin-top: 60px;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 20px 32px;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
}

.footer-copy {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
}

.footer-copy span { color: #00c4a8; }

.footer-bottom-links {
    display: flex;
    gap: 24px;
}

.footer-bottom-links a {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.2s;
}

.footer-bottom-links a:hover { color: #00c4a8; }

/* ── Responsive ── */
@@media (max-width: 1200px) {
    .footer-container {
        grid-template-columns: 1.2fr 1fr 1fr;
    }
    .footer-col:last-child {
        grid-column: 1 / -1;
    }
    .footer-map-wrap img { height: 160px; }
}

@@media (max-width: 768px) {
    .footer-container {
        grid-template-columns: 1fr 1fr;
        padding: 60px 20px 0;
        gap: 40px;
    }
    .footer-brand { grid-column: 1 / -1; }
    .footer-col:last-child { grid-column: 1 / -1; }
}

@@media (max-width: 480px) {
    .footer-container {
        grid-template-columns: 1fr;
        gap: 36px;
    }
    .footer-brand { grid-column: auto; }
    .footer-bottom {
        flex-direction: column;
        text-align: center;
        padding: 20px 16px;
    }
    .footer-bottom-links { gap: 16px; justify-content: center; }
}
</style>

<footer id="footer">
    <div class="footer-common">
        <div class="footer-container">

            <!-- ── Brand ── -->
            <div class="footer-brand">
                <a href="/" class="footer-logo-wrap">
                    <div class="footer-logo-mark">
                        <i class="fa-solid fa-graduation-cap"></i>
                    </div>
                    <div class="footer-logo-name">
                        <div class="fl1"><em>i</em><span>Nzara</span><b>.</b></div>
                        <div class="fl2">Online Academy</div>
                    </div>
                </a>

                <p class="footer-tagline">
                    Empowering learners worldwide with world-class courses, expert instructors, and unlimited opportunities.
                </p>

                <div class="footer-contact-list">
                    @{
                        var items = ViewBag.ContactItems as List<Academy.Models.ContactItem>;
                        // Address tipli (Description-da "address" keçirsə)
                        var addrItem  = items?.FirstOrDefault(x => x.Description != null && x.Description.ToLower().Contains("address"));
                        var emailItem = items?.FirstOrDefault(x => x.Description != null && x.Description.ToLower().Contains("email"));
                        var phoneItem = items?.FirstOrDefault(x => x.Description != null && x.Description.ToLower().Contains("phone") || x.Description != null && x.Description.ToLower().Contains("tel"));

                        // fallback — sadəcə sıra ilə götür
                        if (addrItem == null && items?.Count > 0)  addrItem  = items.ElementAtOrDefault(0);
                        if (emailItem == null && items?.Count > 1) emailItem = items.ElementAtOrDefault(1);
                        if (phoneItem == null && items?.Count > 2) phoneItem = items.ElementAtOrDefault(2);
                    }

                    @if (addrItem != null)
                    {
                        <div class="footer-contact-row">
                            <div class="fc-icon"><i class="fa-solid fa-location-dot"></i></div>
                            <div class="fc-text">
                                <span class="fc-label">Ünvan</span>
                                <span class="fc-value">@addrItem.Address</span>
                            </div>
                        </div>
                    }
                    @if (emailItem != null)
                    {
                        <div class="footer-contact-row">
                            <div class="fc-icon"><i class="fa-solid fa-envelope"></i></div>
                            <div class="fc-text">
                                <span class="fc-label">Email</span>
                                <span class="fc-value">@emailItem.Address</span>
                            </div>
                        </div>
                    }
                    @if (phoneItem != null)
                    {
                        <div class="footer-contact-row">
                            <div class="fc-icon"><i class="fa-solid fa-phone"></i></div>
                            <div class="fc-text">
                                <span class="fc-label">Telefon</span>
                                <span class="fc-value">@phoneItem.Address</span>
                            </div>
                        </div>
                    }
                    @if (items == null || !items.Any())
                    {
                        <div class="footer-contact-row">
                            <div class="fc-icon"><i class="fa-solid fa-location-dot"></i></div>
                            <div class="fc-text">
                                <span class="fc-label">Ünvan</span>
                                <span class="fc-value">Bakı, Azərbaycan</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="footer-socials">
                    <a href="#" class="footer-social-btn" title="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" class="footer-social-btn" title="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" class="footer-social-btn" title="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="footer-social-btn" title="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                    <a href="#" class="footer-social-btn" title="YouTube"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>

            <!-- ── Popular Courses ── -->
            <div class="footer-col">
                <h4>Popular Courses</h4>
                <ul class="footer-link-list">
                    <li><a href="/Course">UI/UX Design</a></li>
                    <li><a href="/Course">WordPress Development</a></li>
                    <li><a href="/Course">Business Strategy</a></li>
                    <li><a href="/Course">Software Development</a></li>
                    <li><a href="/Course">Business English</a></li>
                    <li><a href="/Course">Data Science</a></li>
                </ul>
            </div>

            <!-- ── Quick Links ── -->
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul class="footer-link-list">
                    <li><a href="/">Ana Səhifə</a></li>
                    <li><a href="/About">Haqqımızda</a></li>
                    <li><a href="/Course">Kurslar</a></li>
                    <li><a href="/Teacher">Müəllimlər</a></li>
                    <li><a href="/Blog">Bloq</a></li>
                    <li><a href="/Contact">Əlaqə</a></li>
                </ul>
            </div>

            <!-- ── Map ── -->
            <div class="footer-col">
                <h4>Find Us Here</h4>
                <div class="footer-map-wrap">
                    <img src="~/assets/images/map.jpg" alt="Our Location">
                    <div class="footer-map-overlay">
                        <div class="footer-map-pin">
                            <i class="fa-solid fa-location-dot"></i>
                            New York, USA
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Bottom bar ── -->
        <div class="footer-bottom">
            <p class="footer-copy">
                © 2025 <span>iNzara Academy</span>. All rights reserved.
            </p>
            <div class="footer-bottom-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Use</a>
                <a href="#">Cookie Policy</a>
            </div>
        </div>
    </div>
</footer>
