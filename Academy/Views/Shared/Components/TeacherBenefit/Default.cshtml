<style>
@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

#benefit-section {
    width: 100%;
    background: #040814;
    padding: 100px 32px;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
}

#benefit-section::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(0,196,168,0.07) 0%, transparent 70%);
    border-radius: 50%;
    top: -150px; left: -150px;
    pointer-events: none;
}

#benefit-section::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(99,102,241,0.06) 0%, transparent 70%);
    border-radius: 50%;
    bottom: -100px; right: -100px;
    pointer-events: none;
}

.benefit-container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    z-index: 1;
}

/* ── Left ── */
.left-benefit {
    color: #fff;
}

.benefit-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #00c4a8;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
}

.benefit-label::before {
    content: '';
    display: block;
    width: 24px; height: 2px;
    background: linear-gradient(90deg, #00c4a8, #0ea5e9);
    border-radius: 2px;
}

.left-benefit h1 {
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 900;
    color: #f8fafc;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 40px;
}

.benefit-column {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.item {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 22px 24px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    transition: all 0.3s ease;
}

.item:hover {
    background: rgba(0,196,168,0.05);
    border-color: rgba(0,196,168,0.18);
    transform: translateX(6px);
}

.item-icon {
    width: 44px; height: 44px;
    background: rgba(0,196,168,0.1);
    border: 1px solid rgba(0,196,168,0.2);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: #00c4a8;
    font-size: 18px;
    flex-shrink: 0;
    transition: all 0.3s ease;
}

.item:hover .item-icon {
    background: rgba(0,196,168,0.18);
    box-shadow: 0 0 16px rgba(0,196,168,0.2);
}

.text {
    flex: 1;
}

.two {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: #f8fafc;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
}

.text p {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(203,213,225,0.6);
}

/* ── Right image ── */
.right-benefit {
    display: flex;
    justify-content: center;
    align-items: center;
}

.right-benefit img {
    width: 100%;
    max-width: 440px;
    border-radius: 30px 10px 30px 10px;
    object-fit: cover;
    border: 2px solid rgba(0,196,168,0.15);
    box-shadow: 0 24px 60px rgba(0,0,0,0.4), 0 0 0 1px rgba(0,196,168,0.08);
    filter: brightness(0.9);
    transition: all 0.4s ease;
}

.right-benefit img:hover {
    filter: brightness(1);
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 40px rgba(0,196,168,0.1);
}

@@media (max-width: 900px) {
    .benefit-container {
        grid-template-columns: 1fr;
        gap: 48px;
    }
    .right-benefit img { max-width: 100%; }
}

@@media (max-width: 640px) {
    #benefit-section { padding: 70px 20px; }
    .item { padding: 16px 18px; }
}
</style>

<section id="benefit-section">
    <div class="benefit-container">

        <div class="left-benefit">
            <span class="benefit-label">Our Benefits</span>
            <h1>Why Teach With Us?</h1>

            <div class="benefit-column">
                <div class="item">
                    <div class="item-icon">
                        <i class="fa-solid fa-sack-dollar"></i>
                    </div>
                    <div class="text">
                        <span class="two">Earn Money</span>
                        <p>Whether you want to develop as a professional or discover a new hobby, there's an online course for that. Reach millions of students globally.</p>
                    </div>
                </div>

                <div class="item">
                    <div class="item-icon">
                        <i class="fa-solid fa-users-gear"></i>
                    </div>
                    <div class="text">
                        <span class="two">Inspire Students</span>
                        <p>Share your knowledge and expertise with a passionate community of learners. Make a real difference in people's lives and careers.</p>
                    </div>
                </div>

                <div class="item">
                    <div class="item-icon">
                        <i class="fa-solid fa-chart-line"></i>
                    </div>
                    <div class="text">
                        <span class="two">Grow Your Brand</span>
                        <p>Build your personal brand, get exposure and grow your audience. Our platform gives you the tools to succeed as an educator.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="right-benefit">
            <img src="~/assets/images/bacome-a-teacher_02.png" alt="Become a Teacher">
        </div>

    </div>
</section>
