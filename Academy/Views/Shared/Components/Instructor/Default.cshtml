@using Academy.ViewModels.Instructor
@model IEnumerable<InstructorVM>

<style>
@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

#instructor {
    width: 100%;
    padding: 100px 32px;
    background: #f8fafc;
    font-family: 'Inter', sans-serif;
}

.common-instructors {
    max-width: 1200px;
    margin: 0 auto;
}

.top-side {
    text-align: center;
    margin-bottom: 56px;
}

.instructor-content span {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #00c4a8;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
}

.instructor-content span::before,
.instructor-content span::after {
    content: '';
    display: inline-block;
    width: 24px; height: 2px;
    background: linear-gradient(90deg, #00c4a8, #0ea5e9);
    border-radius: 2px;
}

.instructor-content h1 {
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.03em;
    margin-bottom: 10px;
}

.instructor-content p {
    font-size: 15px;
    color: #64748b;
    line-height: 1.65;
}

/* Cards */
.teacher-card {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
}

.teacher-single {
    background: #ffffff;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid #e8edf3;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    text-align: center;
}

.teacher-single:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    border-color: rgba(0,196,168,0.2);
}

.teacher-single .img {
    position: relative;
    overflow: hidden;
    height: 260px;
    background: linear-gradient(135deg, #f8fafc, #e8edf3);
}

.teacher-single .img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.teacher-single:hover .img img {
    transform: scale(1.06);
}

/* Şəkil yoxdursa avatar */
.teacher-avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #00c4a8, #0ea5e9);
    font-size: 56px;
    font-weight: 800;
    color: #fff;
}

/* Social icons overlay */
.content {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(4,8,20,0.85) 0%, rgba(4,8,20,0.2) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 8px;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.teacher-single:hover .content { opacity: 1; }

.for-icon {
    width: 34px; height: 34px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.2s ease;
}

.for-icon:hover {
    background: #00c4a8;
    border-color: #00c4a8;
    transform: translateY(-3px);
}

.teacher-single h4 {
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
    margin: 16px 16px 4px;
    letter-spacing: -0.01em;
}

.teacher-single > span {
    font-size: 13px;
    color: #ff6d34;
    font-weight: 600;
    display: block;
    margin-bottom: 16px;
}

/* Empty state */
.instructor-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: #94a3b8;
}

@@media (max-width: 1024px) {
    .teacher-card { grid-template-columns: repeat(3, 1fr); }
}
@@media (max-width: 768px) {
    #instructor { padding: 70px 20px; }
    .teacher-card { grid-template-columns: 1fr 1fr; }
}
@@media (max-width: 480px) {
    .teacher-card { grid-template-columns: 1fr; }
}
</style>

<section id="instructor">
    <div class="common-instructors">
        <div class="top-side">
            <div class="instructor-content">
                <span>Best Of The Best</span>
                <h1>Top Online Instructors</h1>
                <p>Explore learning tips, career advice. Unlock new opportunities with unlimited access.</p>
            </div>
        </div>

        <div class="teacher-card">
            @if (Model != null && Model.Any())
            {
                @foreach (var t in Model)
                {
                    <div class="teacher-single">
                        <div class="img">
                            @if (!string.IsNullOrEmpty(t.Image))
                            {
                                <img src="~/uploads/instructors/@t.Image" alt="@t.FullName">
                            }
                            else
                            {
                                <div class="teacher-avatar-fallback">
                                    @t.FullName[0].ToString().ToUpper()
                                </div>
                            }
                            <div class="content">
                                <div class="for-icon"><i class="fa-brands fa-instagram"></i></div>
                                <div class="for-icon"><i class="fa-brands fa-x-twitter"></i></div>
                                <div class="for-icon"><i class="fa-brands fa-linkedin-in"></i></div>
                                <div class="for-icon"><i class="fa-brands fa-facebook-f"></i></div>
                            </div>
                        </div>
                        <h4>@t.FullName</h4>
                        <span>@(string.IsNullOrEmpty(t.Title) ? "Müəllim" : t.Title)</span>
                        @if (!string.IsNullOrEmpty(t.Bio))
                        {
                            <p style="font-size:13px;color:#64748b;line-height:1.55;padding:0 16px 18px;margin:0;">@t.Bio</p>
                        }
                    </div>
                }
            }
            else
            {
                <div class="instructor-empty">
                    <i class="fa-solid fa-chalkboard-user" style="font-size:40px;display:block;margin-bottom:12px;"></i>
                    <p>Hələ müəllim əlavə edilməyib.</p>
                </div>
            }
        </div>
    </div>
</section>

@if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
{
    int cur   = (int)ViewBag.CurrentPage;
    int total = (int)ViewBag.TotalPages;

    <div class="instr-pagination">
        @if (cur > 1)
        {
            <a href="?instrPage=@(cur - 1)" class="instr-page-btn">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
        }
        @for (int p = 1; p <= total; p++)
        {
            <a href="?instrPage=@p" class="instr-page-btn @(p == cur ? "active" : "")">@p</a>
        }
        @if (cur < total)
        {
            <a href="?instrPage=@(cur + 1)" class="instr-page-btn">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        }
    </div>
}

<style>
.instr-pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 48px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}

.instr-page-btn {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px;
    background: #fff;
    border: 1px solid #e8edf3;
    color: #64748b;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
}

.instr-page-btn:hover {
    background: rgba(0,196,168,0.08);
    border-color: rgba(0,196,168,0.3);
    color: #00c4a8;
    transform: translateY(-2px);
}

.instr-page-btn.active {
    background: linear-gradient(135deg, #00c4a8, #0ea5e9);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 6px 20px rgba(0,196,168,0.3);
}
</style>
