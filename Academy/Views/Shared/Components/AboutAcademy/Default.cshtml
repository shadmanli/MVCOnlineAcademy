@model AboutVM

<section id="about-middle">
    <div class="about-video">

        <div class="content">
            <h1>@Model.Title</h1>
            <span>@Model.Description</span>
        </div>

        <div class="content-video"
             style="position:relative; cursor:pointer;"
             onclick="openVideo()">

            <img src="~/uploads/about/@Model.Image" alt="" style="width:100%;">

            <!-- Play button -->
            <div style="
                position:absolute;
                top:50%;
                left:50%;
                transform:translate(-50%, -50%);
                width:70px;
                height:70px;
                background:orange;
                border-radius:50%;
                display:flex;
                justify-content:center;
                align-items:center;
                color:white;
                font-size:30px;
            ">
                ▶
            </div>

        </div>
    </div>
</section>

<!-- MODAL -->
<div id="videoModal"
     style="
        display:none;
        position:fixed;
        top:0;
        left:0;
        width:100%;
        height:100%;
        background:rgba(0,0,0,0.85);
        justify-content:center;
        align-items:center;
        z-index:9999;
     "
     onclick="outsideClick(event)">

    <div style="
        position:relative;
        width:60%;
        max-width:800px;
    " onclick="event.stopPropagation()">

        <!-- ✅ DÜZGÜN X BUTTON -->
        <button onclick="closeVideo()" style="
            position:absolute;
            top:-15px;
            right:-15px;
            width:40px;
            height:40px;
            border:none;
            border-radius:50%;
            background:red;
            color:white;
            font-size:20px;
            cursor:pointer;
            display:flex;
            align-items:center;
            justify-content:center;
            z-index:10000;
        ">
            ✖
        </button>

        <!-- VIDEO -->
        <video id="aboutVideo" width="100%" controls>
            <source src="~/uploads/about/@Model.Video" type="video/mp4">
        </video>

    </div>
</div>

<script>
    function openVideo() {
        const modal = document.getElementById("videoModal");
        const video = document.getElementById("aboutVideo");

        modal.style.display = "flex";

        if (video) {
            video.play();
        }
    }

    function closeVideo() {
        const modal = document.getElementById("videoModal");
        const video = document.getElementById("aboutVideo");

        modal.style.display = "none";

        if (video) {
            video.pause();
            video.currentTime = 0;
        }
    }

    function outsideClick(e) {
        if (e.target.id === "videoModal") {
            closeVideo();
        }
    }

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
            closeVideo();
        }
    });
</script>