@using Academy.ViewModels.Course
@model CoursePageVM

<section id="courses-common">
    <div class="top-filter">
        <form method="get" asp-controller="Course" asp-action="Index">


            <div class="search-box">
                <input type="text" name="search" placeholder="Search courses..."
                       value="@Context.Request.Query["search"]"
                <button type="submit">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>


            <div class="sort-box">
                <select name="sort">
                    <option value="">Default Sorting</option>
                    <option value="latest">Sort by latest</option>
                    <option value="low">Price: low to high</option>
                    <option value="high">Price: high to low</option>
                </select>
            </div>


            <div class="filters">


                <select name="categoryId">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        if (Model.CategoryId == cat.Id)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>

                <!-- INSTRUCTOR -->
                <select name="instructorId">
                    <option value="">All Instructors</option>
                    @foreach (var ins in Model.Instructors)
                    {
                        if (Model.InstructorId == ins.Id)
                        {
                            <option value="@ins.Id" selected>@ins.FullName</option>
                        }
                        else
                        {
                            <option value="@ins.Id">@ins.FullName</option>
                        }
                    }
                </select>

            </div>
        </form>
    </div>


    <div class="courses-layout">
        <div class="courses-container">

            @if (Model.Courses != null && Model.Courses.Any())
            {
                @foreach (var course in Model.Courses)
                {
                    <div class="card-courses">
                        <a href="/course/detail/@course.Id">
                            <div class="courses-img">

                                <span class="img-top">
                                    @(course.CategoryName ?? "No Category")
                                </span>

                                <img src="@(string.IsNullOrEmpty(course.ImageUrl)
                                                                                                              ? "/images/default.png"
                                                                                                              : "/uploads/course/" + course.ImageUrl)"
                             alt="@course.Title" />

                                <div class="card-content">
                                    <span class="instructor">
                                        @(course.InstructorName ?? "Unknown Instructor")
                                    </span>

                                    <h3 class="title">@course.Title</h3>

                                    <div class="rating">
                                        <span>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-regular fa-star"></i>
                                        </span>

                                        <span class="price">$@course.Price</span>
                                    </div>

                                    <form asp-controller="Basket" asp-action="Add" method="post" style="margin-top: 15px; width: 100%;">
                                        <input type="hidden" name="courseId" value="@course.Id" />
                                        <button type="submit" class="add-to-cart-btn" style="width: 100%; padding: 10px; background-color: #007bff; color: white; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; transition: 0.3s; z-index: 10; position: relative;">
                                            🛒 Səbətə Əlavə Et
                                        </button>
                                    </form>

                                </div>

                            </div>
                        </a>
                    </div>
                        }
            }
            else
            {
                <div class="no-course">
                    <p>Course tapılmadı</p>
                </div>
            }


            <div class="pagination">
                <a href="#" class="prev">«</a>
                <a href="#" class="page active">1</a>
                <a href="#" class="page">2</a>
                <a href="#" class="page">3</a>
                <a href="#" class="next">»</a>
            </div>

        </div>
    </div>
</section>