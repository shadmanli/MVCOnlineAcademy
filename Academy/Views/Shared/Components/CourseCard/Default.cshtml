@using Academy.ViewModels.Course
@model List<CourseVM>

<section id="courses-common">
    <div class="top-filter">

        <div class="search-box">
            <input type="text" placeholder="Search courses...">
            <button type="button">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </div>

        <div class="sort-box">
            <select>
                <option value="">Default Sorting</option>
                <option value="latest">Sort by latest</option>
                <option value="low">Price: low to high</option>
                <option value="high">Price: high to low</option>
            </select>
        </div>

    </div>

    <div class="courses-layout">

        <div class="sidebar">
          
        </div>

        <div class="courses-container">

            @if (Model != null && Model.Any())
            {
                @foreach (var course in Model)
                {
                    <div class="card-courses">

                        <a href="/course/detail/@course.Id">

                            <div class="courses-img">

                                <span class="img-top">
                                    @(course.CategoryName ?? "No Category")
                                </span>

                                <img src="@(string.IsNullOrEmpty(course.ImageUrl)
                                                                                 ? "/images/default.png"
                                                                                 : "/uploads/course/" + course.ImageUrl)"
                             alt="@course.Title" />

                                <div class="card-content">

                                    <span class="instructor">
                                        @(course.InstructorName ?? "Unknown Instructor")
                                    </span>

                                    <h3 class="title">
                                        @course.Title
                                    </h3>

                                    <div class="rating">
                                        <span>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-solid fa-star"></i>
                                            <i class="fa-regular fa-star"></i>
                                        </span>

                                        <span class="price">
                                            $@course.Price
                                        </span>
                                    </div>

                                </div>

                            </div>

                        </a>

                    </div>
                        }
            }
            else
            {
                <div class="no-course">
                    <p>Course tapılmadı</p>
                </div>
            }

            
            <div class="pagination">
                <a href="#" class="prev">«</a>
                <a href="#" class="page active">1</a>
                <a href="#" class="page">2</a>
                <a href="#" class="page">3</a>
                <a href="#" class="next">»</a>
            </div>

        </div>
    </div>
</section>