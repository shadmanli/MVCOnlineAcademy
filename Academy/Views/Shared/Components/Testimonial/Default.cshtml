@model List<Academy.Models.CourseReview>

<section id="Testimonial">
    <div class="testimonial-common">

        <div class="testimonial-text">
            <span>TƏSDİQLƏNMİŞ RƏYLƏR</span>
            <h1>What People Say</h1>
            <p>Kurslarımızı tamamlamış tələbələrin həqiqi rəyləri.</p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="swiper about-testimonial-swiper">
                <div class="swiper-wrapper">
                    @foreach (var review in Model)
                    {
                        <div class="swiper-slide">
                            <div class="card-general">
                                <div class="header">
                                    @if (!string.IsNullOrEmpty(review.Photo))
                                    {
                                        <img src="/uploads/profiles/@review.Photo" alt="@review.Name"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                                        <div class="about-avatar-fallback" style="display:none;">@review.Name[0].ToString().ToUpper()</div>
                                    }
                                    else
                                    {
                                        <div class="about-avatar-fallback">@review.Name[0].ToString().ToUpper()</div>
                                    }
                                    <div>
                                        <h4>@review.Name</h4>
                                        <span class="about-course-name">@review.Course?.Title</span>
                                        <div class="about-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fa fa-star @(i <= review.Rating ? "filled" : "empty")"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <p>"@review.Message"</p>
                                <div class="about-review-date">@review.CreatedAt.ToString("dd.MM.yyyy")</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="swiper-pagination"></div>
            </div>
        }
        else
        {
            <div style="text-align:center;color:rgba(255,255,255,0.4);padding:40px 0;">
                <i class="fa fa-star" style="font-size:40px;display:block;margin-bottom:12px;"></i>
                <p>Hələ təsdiqlənmiş rəy yoxdur.</p>
            </div>
        }

    </div>
</section>

<style>
    #Testimonial {
        background: #040814;
        padding: 100px 32px;
        position: relative;
        overflow: hidden;
        font-family: 'Inter', sans-serif;
    }

    #Testimonial::before {
        content: '';
        position: absolute;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(0,196,168,0.06) 0%, transparent 70%);
        border-radius: 50%;
        top: -150px; right: -150px;
        pointer-events: none;
    }

    .testimonial-common {
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .testimonial-text {
        text-align: center;
        margin-bottom: 56px;
    }

    .testimonial-text span {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #00c4a8;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
    }

    .testimonial-text span::before,
    .testimonial-text span::after {
        content: '';
        display: inline-block;
        width: 24px; height: 2px;
        background: linear-gradient(90deg, #00c4a8, #0ea5e9);
        border-radius: 2px;
    }

    .testimonial-text h1 {
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 800;
        color: #f8fafc;
        letter-spacing: -0.03em;
        line-height: 1.2;
        margin: 0 0 12px;
    }

    .testimonial-text p {
        font-size: 15px;
        color: rgba(203,213,225,0.5);
        line-height: 1.7;
    }

    .card-general {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        padding: 28px;
        border-radius: 20px;
        min-height: 220px;
        transition: all 0.3s ease;
    }

    .card-general:hover {
        transform: translateY(-5px);
        background: rgba(0,196,168,0.04);
        border-color: rgba(0,196,168,0.18);
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }

    .card-general .header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 18px;
    }

    .card-general .header img,
    .about-avatar-fallback {
        width: 52px; height: 52px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid rgba(0,196,168,0.3);
    }

    .about-avatar-fallback {
        background: linear-gradient(135deg, #00c4a8, #6366f1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 700;
        color: white;
    }

    .card-general .header h4 {
        margin: 0 0 3px;
        font-size: 15px;
        font-weight: 700;
        color: #f8fafc;
    }

    .about-course-name {
        font-size: 12px;
        color: #00c4a8;
        display: block;
        margin-bottom: 5px;
    }

    .about-stars { display: flex; gap: 2px; }
    .about-stars .fa-star.filled { color: #fbbf24; font-size: 12px; }
    .about-stars .fa-star.empty  { color: rgba(255,255,255,0.15); font-size: 12px; }

    .card-general > p {
        color: rgba(203,213,225,0.65);
        font-size: 14px;
        line-height: 1.75;
        font-style: italic;
        margin-bottom: 14px;
    }

    .about-review-date {
        font-size: 11px;
        color: rgba(255,255,255,0.25);
        text-align: right;
    }

    /* Swiper dots */
    .about-testimonial-swiper .swiper-pagination-bullet {
        background: rgba(255,255,255,0.2);
        opacity: 1;
    }

    .about-testimonial-swiper .swiper-pagination-bullet-active {
        background: linear-gradient(90deg, #00c4a8, #0ea5e9);
        width: 24px;
        border-radius: 99px;
    }

    .swiper-pagination { margin-top: 32px; position: relative !important; }

    @@media (max-width: 480px) {
        #Testimonial { padding: 70px 20px; }
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        new Swiper('.about-testimonial-swiper', {
            slidesPerView: 2,
            spaceBetween: 24,
            loop: true,
            autoplay: { delay: 4000, disableOnInteraction: false },
            pagination: { el: '.swiper-pagination', clickable: true },
            breakpoints: {
                0:   { slidesPerView: 1 },
                768: { slidesPerView: 2 }
            }
        });
    });
</script>
