@using Academy.ViewModels.Blog
@model IEnumerable<BlogVM>

<style>
@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

#last-card {
    width: 100%;
    background: #f8fafc;
    padding: 80px 32px 100px;
    font-family: 'Inter', sans-serif;
}

.blog-card {
    max-width: 1200px;
    margin: 0 auto;
}

.blog-page-header {
    text-align: center;
    margin-bottom: 56px;
}

.blog-page-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #00c4a8;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
}

.blog-page-label::before,
.blog-page-label::after {
    content: '';
    display: inline-block;
    width: 24px; height: 2px;
    background: linear-gradient(90deg, #00c4a8, #0ea5e9);
    border-radius: 2px;
}

.blog-page-header h1 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.03em;
    line-height: 1.2;
}

/* Cards grid */
.cards-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
}

.blog-card-single {
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid #e8edf3;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    display: flex;
    flex-direction: column;
}

.blog-card-single:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    border-color: rgba(0,196,168,0.2);
}

/* Image */
.blog-img {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
}

.blog-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.blog-card-single:hover .blog-img img {
    transform: scale(1.06);
}

/* Text */
.blog-text {
    padding: 24px 26px 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.blog-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #94a3b8;
    font-weight: 500;
}

.blog-meta .cat-name {
    color: #00c4a8;
    font-weight: 700;
}

.blog-meta .dot-sep {
    width: 3px; height: 3px;
    background: #cbd5e1;
    border-radius: 50%;
}

.blog-meta .author-link {
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s;
}

.blog-meta .author-link:hover { color: #0ea5e9; }

.blog-text h3 {
    font-size: 17px;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.5;
    margin: 0;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.blog-card-single:hover .blog-text h3 { color: #00c4a8; }

.blog-footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid #f1f5f9;
}

.link2 {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 700;
    color: #ff6d34;
    text-decoration: none;
    transition: all 0.2s ease;
}

.link2::after { content: '→'; transition: transform 0.2s ease; }
.link2:hover { color: #e8551f; }
.link2:hover::after { transform: translateX(4px); }

/* Load more */
.btn-wrapper {
    text-align: center;
    margin-top: 56px;
}

.btn-wrapper a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 36px;
    background: linear-gradient(135deg, #00c4a8, #0ea5e9);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 4px 16px rgba(0,196,168,0.3);
    font-family: 'Inter', sans-serif;
}

.btn-wrapper a:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,196,168,0.45);
    color: #fff;
}

@@media (max-width: 1024px) {
    .cards-container { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 640px) {
    #last-card { padding: 60px 16px 80px; }
    .cards-container { grid-template-columns: 1fr; }
}

/* Pagination */
.blog-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 60px;
    flex-wrap: wrap;
}

.blog-page-btn {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px;
    background: #ffffff;
    border: 1px solid #e8edf3;
    color: #64748b;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
}

.blog-page-btn:hover {
    background: rgba(0,196,168,0.08);
    border-color: rgba(0,196,168,0.3);
    color: #00c4a8;
    transform: translateY(-2px);
}

.blog-page-btn.active {
    background: linear-gradient(135deg, #00c4a8, #0ea5e9);
    border-color: transparent;
    color: #fff;
    box-shadow: 0 6px 20px rgba(0,196,168,0.3);
}
</style>

<section id="last-card">
    <div class="blog-card">

        <div class="blog-page-header">
            <span class="blog-page-label">Latest Posts</span>
            <h1>Our Blog & Articles</h1>
        </div>

        <div class="cards-container">
            @foreach (var item in Model)
            {
                <div class="blog-card-single">
                    <div class="blog-img">
                        <img src="@Url.Content("~/uploads/blog/" + item.Image)" alt="@item.Title">
                    </div>
                    <div class="blog-text">
                        <div class="blog-meta">
                            <span class="cat-name">@item.Title</span>
                            <span class="dot-sep"></span>
                            <a href="" class="author-link">@item.Name</a>
                        </div>
                        <h3>@item.Description</h3>
                        <div class="blog-footer-row">
                            <a href="" class="link2">Read More</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (ViewBag.TotalPages != null && (int)ViewBag.TotalPages > 1)
        {
            int cur   = (int)ViewBag.CurrentPage;
            int total = (int)ViewBag.TotalPages;

            <div class="blog-pagination">
                @if (cur > 1)
                {
                    <a href="?blogPage=@(cur - 1)" class="blog-page-btn">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                }
                @for (int p = 1; p <= total; p++)
                {
                    @if (p == 1 || p == total || (p >= cur - 2 && p <= cur + 2))
                    {
                        <a href="?blogPage=@p" class="blog-page-btn @(p == cur ? "active" : "")">@p</a>
                    }
                    else if (p == cur - 3 || p == cur + 3)
                    {
                        <span class="blog-page-btn" style="pointer-events:none;opacity:0.4;">...</span>
                    }
                }
                @if (cur < total)
                {
                    <a href="?blogPage=@(cur + 1)" class="blog-page-btn">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                }
            </div>
        }
    </div>
</section>
