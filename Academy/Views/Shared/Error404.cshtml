@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "404 - Səhifə Tapılmadı";
    ViewData["HideFooter"] = true;
}

<style>
.error-page {
    min-height: 100vh;
    background: #040814;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
    padding: 100px 20px 60px;
}

.error-page::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(99,102,241,0.07) 0%, transparent 70%);
    border-radius: 50%;
    top: -200px; left: -150px;
    pointer-events: none;
}

.error-page::after {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(0,196,168,0.05) 0%, transparent 70%);
    border-radius: 50%;
    bottom: -150px; right: -100px;
    pointer-events: none;
}

.error-box {
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 560px;
}

.error-code {
    font-size: clamp(100px, 18vw, 160px);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.05em;
    margin-bottom: 8px;
}

.error-icon-wrap {
    width: 80px; height: 80px;
    background: rgba(99,102,241,0.1);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 28px;
    font-size: 36px;
    color: #818cf8;
}

.error-title {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 800;
    color: #f8fafc;
    margin-bottom: 14px;
    letter-spacing: -0.03em;
}

.error-desc {
    font-size: 16px;
    color: rgba(203,213,225,0.6);
    line-height: 1.75;
    margin-bottom: 40px;
}

.error-search-wrap {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 32px;
    transition: border-color 0.25s;
}

.error-search-wrap:focus-within {
    border-color: rgba(0,196,168,0.35);
    background: rgba(0,196,168,0.04);
}

.error-search-wrap input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 14px 18px;
    color: #fff;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
}

.error-search-wrap input::placeholder { color: rgba(255,255,255,0.3); }

.error-search-wrap button {
    background: linear-gradient(135deg, #00c4a8, #0ea5e9);
    border: none;
    padding: 0 20px;
    height: 48px;
    color: #fff;
    font-size: 16px;
    cursor: pointer;
    transition: opacity 0.2s;
}

.error-search-wrap button:hover { opacity: 0.85; }

.error-links {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 36px;
}

.error-link-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 99px;
    color: rgba(255,255,255,0.6);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
}

.error-link-chip:hover {
    background: rgba(0,196,168,0.08);
    border-color: rgba(0,196,168,0.25);
    color: #00c4a8;
}

.error-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
}

.err-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    background: linear-gradient(135deg, #00c4a8, #0ea5e9);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 4px 16px rgba(0,196,168,0.3);
    font-family: 'Inter', sans-serif;
}

.err-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,196,168,0.45);
    color: #fff;
}

.err-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.75);
    font-size: 14px;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
}

.err-btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
}
</style>

<div class="error-page">
    <div class="error-box">
        <div class="error-code">404</div>
        <div class="error-icon-wrap">
            <i class="fa-solid fa-compass-drafting"></i>
        </div>
        <h1 class="error-title">Səhifə Tapılmadı</h1>
        <p class="error-desc">
            Axtardığınız səhifə mövcud deyil, silinib və ya köçürülüb.
            Zəhmət olmasa aşağıdakı linklərdən birini istifadə edin.
        </p>

        <form action="/Course" method="get" class="error-search-wrap">
            <input type="text" name="search" placeholder="Kurs axtar..." />
            <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
        </form>

        <div class="error-links">
            <a href="/" class="error-link-chip"><i class="fa-solid fa-house"></i> Ana Səhifə</a>
            <a href="/Course" class="error-link-chip"><i class="fa-solid fa-graduation-cap"></i> Kurslar</a>
            <a href="/About" class="error-link-chip"><i class="fa-solid fa-circle-info"></i> Haqqımızda</a>
            <a href="/Blog" class="error-link-chip"><i class="fa-solid fa-newspaper"></i> Bloq</a>
            <a href="/Contact" class="error-link-chip"><i class="fa-solid fa-envelope"></i> Əlaqə</a>
        </div>

        <div class="error-actions">
            <a href="javascript:history.back()" class="err-btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Geri Qayıt
            </a>
            <a href="/" class="err-btn-primary">
                <i class="fa-solid fa-house"></i> Ana Səhifə
            </a>
        </div>
    </div>
</div>
