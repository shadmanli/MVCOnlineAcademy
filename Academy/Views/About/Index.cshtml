@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section css {
    <link rel="stylesheet" href="~/assets/css/about.css">
}


<main>
    <section id="about-start">
        <div class="about">
            <div class="top-line"></div>
            <div class="about-img" style="background-image: url(./assets/images/about-us_page-title.jpg);">
                <h1>About Us</h1>
                <span> <a href="home.html">Home</a> >  About Us</span>

            </div>
        </div>
    </section>
    <section id="about-middle">
        <div class="about-video">
            <div class="content">
                <p>About Us</p>
                <h1>
                    Welcome to iGuru
                </h1>
                <span>We’ll then ask you to tell us your current level of English or invite you to take our quick 20 <br> minute placement test so we can make sure you start learning English.</span>
            </div>
            <div class="content-video">
                <img src="~/assets/images/about-us_01.jpg" alt="">
                <div class="play-button">
                    <span></span>
                </div>
            </div>
        </div>
    </section>
    <section id="about-card">
        <div class="card-common">

            <div class="card">
                <div class="icon-box">
                    <i class="fa-solid fa-paper-plane"></i>
                </div>
                <h4>Global Reach</h4>
                <p>Whether you want to develop as a professional or discover a new hobby, there's an online course for that.</p>
                <div class="card-bg"></div>
            </div>

            <div class="card">
                <div class="icon-box">
                    <i class="fa-solid fa-globe"></i>
                </div>
                <h4>Worldwide Access</h4>
                <p>Learn from anywhere in the world with flexible and accessible online programs.</p>
                <div class="card-bg"></div>
            </div>

            <div class="card">
                <div class="icon-box">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <h4>Expert Teachers</h4>
                <p>Professional instructors guiding you step by step to achieve your goals.</p>
                <div class="card-bg"></div>
            </div>

        </div>
    </section>


    <section id="Mission">
        <div class="mission-parts">
            <div class="mission-left">
                <span>OUR MISSION</span>
                <h1>At What We Believe</h1>
                <p>Our culture is diverse, inclusive, and committed to personal and <br> professional development. We’re not afraid to take on a new  <br>challenge, and we love taking courses!</p>

                <div class="skills">


                    <div class="skill">
                        <div class="skill-top">
                            <span>Experience</span>
                            <p>70%</p>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" data-percent="70"></div>
                        </div>

                    </div>


                    <div class="skill">
                        <div class="skill-top">
                            <span>Motivation</span>
                            <p>90%</p>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" data-percent="90"></div>
                        </div>

                    </div>


                    <div class="skill">
                        <div class="skill-top">
                            <span>Quality</span>
                            <p>90%</p>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" data-percent="90"></div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="image-mission">
                <img src="~/assets/images/about-us_02-3.png" alt="">
            </div>
        </div>
    </section>

    <section id="Testimonial">
        <div class="testimonial-common">
            <img src="~/assets/images/about-us_03.jpg" alt="Background Image">

            <div class="testimonial-text">
                <span>TESTIMONIALS</span>
                <h1>What People Say</h1>
                <p>We’ll then ask you to tell us your current level of English or invite you to take our quick 20 minute placement test so we can make sure you start learning English.</p>
            </div>


            <div class="swiper-container">
                <div class="swiper-wrapper">

                    <div class="swiper-slide">
                        <div class="card-general">
                            <div class="header">
                                <div class="card-number">
                                    <img src="~/assets/images/testimonials.jpg" alt="Nina Farel">
                                </div>
                                <div class="contentt">
                                    <h4>Nina Farel</h4>
                                    <span>@@smashingmagazine</span>
                                </div>
                            </div>
                            <div class="text-card">
                                <p>"Choosing online studies was the best way to do it – the internet is fast, cheap & popular and it’s easy to communicate in social media with native speakers."</p>
                            </div>
                        </div>
                    </div>


                    <div class="swiper-slide">
                        <div class="card-general">
                            <div class="header">
                                <div class="card-number">
                                    <img src="~/assets/images/testimonials.jpg" alt="Jina Grindevald">
                                </div>
                                <div class="contentt">
                                    <h4>Jina Grindevald</h4>
                                    <span>@@habrahabr</span>
                                </div>
                            </div>
                            <div class="text-card">
                                <p>"Choosing online studies was the best way to do it – the internet is fast, cheap & popular and it’s easy to communicate in social media with native speakers."</p>
                            </div>
                        </div>
                    </div>


                    <div class="swiper-slide">
                        <div class="card-general">
                            <div class="header">
                                <div class="card-number">
                                    <img src="~/assets/images/testimonials.jpg" alt="Instructor 3">
                                </div>
                                <div class="contentt">
                                    <h4>John Doe</h4>
                                    <span>@@john_doe</span>
                                </div>
                            </div>
                            <div class="text-card">
                                <p>"Online learning is a great way to grow your skills, especially with native speakers!"</p>
                            </div>
                        </div>
                    </div>


                    <div class="swiper-slide">
                        <div class="card-general">
                            <div class="header">
                                <div class="card-number">
                                    <img src="~/assets/images/testimonials.jpg" alt="Instructor 4">
                                </div>
                                <div class="contentt">
                                    <h4>Jane Smith</h4>
                                    <span>@@janesmith</span>
                                </div>
                            </div>
                            <div class="text-card">
                                <p>"Online studies are fast and efficient. I love the flexibility and convenience!"</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="swiper-pagination"></div>
            </div>
        </div>
    </section>


    <section id="about-pulse">
        <div class="common-section">

            <div class="button-for">
                <div class="text-part">
                    <span>DISCOVER NEW</span>
                    <h1>Pulse of iGuru</h1>
                    <p>Explore learning tips, career advice. Unlock new opportunities with unlimited access.</p>
                </div>
                <a href="about.html">View All</a>
            </div>

            <div class="card-section">


                <div class="card-single">
                    <div class="card-inner">

                        <div class="card-front">
                            <img src="~/assets/images/flip-boxes_01.jpg" alt="">
                            <div class="overlay">
                                <h2>Smart News</h2>
                            </div>
                        </div>

                        <div class="card-back">
                            <h3>Smart News</h3>
                            <p>Discover smart learning strategies and career insights with iGuru.</p>

                        </div>

                    </div>
                </div>


                <div class="card-single">
                    <div class="card-inner">

                        <div class="card-front">
                            <img src="~/assets/images/flip-boxes_01.jpg" alt="">
                            <div class="overlay">
                                <h2>Career Tips</h2>
                            </div>
                        </div>

                        <div class="card-back">
                            <h3>Career Tips</h3>
                            <p>Get professional advice and unlock new opportunities in your field.</p>

                        </div>

                    </div>
                </div>


                <div class="card-single">
                    <div class="card-inner">

                        <div class="card-front">
                            <img src="~/assets/images/flip-boxes_01.jpg" alt="">
                            <div class="overlay">
                                <h2>Learning Hacks</h2>
                            </div>
                        </div>

                        <div class="card-back">
                            <h3>Learning Hacks</h3>
                            <p>Boost your productivity and master new skills faster than ever.</p>

                        </div>

                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="logos">
        <div class="logo-img">
            <div class="logos-container">
                <img src="~/assets/images/logo1.png" alt="">
                <img src="~/assets/images/logo2.png" alt="">
                <img src="~/assets/images/logo3.png" alt="">
                <img src="~/assets/images/logo4.png" alt="">


            </div>
        </div>
    </section>

</main>

@section Scripts {
    <script src="~/assets/js/about.js"></script>
}