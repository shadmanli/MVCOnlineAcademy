@using Academy.ViewModels.Instructor
@model IEnumerable<InstructorVM>
@{
    int cur   = ViewBag.CurrentPage ?? 1;
    int total = ViewBag.TotalPages  ?? 1;
}

<div class="teacher-card" id="instructorGrid">
    @if (Model != null && Model.Any())
    {
        @foreach (var t in Model)
        {
            <div class="teacher-single">
                <div class="img">
                    @if (!string.IsNullOrEmpty(t.Image))
                    {
                        <img src="~/uploads/instructors/@t.Image" alt="@t.FullName">
                    }
                    else
                    {
                        <div class="teacher-avatar-fallback">
                            @t.FullName[0].ToString().ToUpper()
                        </div>
                    }
                    <div class="content">
                        <div class="for-icon"><i class="fa-brands fa-instagram"></i></div>
                        <div class="for-icon"><i class="fa-brands fa-x-twitter"></i></div>
                        <div class="for-icon"><i class="fa-brands fa-linkedin-in"></i></div>
                        <div class="for-icon"><i class="fa-brands fa-facebook-f"></i></div>
                    </div>
                </div>
                <h4>@t.FullName</h4>
                <span>@(string.IsNullOrEmpty(t.Title) ? "Müəllim" : t.Title)</span>
                @if (!string.IsNullOrEmpty(t.Bio))
                {
                    <p style="font-size:13px;color:#64748b;line-height:1.55;padding:0 16px 18px;margin:0;">@t.Bio</p>
                }
            </div>
        }
    }
</div>

@if (total > 1)
{
    <div class="instr-pagination" id="instrPagination">
        @if (cur > 1)
        {
            <button type="button" onclick="loadInstrPage(@(cur - 1))" class="instr-page-btn">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
        }
        @for (int p = 1; p <= total; p++)
        {
            <button type="button" onclick="loadInstrPage(@p)" class="instr-page-btn @(p == cur ? "active" : "")">@p</button>
        }
        @if (cur < total)
        {
            <button type="button" onclick="loadInstrPage(@(cur + 1))" class="instr-page-btn">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        }
    </div>
}
