@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Səviyyə Yoxlanışı | Premium Assessment</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <!-- Confetti JS -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <style>
        :root {
            --bg-color: #0A0A0A;
            --card-bg: rgba(255, 255, 255, 0.03);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-main: #FFFFFF;
            --text-muted: #A1A1AA;
            --accent: #00F0FF;
            --accent-glow: rgba(0, 240, 255, 0.3);
            --brand-purple: #7000FF;
            --success: #10B981;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(112, 0, 255, 0.15), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(0, 240, 255, 0.15), transparent 25%);
        }

        .container {
            width: 100%;
            max-width: 800px;
            padding: 40px;
            position: relative;
        }

        /* GLASSMORPHISM CARD */
        .glass-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 24px;
            padding: 48px;
            box-shadow: 0 32px 64px rgba(0,0,0,0.4);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }

        /* HEADER */
        .quiz-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .progress-container {
            flex: 1;
            margin-right: 32px;
        }

        .progress-info {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .progress-bar-bg {
            width: 100%;
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            position: relative;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--brand-purple), var(--accent));
            border-radius: 4px;
            transition: width 0.6s cubic-bezier(0.65, 0, 0.35, 1);
            box-shadow: 0 0 10px var(--accent-glow);
        }

        .timer {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            background: rgba(255,255,255,0.05);
            padding: 8px 16px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
        }

        /* QUESTION */
        .question-title {
            font-family: 'Sora', sans-serif;
            font-size: 28px;
            font-weight: 600;
            line-height: 1.4;
            margin-bottom: 32px;
            animation: fadeIn 0.5s ease forwards;
        }

        /* OPTIONS */
        .options-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .option-btn {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-color);
            padding: 20px 24px;
            border-radius: 16px;
            color: var(--text-main);
            font-family: 'DM Sans', sans-serif;
            font-size: 16px;
            font-weight: 500;
            text-align: left;
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .option-btn:hover {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.15);
            transform: translateY(-2px);
        }

        .option-btn.selected {
            background: rgba(0, 240, 255, 0.1);
            border-color: var(--accent);
            box-shadow: 0 0 20px var(--accent-glow);
        }

        .option-btn .check-circle {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
        }

        .option-btn.selected .check-circle {
            background: var(--accent);
            border-color: var(--accent);
            color: #000;
        }

        .option-btn .check-circle i {
            font-size: 12px;
            opacity: 0;
            transition: 0.2s;
        }

        .option-btn.selected .check-circle i {
            opacity: 1;
        }

        /* ACTIONS */
        .quiz-actions {
            margin-top: 40px;
            display: flex;
            justify-content: space-between;
        }

        .btn-premium {
            background: var(--text-main);
            color: var(--bg-color);
            border: none;
            padding: 16px 32px;
            border-radius: 12px;
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 12px;
        }

        .btn-premium:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 10px 30px rgba(255,255,255,0.15);
        }

        .btn-premium:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* VIEW STATES */
        .view-section {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .view-section.active {
            display: block;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* PREMIUM RESULT VIEW ANIMATIONS */
        .victory-glow {
            box-shadow: 0 0 100px rgba(255, 215, 0, 0.2);
            border-color: rgba(255, 215, 0, 0.4) !important;
            animation: pulseGlow 3s infinite alternate;
        }

        @@keyframes pulseGlow {
            0% { box-shadow: 0 0 80px rgba(255, 215, 0, 0.2); }
            100% { box-shadow: 0 0 140px rgba(255, 215, 0, 0.4); }
        }

        .slide-up-fade {
            animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        @@keyframes slideUpFade {
            0% { opacity: 0; transform: translateY(30px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .pop-in {
            animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }

        @@keyframes popIn {
            0% { opacity: 0; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1); }
        }

        .badge-flip {
            perspective: 1000px;
        }
        .badge-flip-inner {
            display: inline-block;
            animation: flipIn 1s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
            transform-style: preserve-3d;
        }

        @@keyframes flipIn {
            0% { transform: rotateY(180deg); opacity: 0; }
            100% { transform: rotateY(0deg); opacity: 1; }
        }

        /* ACHIEVEMENT BADGE UI */
        .achievement-badge-card {
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.1), rgba(255, 140, 0, 0.1));
            border: 1px solid rgba(255, 215, 0, 0.3);
            backdrop-filter: blur(12px);
            padding: 16px 24px;
            border-radius: 100px;
            display: inline-flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }

        .achievement-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #FFD700, #FF8C00);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-size: 20px;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
        }

        .achievement-text {
            text-align: left;
        }
        .achievement-text span {
            display: block;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.7);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }
        .achievement-text strong {
            display: block;
            font-size: 18px;
            font-family: 'Sora', sans-serif;
            color: #fff;
        }

        .number-counter {
            font-variant-numeric: tabular-nums;
        }

        /* RESULT DASHBOARD */
        .result-badge-container {
            text-align: center;
            margin-bottom: 40px;
        }

        .level-badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--brand-purple), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-family: 'Sora', sans-serif;
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 16px;
            filter: drop-shadow(0 0 20px rgba(0, 240, 255, 0.4));
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border-color);
            padding: 24px;
            border-radius: 16px;
            text-align: center;
            transition: 0.3s;
        }

        .stat-card:hover {
            border-color: rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.04);
        }

        .stat-val { font-size: 24px; font-weight: 700; font-family: 'Sora', sans-serif; margin-bottom: 8px; color: var(--text-main); }
        .stat-label { font-size: 13px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

        .recommendation {
            background: linear-gradient(to right, rgba(0, 240, 255, 0.05), transparent);
            border-left: 4px solid var(--accent);
            padding: 20px;
            border-radius: 0 12px 12px 0;
            margin-bottom: 32px;
        }

        /* ONBOARDING */
        .onboarding-wrap {
            text-align: center;
            padding: 40px 0;
        }

        .onboarding-wrap h1 {
            font-family: 'Sora';
            font-size: 40px;
            margin-bottom: 16px;
            background: linear-gradient(135deg, #FFF, #888);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* LOADING SPINNER */
        .loader {
            width: 48px;
            height: 48px;
            border: 4px solid rgba(255,255,255,0.1);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        @@keyframes spin { 100% { transform: rotate(360deg); } }

        /* ANTI-CHEAT & WARNINGS */
        .warning-toast {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(255, 50, 50, 0.9);
            color: white;
            padding: 15px 25px;
            border-radius: 12px;
            backdrop-filter: blur(10px);
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            box-shadow: 0 10px 30px rgba(255, 0, 0, 0.3);
            transform: translateX(150%);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 9999;
        }
        .warning-toast.show {
            transform: translateX(0);
        }

        /* MOBILE RESPONSIVE */
        @@media (max-width: 768px) {
            .container { padding: 20px; }
            .glass-card { padding: 30px 20px; border-radius: 20px; }
            .question-title { font-size: 22px; }
            .stats-grid { grid-template-columns: 1fr; gap: 15px; }
            .onboarding-wrap h1 { font-size: 32px; }
            .level-badge { font-size: 36px; }
        }
    </style>
</head>
<body>
    <div id="cheat-warning" class="warning-toast">
        <i class="fa-solid fa-triangle-exclamation"></i> Diqqət: Səhifədən çıxış aşkar edildi!
    </div>

    <div class="container">
        <div class="glass-card">

            <!-- 1. INTRO / ONBOARDING -->
            <div id="view-intro" class="view-section active">
                <div class="onboarding-wrap">
                    <i class="fa-solid fa-brain" style="font-size: 48px; color: var(--accent); margin-bottom: 24px; filter: drop-shadow(0 0 15px var(--accent-glow));"></i>
                    <h1>Biliklərinizi Kəşf Edin</h1>
                    <p style="color: var(--text-muted); font-size: 16px; margin-bottom: 40px; line-height: 1.6;">
                        Platformamızdakı süni intellekt dəstəkli quiz vasitəsilə 
                        hazırkı səviyyənizi müəyyən edək. Bu, sizə ən uyğun kursları və xüsusi inkişaf 
                        yol xəritəsini formalaşdırmağa kömək edəcək.
                    </p>
                    <button class="btn-premium" onclick="startQuiz()">
                        Testə Başla <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <!-- 2. QUIZ INTERFACE -->
            <div id="view-quiz" class="view-section">
                <div class="quiz-header">
                    <div class="progress-container">
                        <div class="progress-info">
                            <span id="question-indicator">Sual 1 / 5</span>
                            <span style="color: var(--accent);">Level Assessment</span>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" id="progress-bar"></div>
                        </div>
                    </div>
                    <div class="timer">
                        <i class="fa-regular fa-clock" style="color: var(--accent);"></i>
                        <span id="timer-display">05:00</span>
                    </div>
                </div>

                <div class="question-container">
                    <h2 class="question-title" id="question-text">Loading...</h2>
                    <div class="options-grid" id="options-container">
                        <!-- Options injected by JS -->
                    </div>
                </div>

                <div class="quiz-actions">
                    <button class="btn-premium" style="background: transparent; color: var(--text-main); border: 1px solid var(--border-color);" id="btn-skip" onclick="nextQuestion(true)">
                        Burax
                    </button>
                    <button class="btn-premium" id="btn-next" onclick="nextQuestion(false)" disabled>
                        Təsdiqlə <i class="fa-solid fa-check"></i>
                    </button>
                </div>
            </div>

            <!-- 3. PROCESSING -->
            <div id="view-processing" class="view-section" style="text-align: center; padding: 60px 0;">
                <div class="loader"></div>
                <h2 style="font-family: 'Sora'; font-size: 24px; margin-bottom: 12px;">Nəticələr Analiz Edilir...</h2>
                <p style="color: var(--text-muted);">Süni intellekt cavablarınızı incələyir və sizin üçün xüsusi yol xəritəsi hazırlayır.</p>
            </div>

            <!-- 4. RESULT DASHBOARD -->
            <div id="view-result" class="view-section">
                <div class="result-badge-container badge-flip">
                    <div class="badge-flip-inner">
                        <div id="achievement-unlocked" class="achievement-badge-card" style="display:none;">
                            <div class="achievement-icon"><i class="fa-solid fa-trophy"></i></div>
                            <div class="achievement-text">
                                <span>Yeni Nişan Açıldı</span>
                                <strong>Pro Tələbə</strong>
                            </div>
                        </div>
                        <p style="color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; font-size: 12px; margin-bottom: 8px;">Təyin olunan Səviyyə</p>
                        <div class="level-badge" id="result-level">Intermediate</div>
                        <p id="result-message" style="color: var(--text-main); font-size: 16px;">Təbriklər! Siz baza biliklərinə tam hakimsiniz.</p>
                    </div>
                </div>

                <div class="stats-grid pop-in" style="animation-delay: 0.3s;">
                    <div class="stat-card">
                        <div class="stat-val number-counter" id="res-xp">+0</div>
                        <div class="stat-label">Qazanılan XP</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-val number-counter" id="res-percent">0%</div>
                        <div class="stat-label">Məntiq Dəqiqliyi</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-val" id="res-potential" style="color: var(--success);">Yüksək</div>
                        <div class="stat-label">Potensial</div>
                    </div>
                </div>

                <div class="stats-grid slide-up-fade" style="margin-top:-20px; animation-delay: 0.6s;">
                    <div class="stat-card" style="grid-column: span 3; text-align:left;">
                        <span style="display:block; color:var(--success); font-weight:700; margin-bottom:4px;"><i class="fa-solid fa-arrow-trend-up"></i> Güclü Tərəflər:</span>
                        <div id="res-strengths" style="color:var(--text-main); font-size:14px;">-</div>
                        
                        <span style="display:block; color:var(--brand-purple); font-weight:700; margin-bottom:4px; margin-top:12px;"><i class="fa-solid fa-bullseye"></i> İnkişaf Etməli:</span>
                        <div id="res-weak" style="color:var(--text-main); font-size:14px;">-</div>
                    </div>
                </div>

                <div class="recommendation slide-up-fade" style="animation-delay: 0.9s;">
                    <h4 style="font-family: 'Sora'; margin-bottom: 8px;"><i class="fa-solid fa-map-location-dot"></i> Sizin üçün Məsləhət Görülən Yol Xəritəsi</h4>
                    <p id="res-roadmap" style="color: var(--text-muted); font-size: 14px; line-height: 1.6;">
                        Loading...
                    </p>
                </div>

                <div class="slide-up-fade" style="animation-delay: 1.2s;" id="recommendation-btn-container">
                    <button class="btn-premium" style="width: 100%; justify-content: center; background: linear-gradient(90deg, var(--brand-purple), var(--accent));" onclick="document.getElementById('ai-courses-section').style.display='block'; document.getElementById('recommendation-btn-container').style.display='none';">
                        Tövsiyə Edilən Kurslara Bax <i class="fa-solid fa-rocket"></i>
                    </button>
                </div>

                <!-- DYNAMIC COURSES INJECTION CONTAINER -->
                <div id="ai-courses-section" class="slide-up-fade" style="display: none; margin-top: 40px; animation-delay: 0.2s;">
                    <h3 style="font-family: 'Sora'; font-size: 20px; font-weight: 600; margin-bottom: 16px; border-bottom: 2px solid rgba(255,255,255,0.1); padding-bottom: 8px;">
                        <i class="fa-solid fa-robot" style="color: var(--accent);"></i> AI Xüsusi Tövsiyə
                    </h3>
                    <div id="dynamic-courses-grid" style="display: grid; grid-template-columns: 1fr; gap: 16px;">
                        <!-- JS WILL INJECT COURSES -->
                    </div>
                    
                    <button class="btn-premium" style="margin-top:20px; background: rgba(255,255,255,0.05); color: #fff; border: 1px solid var(--border-color); width: 100%; justify-content:center;" onclick="window.location.href='/Course'">
                        Bütün Kurslara Keçid
                    </button>
                </div>

            </div>

        </div>
    </div>

    <script>
        let questions = [];
        let currentQIndex = 0;
        let selectedOptionId = null;
        let answersData = [];
        let timerInterval = null;
        let timeLeft = 300; // 5 minutes
        let cheatAttempts = 0;
        let questionStartTime = 0;

        const setView = (viewId) => {
            document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
        };

        // ANTI-CHEAT: TAB SWITCH DETECTION
        document.addEventListener("visibilitychange", () => {
            if (document.visibilityState === 'hidden' && document.getElementById('view-quiz').classList.contains('active')) {
                cheatAttempts++;
                showWarning(`Diqqət: Səhifədən çıxış aşkar edildi! (Cəhd: ${cheatAttempts}/3)`);
                if (cheatAttempts >= 3) {
                    finishQuiz(); // Auto submit on 3rd violation
                }
            }
        });

        const showWarning = (msg) => {
            const toast = document.getElementById('cheat-warning');
            toast.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> ${msg}`;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 4000);
        };

        // FULLSCREEN SUPPORT
        const requestFullScreen = () => {
            const elem = document.documentElement;
            if (elem.requestFullscreen) { elem.requestFullscreen(); }
            else if (elem.webkitRequestFullscreen) { elem.webkitRequestFullscreen(); } // Safari
            else if (elem.msRequestFullscreen) { elem.msRequestFullscreen(); } // IE11
        };

        const fetchQuestions = async () => {
             try {
                // URL-dən courseId al (məsələn: /Assessment/Index?courseId=5)
                const urlParams = new URLSearchParams(window.location.search);
                const courseId = urlParams.get('courseId') || 0;
                const res = await fetch('/Assessment/GetQuestions?courseId=' + courseId);
                if(res.ok) {
                    questions = await res.json();
                } else {
                    console.error("No questions found in DB");
                }
             } catch (e) {
                 console.error(e);
             }
        };

        const formatTime = (seconds) => {
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
        };

        const startTimer = () => {
            document.getElementById('timer-display').innerText = formatTime(timeLeft);
            timerInterval = setInterval(() => {
                timeLeft--;
                document.getElementById('timer-display').innerText = formatTime(timeLeft);
                if(timeLeft <= 0) {
                    clearInterval(timerInterval);
                    finishQuiz(); // force submit
                }
            }, 1000);
        };

        const startQuiz = async () => {
            const btn = document.querySelector('#view-intro .btn-premium');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Yüklənir...';
            btn.disabled = true;

            await fetchQuestions();
            
            if(questions.length === 0) {
                // Quiz UI-a xoş mesaj göstər
                document.getElementById('view-intro').innerHTML = `
                    <div class="onboarding-wrap">
                        <i class="fa-solid fa-lock" style="font-size:48px;color:var(--text-muted);margin-bottom:24px;"></i>
                        <h1 style="font-size:28px;">Bu Kurs Üçün Quiz Yoxdur</h1>
                        <p style="color:var(--text-muted);font-size:16px;margin-bottom:40px;line-height:1.6;">
                            Admin hələ bu kurs üçün quiz sualları əlavə etməyib.<br>
                            Kursun detayına qayıda bilərsiniz.
                        </p>
                        <button class="btn-premium" onclick="history.back()">
                            <i class="fa-solid fa-arrow-left"></i> Geri Qayıt
                        </button>
                    </div>`;
                btn.innerHTML = 'Testə Başla <i class="fa-solid fa-arrow-right"></i>';
                btn.disabled = false;
                return;
            }

            requestFullScreen();

            setView('view-quiz');
            startTimer();
            loadQuestion();
        };

        const loadQuestion = () => {
            selectedOptionId = null;
            document.getElementById('btn-next').disabled = true;
            questionStartTime = Date.now(); // Track start time for speed bonus

            const q = questions[currentQIndex];
            document.getElementById('question-text').innerText = q.text;
            document.getElementById('question-indicator').innerText = `Sual ${currentQIndex + 1} / ${questions.length}`;

            const pBar = document.getElementById('progress-bar');
            pBar.style.width = `${((currentQIndex) / questions.length) * 100}%`;

            const opts = document.getElementById('options-container');
            opts.innerHTML = '';

            q.options.forEach((opt) => {
                const btn = document.createElement('div');
                btn.className = 'option-btn';
                btn.innerHTML = `
                    <span>${opt.text}</span>
                    <div class="check-circle"><i class="fa-solid fa-check"></i></div>
                `;
                btn.onclick = () => selectOption(btn, opt.id);
                opts.appendChild(btn);
            });
        };

        const selectOption = (btnElement, optId) => {
            document.querySelectorAll('.option-btn').forEach(btn => btn.classList.remove('selected'));
            btnElement.classList.add('selected');
            selectedOptionId = optId;
            document.getElementById('btn-next').disabled = false;
        };

        const nextQuestion = (skipped) => {
            if(!skipped && selectedOptionId !== null) {
                let timeTaken = Math.floor((Date.now() - questionStartTime) / 1000);
                answersData.push({ 
                    questionId: questions[currentQIndex].id, 
                    optionId: selectedOptionId,
                    timeTakenSeconds: timeTaken
                });
            }

            currentQIndex++;
            if(currentQIndex < questions.length) {
                loadQuestion();
            } else {
                finishQuiz();
            }
        };

        const animateValue = (id, start, end, duration, suffix = "") => {
            if (start === end) return;
            let range = end - start;
            let current = start;
            let increment = end > start ? 1 : -1;
            let stepTime = Math.abs(Math.floor(duration / range));
            if(stepTime < 10) stepTime = 10;
            let obj = document.getElementById(id);
            let timer = setInterval(function() {
                current += increment;
                obj.innerHTML = (id === "res-xp" ? "+" : "") + current + suffix;
                if (current == end) {
                    clearInterval(timer);
                }
            }, stepTime);
        };

        const fireConfetti = () => {
            var duration = 3000;
            var end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 5,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: ['#00F0FF', '#7000FF', '#FFD700']
                });
                confetti({
                    particleCount: 5,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: ['#00F0FF', '#7000FF', '#FFD700']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
        };

        const finishQuiz = async () => {
            clearInterval(timerInterval);
            document.getElementById('progress-bar').style.width = '100%';

            setTimeout(async () => {
                setView('view-processing');

                try {
                    // SECURE POST TO BACKEND TO EVALUATE SCORE
                    const urlParams = new URLSearchParams(window.location.search);
                    const courseId = parseInt(urlParams.get('courseId')) || 0;
                    const categoryId = parseInt(urlParams.get('categoryId')) || 0;

                    const response = await fetch('/Assessment/SubmitAssessment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            Answers: answersData,
                            CheatAttempts: cheatAttempts,
                            CourseId: courseId > 0 ? courseId : null,
                            CategoryId: categoryId > 0 ? categoryId : null
                        })
                    });
                    
                    if(response.ok) {
                        const resultData = await response.json();
                        
                        // POPULATE UI
                        document.getElementById('result-level').innerText = resultData.level;
                        
                        // Wait for view to switch before counting
                        setTimeout(() => {
                            animateValue("res-xp", 0, resultData.xp, 1500);
                            animateValue("res-percent", 0, resultData.percentage, 1500, "%");
                        }, 500);

                        document.getElementById('res-roadmap').innerText = resultData.roadmap;
                        document.getElementById('res-strengths').innerText = resultData.strengths || "Yoxlanılır...";
                        document.getElementById('res-weak').innerText = resultData.weaknesses || "Yoxlanılır...";

                        // BUILD AI RECOMMENDED COURSES UI
                        const coursesGrid = document.getElementById('dynamic-courses-grid');
                        coursesGrid.innerHTML = '';

                        // ── Əvvəlcə həmin kursun tövsiyə edilən dərslərini göstər ──
                        const urlParams2 = new URLSearchParams(window.location.search);
                        const currentCourseId = parseInt(urlParams2.get('courseId')) || 0;

                        if (currentCourseId > 0) {
                            try {
                                const lessonsRes = await fetch(`/Assessment/GetRecommendedLessons?courseId=${currentCourseId}&level=${encodeURIComponent(resultData.level)}`);
                                if (lessonsRes.ok) {
                                    const lessonsData = await lessonsRes.json();
                                    if (lessonsData.videos && lessonsData.videos.length > 0) {
                                        const levelColor = resultData.level === 'Beginner' ? '#10B981' : resultData.level === 'Intermediate' ? '#fbbf24' : '#ef4444';
                                        let lessonsHtml = `
                                            <div style="background:rgba(0,240,255,0.04);border:1px solid rgba(0,240,255,0.15);border-radius:16px;padding:20px;margin-bottom:20px;">
                                                <h4 style="font-family:'Sora';margin-bottom:4px;font-size:17px;">
                                                    <i class="fa-solid fa-graduation-cap" style="color:var(--accent);"></i>
                                                    ${lessonsData.courseTitle} — Tövsiyə Edilən Dərslər
                                                </h4>
                                                <p style="color:var(--text-muted);font-size:13px;margin-bottom:16px;">${lessonsData.message}</p>
                                                <div style="display:flex;flex-direction:column;gap:8px;">`;

                                        lessonsData.videos.forEach((v, i) => {
                                            const lvlColor = v.level === 'Beginner' ? '#10B981' : v.level === 'Intermediate' ? '#fbbf24' : '#ef4444';
                                            lessonsHtml += `
                                                <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:rgba(255,255,255,0.03);border-radius:10px;border:1px solid rgba(255,255,255,0.06);">
                                                    <div style="width:28px;height:28px;border-radius:50%;background:${lvlColor}22;color:${lvlColor};display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;">${i+1}</div>
                                                    <div style="flex:1;">
                                                        <div style="font-size:14px;font-weight:600;color:#fff;">${v.title}</div>
                                                        <div style="font-size:11px;color:${lvlColor};margin-top:2px;">${v.level}</div>
                                                    </div>
                                                    <a href="/CourseDetail/Index/${currentCourseId}" style="font-size:12px;color:var(--accent);font-weight:600;white-space:nowrap;">
                                                        İzlə <i class="fa-solid fa-play" style="font-size:10px;"></i>
                                                    </a>
                                                </div>`;
                                        });

                                        lessonsHtml += `</div>
                                                <a href="/CourseDetail/Index/${currentCourseId}" style="display:inline-flex;align-items:center;gap:6px;margin-top:14px;font-size:13px;color:var(--accent);font-weight:600;">
                                                    Kursun bütün dərslərinə bax <i class="fa-solid fa-arrow-right"></i>
                                                </a>
                                            </div>`;
                                        coursesGrid.insertAdjacentHTML('beforeend', lessonsHtml);
                                    }
                                }
                            } catch(e) { console.error('Lessons fetch error:', e); }
                        }

                        // ── Digər tövsiyə edilən kurslar ──
                        if (resultData.recommendedCourses && resultData.recommendedCourses.length > 0) {
                            resultData.recommendedCourses.forEach((c) => {
                                const levelColor = c.level === 'Beginner' ? '#10B981' : c.level === 'Intermediate' ? '#fbbf24' : '#ef4444';
                                const html = `
                                    <a href="${c.url}" style="text-decoration: none; color: inherit; display: block;" class="course-rec-link">
                                        <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px; text-align: left; transition: 0.3s; position:relative; overflow:hidden;" class="course-rec-card">
                                            <div style="display:flex; justify-content: space-between; align-items:flex-start; margin-bottom:12px;">
                                                <span style="font-size: 11px; background: rgba(255,255,255,0.1); padding: 4px 8px; border-radius: 6px; color:#ddd; font-weight:600;"><i class="fa-solid fa-folder-tree"></i> ${c.category}</span>
                                                <span style="font-size: 11px; border: 1px solid ${levelColor}; padding: 4px 8px; border-radius: 6px; color:${levelColor}; font-weight:600;"><i class="fa-solid fa-layer-group"></i> ${c.level}</span>
                                            </div>
                                            <h4 style="font-family:'Sora'; margin-bottom:8px; font-size:16px;">${c.title}</h4>
                                            <p style="color:var(--text-muted); font-size:13px; line-height:1.5; margin-bottom:12px;">${c.shortDescription || 'Məlumat yoxdur'}</p>
                                            <div style="background: rgba(0, 240, 255, 0.05); border-left: 3px solid var(--accent); padding: 8px 12px; font-size: 12px; color:#fff;">
                                                <strong><i class="fa-solid fa-lightbulb" style="color:var(--accent);"></i> Niyə biz bunu seçdik?</strong><br/>
                                                <span style="color: rgba(255,255,255,0.8);">${c.reason}</span>
                                            </div>
                                        </div>
                                    </a>`;
                                coursesGrid.insertAdjacentHTML('beforeend', html);
                            });
                        } else if (coursesGrid.innerHTML === '') {
                            coursesGrid.innerHTML = `
                                <div style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.2); border-radius: 16px; padding: 40px 20px; text-align: center;">
                                    <i class="fa-solid fa-folder-open" style="font-size: 48px; color: var(--text-muted); margin-bottom: 16px;"></i>
                                    <h4 style="font-family:'Sora'; margin-bottom:8px; font-size:20px;">Xüsusi Kurs Tapılmadı</h4>
                                    <p style="color:var(--text-muted); font-size:14px; line-height: 1.6; max-width: 400px; margin: 0 auto;">Ümumi kataloqa göz ata bilərsiniz.</p>
                                </div>`;
                        }
                        
                        const glassCard = document.querySelector('.glass-card');

                        if(resultData.percentage === 100) {
                            // ULTRA PREMIUM CELEBRATION
                            document.getElementById('result-message').innerText = "KUSURSUZ NƏTİCƏ! Siz bir dahisiniz!";
                            document.getElementById('result-level').style.background = "linear-gradient(135deg, #00FF87, #60EFFF)";
                            document.getElementById('achievement-unlocked').style.display = "inline-flex";
                            document.getElementById('achievement-unlocked').innerHTML = '<div class="achievement-icon" style="background: linear-gradient(135deg, #00FF87, #60EFFF)"><i class="fa-solid fa-crown"></i></div><div class="achievement-text"><span>Yeni Nişan Açıldı</span><strong>Kusursuz Tələbə</strong></div>';
                            
                            glassCard.classList.add('victory-glow');
                            setTimeout(() => { 
                                fireConfetti(); 
                                setTimeout(fireConfetti, 1000); 
                                setTimeout(fireConfetti, 2000); 
                            }, 600);
                        } else if(resultData.level === "Advanced") {
                            document.getElementById('result-message').innerText = "Möhtəşəm nəticə! Siz tam hazırsınız.";
                            document.getElementById('result-level').style.background = "linear-gradient(135deg, #FFD700, #FF8C00)";
                            document.getElementById('achievement-unlocked').style.display = "inline-flex";
                            
                            // Cinematic WOW Effects
                            glassCard.classList.add('victory-glow');
                            setTimeout(() => { fireConfetti(); }, 600); // Wait for badge flip logic
                            
                        } else if(resultData.level === "Intermediate") {
                            document.getElementById('result-message').innerText = "Yaxşı irəliləyirsiniz! Baza bilikləriniz formalaşıb.";
                        } else {
                            document.getElementById('result-message').innerText = "Təlaşa ehtiyac yoxdur. Sıfırdan başlamaq ən doğrusudur.";
                            document.getElementById('res-potential').innerText = "Geniş";
                        }
                    }
                } catch(e) {
                    console.error("Xəta:", e);
                }

                setTimeout(() => setView('view-result'), 1200); // UI feel delay
            }, 600);
        };
    </script>
</body>
</html>