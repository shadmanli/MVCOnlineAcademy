@using Academy.ViewModels.Feature
@model FeatureCreateVM
@{ ViewData["Title"] = "Yeni Xüsusiyyət"; }
<partial name="~/Areas/Admin/Views/Shared/_AdminFormStyles.cshtml" />

<div class="p-page-header">
    <div class="p-page-title">Yeni Xüsusiyyət</div>
    <div class="p-breadcrumb"><a asp-area="Admin" asp-controller="Feature" asp-action="Index">Xüsusiyyətlər</a> / Yeni</div>
</div>

<div class="p-card" style="max-width:560px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="af-field">
            <label class="af-label">Başlıq <span class="req">*</span></label>
            <input asp-for="Title" class="form-control" placeholder="Xüsusiyyət başlığı" data-no-whitespace />
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Təsvir <span class="req">*</span></label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Xüsusiyyət haqqında..."></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">İkon / Şəkil</label>
            <input asp-for="Image" type="file" class="form-control" accept="image/*" />
            <span class="af-hint">Kart üzərində görünəcək ikon və ya şəkil (PNG, JPG, SVG)</span>
        </div>
        <div style="display:flex;gap:10px;margin-top:20px;">
            <button type="submit" class="af-submit"><i class="fa fa-check"></i> Yarat</button>
            <a asp-action="Index" class="af-cancel"><i class="fa fa-arrow-left"></i> Geri</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="~/Areas/Admin/Views/Shared/_AdminFormScripts.cshtml" /> }
