@model IEnumerable<Academy.Models.Order>
@{
    ViewData["Title"] = "Sifarişlər";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="p-page-header">
    <div>
        <h1 class="p-page-title">Sifarişlər</h1>
        <p class="p-page-sub">Bütün ödəniş sifarişlərini idarə edin</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="p-alert p-alert-success mb-4">
        <i class="fa fa-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="p-card">
    <div class="p-card-body">
        @if (!Model.Any())
        {
            <div style="text-align:center;padding:60px;color:#94a3b8;">
                <i class="fa fa-receipt" style="font-size:48px;display:block;margin-bottom:12px;"></i>
                <p>Hələ heç bir sifariş yoxdur.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:14px;">
                    <thead>
                        <tr style="border-bottom:2px solid #e8edf3;text-align:left;">
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">Sifariş №</th>
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">İstifadəçi</th>
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">Kurslar</th>
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">Məbləğ</th>
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">Status</th>
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">Tarix</th>
                            <th style="padding:12px 16px;color:#64748b;font-weight:600;">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr style="border-bottom:1px solid #f1f5f9;transition:background 0.15s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                                <td style="padding:14px 16px;">
                                    <span style="font-family:monospace;font-size:12px;color:#6366f1;font-weight:700;">@order.OrderNumber</span>
                                </td>
                                <td style="padding:14px 16px;">
                                    <div style="font-weight:600;color:#0f172a;">@order.FullName</div>
                                    <div style="font-size:12px;color:#94a3b8;">@order.Email</div>
                                </td>
                                <td style="padding:14px 16px;">
                                    @if (order.OrderItems != null)
                                    {
                                        foreach (var item in order.OrderItems)
                                        {
                                            <div style="font-size:13px;color:#374151;margin-bottom:2px;">
                                                <i class="fa fa-book-open" style="color:#00c4a8;margin-right:4px;font-size:11px;"></i>
                                                @(item.Course?.Title ?? item.CourseTitle)
                                            </div>
                                        }
                                    }
                                </td>
                                <td style="padding:14px 16px;">
                                    <span style="font-weight:700;color:#0f172a;">@order.TotalAmount AZN</span>
                                </td>
                                <td style="padding:14px 16px;">
                                    @{
                                        var (bg, color, label) = order.Status switch
                                        {
                                            Academy.Models.OrderStatus.Paid     => ("rgba(16,185,129,0.1)", "#10b981", "Ödənilib"),
                                            Academy.Models.OrderStatus.Pending  => ("rgba(245,158,11,0.1)", "#f59e0b", "Gözlənilir"),
                                            Academy.Models.OrderStatus.Failed   => ("rgba(239,68,68,0.1)",  "#ef4444", "Uğursuz"),
                                            Academy.Models.OrderStatus.Refunded => ("rgba(99,102,241,0.1)", "#6366f1", "Geri Qaytarıldı"),
                                            _ => ("rgba(148,163,184,0.1)", "#94a3b8", order.Status.ToString())
                                        };
                                    }
                                    <span style="background:@bg;color:@color;padding:4px 10px;border-radius:99px;font-size:12px;font-weight:700;">@label</span>
                                </td>
                                <td style="padding:14px 16px;font-size:13px;color:#64748b;">
                                    @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td style="padding:14px 16px;">
                                    @if (order.Status != Academy.Models.OrderStatus.Paid)
                                    {
                                        <form asp-action="MarkAsPaid" asp-route-id="@order.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#10b981;padding:6px 14px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;transition:all 0.2s;"
                                                    onmouseover="this.style.background='rgba(16,185,129,0.2)'"
                                                    onmouseout="this.style.background='rgba(16,185,129,0.1)'">
                                                <i class="fa fa-check"></i> Paid Et
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="MarkAsPending" asp-route-id="@order.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);color:#f59e0b;padding:6px 14px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;transition:all 0.2s;"
                                                    onmouseover="this.style.background='rgba(245,158,11,0.2)'"
                                                    onmouseout="this.style.background='rgba(245,158,11,0.1)'">
                                                <i class="fa fa-undo"></i> Geri Al
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.p-alert { padding:12px 16px;border-radius:10px;display:flex;align-items:center;gap:8px;font-size:14px; }
.p-alert-success { background:#ecfdf5;color:#059669;border:1px solid #a7f3d0; }
.mb-4 { margin-bottom:16px; }
</style>
