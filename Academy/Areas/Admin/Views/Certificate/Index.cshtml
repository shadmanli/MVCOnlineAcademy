@model IEnumerable<Academy.Models.Certificate>
@{ ViewData["Title"] = "Sertifikatlar"; }
<partial name="~/Areas/Admin/Views/Shared/_AdminFormStyles.cshtml" />

<div class="p-page-header">
    <div>
        <div class="p-page-title">Sertifikatlar</div>
        <div class="p-breadcrumb">Admin / Sertifikatlar</div>
    </div>
    <a asp-action="Issue" class="p-btn-primary"><i class="fa fa-plus"></i> Manual Ver</a>
</div>

<!-- Stats -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;">
    <div class="p-stat-card" style="background:rgba(0,196,168,0.08);border:1px solid rgba(0,196,168,0.2);border-radius:14px;padding:20px;">
        <div style="font-size:28px;font-weight:800;color:#00c4a8;">@ViewBag.TotalCount</div>
        <div style="font-size:12px;color:#64748b;margin-top:4px;">Ümumi Sertifikat</div>
    </div>
    <div class="p-stat-card" style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:14px;padding:20px;">
        <div style="font-size:28px;font-weight:800;color:#10b981;">@ViewBag.ActiveCount</div>
        <div style="font-size:12px;color:#64748b;margin-top:4px;">Aktiv</div>
    </div>
    <div class="p-stat-card" style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:14px;padding:20px;">
        <div style="font-size:28px;font-weight:800;color:#ef4444;">@ViewBag.RevokedCount</div>
        <div style="font-size:12px;color:#64748b;margin-top:4px;">Ləğv Edilmiş</div>
    </div>
</div>

<!-- Search -->
<form method="get" style="margin-bottom:20px;display:flex;gap:10px;">
    <input name="search" value="@ViewBag.Search" placeholder="Ad, kurs, sertifikat № axtar..."
           class="form-control" style="max-width:320px;" />
    <button type="submit" class="p-btn-primary"><i class="fa fa-search"></i> Axtar</button>
</form>

<div class="p-card" style="overflow:hidden;">
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.06);">
                <th style="padding:12px 16px;text-align:left;color:#64748b;font-weight:600;">Sertifikat №</th>
                <th style="padding:12px 16px;text-align:left;color:#64748b;font-weight:600;">Tələbə</th>
                <th style="padding:12px 16px;text-align:left;color:#64748b;font-weight:600;">Kurs</th>
                <th style="padding:12px 16px;text-align:left;color:#64748b;font-weight:600;">Tarix</th>
                <th style="padding:12px 16px;text-align:left;color:#64748b;font-weight:600;">Status</th>
                <th style="padding:12px 16px;text-align:left;color:#64748b;font-weight:600;">Əməliyyat</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr style="border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
                    <td style="padding:13px 16px;font-family:monospace;font-size:12px;color:#00c4a8;font-weight:700;">@c.CertificateNumber</td>
                    <td style="padding:13px 16px;color:#f1f5f9;font-weight:500;">@(c.AppUser?.FullName ?? "-")</td>
                    <td style="padding:13px 16px;color:#94a3b8;">@(c.Course?.Title ?? "-")</td>
                    <td style="padding:13px 16px;color:#64748b;">@c.IssuedAt.ToString("dd.MM.yyyy")</td>
                    <td style="padding:13px 16px;">
                        @if (c.IsRevoked)
                        {
                            <span style="background:rgba(239,68,68,0.1);color:#ef4444;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;border:1px solid rgba(239,68,68,0.2);">Ləğv edilib</span>
                        }
                        else if (c.IsManual)
                        {
                            <span style="background:rgba(245,158,11,0.1);color:#f59e0b;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;border:1px solid rgba(245,158,11,0.2);">Manual</span>
                        }
                        else
                        {
                            <span style="background:rgba(16,185,129,0.1);color:#10b981;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;border:1px solid rgba(16,185,129,0.2);">Aktiv</span>
                        }
                    </td>
                    <td style="padding:13px 16px;">
                        <div style="display:flex;gap:8px;">
                            <a href="/Certificate/View/@c.CertificateNumber" target="_blank"
                               style="padding:5px 12px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:7px;color:#94a3b8;font-size:12px;text-decoration:none;transition:all 0.2s;"
                               onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#94a3b8'">
                                <i class="fa fa-eye"></i>
                            </a>
                            @if (!c.IsRevoked)
                            {
                                <button onclick="revokeAction(@c.Id)"
                                        style="padding:5px 12px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:7px;color:#ef4444;font-size:12px;cursor:pointer;transition:all 0.2s;">
                                    <i class="fa fa-ban"></i> Ləğv Et
                                </button>
                            }
                            else
                            {
                                <button onclick="restoreAction(@c.Id)"
                                        style="padding:5px 12px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:7px;color:#10b981;font-size:12px;cursor:pointer;transition:all 0.2s;">
                                    <i class="fa fa-rotate-right"></i> Bərpa Et
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6" style="padding:40px;text-align:center;color:#475569;">Sertifikat tapılmadı.</td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
function revokeAction(id) {
    var reason = prompt('Ləğv etmə səbəbi (ixtiyari):');
    if (reason === null) return;
    fetch('/Admin/Certificate/Revoke/' + id, {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded','RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]')?.value || ''},
        body: 'reason=' + encodeURIComponent(reason)
    }).then(r=>r.json()).then(d=>{ if(d.success) location.reload(); });
}
function restoreAction(id) {
    if (!confirm('Sertifikatı bərpa edirsiniz?')) return;
    fetch('/Admin/Certificate/Restore/' + id, {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded','RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]')?.value || ''}
    }).then(r=>r.json()).then(d=>{ if(d.success) location.reload(); });
}
</script>
@Html.AntiForgeryToken()
}
