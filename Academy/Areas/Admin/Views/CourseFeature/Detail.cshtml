@model Academy.ViewModels.CourseFeature.CourseFeatureDetailVM

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h3 class="fw-bold mb-3" style="color:black;">
                        @Model.Text
                    </h3>

                    <p class="text-muted">Course:</p>

                    <span class="badge bg-primary fs-6">
                        @Model.CourseName
                    </span>

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary px-4">
                            Geri qayıt
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>

</div>