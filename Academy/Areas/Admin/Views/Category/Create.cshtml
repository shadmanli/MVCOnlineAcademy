@using Academy.ViewModels.Category
@model CategoryCreateVM
@{ ViewData["Title"] = "Yeni Kateqoriya"; }
<partial name="~/Areas/Admin/Views/Shared/_AdminFormStyles.cshtml" />

<div class="p-page-header">
    <div class="p-page-title">Yeni Kateqoriya</div>
    <div class="p-breadcrumb"><a asp-area="Admin" asp-controller="Category" asp-action="Index">Kateqoriyalar</a> / Yeni</div>
</div>

<div class="p-card" style="max-width:480px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="af-field">
            <label class="af-label">Kateqoriya Adı <span class="req">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="Məs: Proqramlaşdırma" data-no-whitespace />
            <span asp-validation-for="Name" class="field-validation-error"></span>
        </div>
        <div style="display:flex;gap:10px;margin-top:20px;">
            <button type="submit" class="af-submit"><i class="fa fa-check"></i> Yarat</button>
            <a asp-action="Index" class="af-cancel"><i class="fa fa-arrow-left"></i> Geri</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="~/Areas/Admin/Views/Shared/_AdminFormScripts.cshtml" /> }
