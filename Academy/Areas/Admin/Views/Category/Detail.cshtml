@using Academy.ViewModels.Category
@model CategoryDetailVM

<h2>@Model.Name</h2>

<h4>Courses:</h4>
<div class="row">
    @foreach (var course in Model.Courses)
    {
        <div class="col-md-4">
            <div class="card p-2">
                <img src="~/uploads/@course.ImageUrl" />
                <h5>@course.Title</h5>
            </div>
        </div>
    }
</div>