@{
    ViewData["Title"] = "Yeni Sual ?lav? Et";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-secondary rounded h-100 p-4">
        <h6 class="mb-4">Yeni Quiz Sual? Yarat</h6>

        <form asp-action="Create" method="post" id="questionForm">
            <div class="mb-3">
                <label for="courseId" class="form-label">Kurs <span class="text-danger">*</span></label>
                <select name="courseId" id="courseId" class="form-select bg-dark text-white" required>
                    <option value="">-- Kurs Seçin --</option>
                    @if (ViewBag.Courses != null)
                    {
                        foreach (var course in ViewBag.Courses)
                        {
                            <option value="@course.Id">@course.Title</option>
                        }
                    }
                </select>
                <div class="form-text text-muted">Sual hansı kursun quiz-inə aid olacaq</div>
            </div>

            <div class="mb-3">
                <label for="categoryId" class="form-label">Kateqoriya <span class="text-danger">*</span></label>
                <select name="categoryId" id="categoryId" class="form-select bg-dark text-white" required>
                    <option value="">-- Kateqoriya Seçin --</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>
            </div>
            
            <div class="mb-3">
                <label for="DefaultText" class="form-label">Sual Mətni <span class="text-danger">*</span></label>
                <input type="text" class="form-control bg-dark text-white" name="DefaultText" id="DefaultText" required placeholder="Məsələn: C#-da 'readonly' və 'const' fərqi nədir?">
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Çətinlik Dərəcəsi</label>
                    <select name="difficulty" class="form-select bg-dark text-white">
                        <option value="1">Asan</option>
                        <option value="2" selected>Orta</option>
                        <option value="3">Çətin</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Xal</label>
                    <input type="number" name="points" class="form-control bg-dark text-white" value="10" min="1" max="100">
                </div>
            </div>

            <h6 class="mb-3 mt-4">Cavab Variantlar?</h6>
            <div id="optionsWrap">
                <!-- Variant 1 -->
                <div class="d-flex align-items-center mb-2 option-row">
                    <div class="form-check me-3">
                        <input class="form-check-input correct-radio" type="radio" name="correctOptionIndex" value="0" required checked>
                    </div>
                    <input type="text" class="form-control bg-dark" name="optionTexts" placeholder="Variant 1" required>
                    <button type="button" class="btn btn-sm btn-outline-danger ms-2 remove-btn" style="display:none;"><i class="fa fa-times"></i></button>
                </div>
                <!-- Variant 2 -->
                <div class="d-flex align-items-center mb-2 option-row">
                    <div class="form-check me-3">
                        <input class="form-check-input correct-radio" type="radio" name="correctOptionIndex" value="1" required>
                    </div>
                    <input type="text" class="form-control bg-dark" name="optionTexts" placeholder="Variant 2" required>
                    <button type="button" class="btn btn-sm btn-outline-danger ms-2 remove-btn"><i class="fa fa-times"></i></button>
                </div>
            </div>

            <button type="button" class="btn btn-sm btn-outline-success mt-2 mb-4" id="addOptionBtn"><i class="fa fa-plus"></i> Variant ?lav? Et</button>
            <br />

            <button type="submit" class="btn btn-primary d-inline-flex">Yadda Saxla</button>
            <a asp-action="Index" class="btn btn-outline-light ms-2">Geri Qay?t</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const wrap = document.getElementById('optionsWrap');
            const addBtn = document.getElementById('addOptionBtn');
            let optionCount = 2; // Init with 2

            // Function to add a row
            addBtn.addEventListener('click', () => {
                const div = document.createElement('div');
                div.className = 'd-flex align-items-center mb-2 option-row';
                div.innerHTML = `
                    <div class="form-check me-3">
                        <input class="form-check-input correct-radio" type="radio" name="correctOptionIndex" value="${optionCount}" required>
                    </div>
                    <input type="text" class="form-control bg-dark" name="optionTexts" placeholder="Variant ${optionCount + 1}" required>
                    <button type="button" class="btn btn-sm btn-outline-danger ms-2 remove-btn"><i class="fa fa-times"></i></button>
                `;
                wrap.appendChild(div);
                optionCount++;
                bindRemoveButtons();
                updateRadioValues();
            });

            // Rebind removes
            function bindRemoveButtons() {
                document.querySelectorAll('.remove-btn').forEach(btn => {
                    btn.onclick = function() {
                        this.parentElement.remove();
                        updateRadioValues();
                    };
                });
            }

            // Keep radio index values synced with exact loop index
            function updateRadioValues() {
                const radios = document.querySelectorAll('.correct-radio');
                radios.forEach((r, idx) => {
                    r.value = idx;
                });
            }

            bindRemoveButtons();
        });
    </script>
}