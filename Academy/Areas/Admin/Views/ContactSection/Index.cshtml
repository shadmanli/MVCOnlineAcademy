@using System.Linq
@model IEnumerable<ContactSectionVM>

<div class="container-md mt-5">

  
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold" style="color:wheat;">Contact Sections</h2>
        <a asp-action="Create" class="btn btn-secondary">Əlavə et</a>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="row g-4 justify-content-center">
            @foreach (var sec in Model)
            {
                <div class="col-12 col-lg-10 mx-auto" data-id="@sec.Id">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">

                         
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h3 class="text-dark fw-semibold mb-1">@sec.Title</h3>
                                    <p class="text-dark mb-0">@sec.SubTitle</p>
                                </div>

                                <div class="d-flex gap-2">
                                    <a asp-action="Detail"
                                       asp-route-id="@sec.Id"
                                       class="btn btn-info btn-sm">
                                        Ətraflı
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@sec.Id"
                                       class="btn btn-warning btn-sm">
                                        Redaktə
                                    </a>

                                    <button class="btn btn-danger btn-sm delete-btn">
                                        Sil
                                    </button>
                                </div>
                            </div>

                
                            @if (sec.Items?.Any() == true)
                            {
                                <div class="row row-cols-1 row-cols-md-3 g-3 mt-2 justify-content-center">
                                    @foreach (var item in sec.Items)
                                    {
                                        <div class="col">
                                            <div class="card h-100 border-0 shadow-sm text-center mx-auto">
                                                <div class="card-body d-flex flex-column justify-content-center">
                                                    <h5 class="text-dark fw-medium">@item.Description</h5>
                                                    <p class="text-dark mb-0">@item.Address</p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-dark fst-italic mt-2 mb-0 text-center">Bu bölməyə aid item yoxdur.</p>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-dark fst-italic text-center">Heç bir bölmə tapılmadı.</p>
    }

</div>

<script>
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            if (!confirm('Silinsin?')) return;

            const div = this.closest('[data-id]');
            const id = div.getAttribute('data-id');

            fetch(`/Admin/ContactSection/Delete/${id}`, { method: 'POST' })
                .then(res => {
                    if (res.ok) div.remove();
                    else alert('Xəta baş verdi!');
                });
        });
    });
</script>