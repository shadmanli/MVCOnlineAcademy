      </div>
    </div>

    <!-- Right: Donut Chart -->
    <div class="db-panel panel-right">
      <div class="db-panel-title">
        <span class="db-panel-title-dot"></span>
        Bal B√∂lg√ºs√º
      </div>
      <div class="db-donut-wrap">
        <canvas id="donutChart" width="160" height="160" class="db-donut-canvas"></canvas>
        <div class="db-legend">
          <div class="db-legend-item">
            <span class="db-legend-dot" style="background:#10b981;"></span>
            Beginner
