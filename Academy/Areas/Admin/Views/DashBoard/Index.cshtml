Ôªø@model List<Academy.Models.UserAssessmentResult>
@{
    ViewData["Title"] = "T…ôl…ôb…ô N…ôtic…ôl…ôri Statistikasƒ±";
    int beginnerCount      = ViewBag.BeginnerCount ?? 0;
    int intermediateCount  = ViewBag.IntermediateCount ?? 0;
    int advancedCount      = ViewBag.AdvancedCount ?? 0;
    int totalStudents      = ViewBag.TotalStudents ?? 0;
    double averageScore    = ViewBag.AverageScore ?? 0;
    int totalForBar        = beginnerCount + intermediateCount + advancedCount;
    double begPct  = totalForBar > 0 ? Math.Round((double)beginnerCount     / totalForBar * 100) : 0;
    double intPct  = totalForBar > 0 ? Math.Round((double)intermediateCount / totalForBar * 100) : 0;
    double advPct  = totalForBar > 0 ? Math.Round((double)advancedCount     / totalForBar * 100) : 0;
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ‚îÄ‚îÄ Reset for this page ‚îÄ‚îÄ */
.p-content * { font-family: 'Plus Jakarta Sans', sans-serif !important; }

/* ‚îÄ‚îÄ Page header ‚îÄ‚îÄ */
.db-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 12px;
}

.db-title {
    font-size: 22px;
    font-weight: 800;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.4px;
}

.db-subtitle { font-size: 13px; color: #475569; margin-top: 3px; }

/* ‚îÄ‚îÄ Top bar ‚îÄ‚îÄ */
.db-topbar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 12px 18px;
    margin-bottom: 24px;
}

.db-search {
    flex: 1;
    max-width: 280px;
    position: relative;
}

.db-search input {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 8px 14px 8px 36px;
    color: #f1f5f9;
    font-size: 13px;
    outline: none;
    transition: all 0.25s ease;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
}

.db-search input:focus {
    border-color: rgba(167,139,250,0.5);
    background: rgba(167,139,250,0.05);
    box-shadow: 0 0 0 3px rgba(167,139,250,0.12);
}

.db-search input::placeholder { color: #475569; }

.db-search-icon {
    position: absolute;
    left: 11px; top: 50%;
    transform: translateY(-50%);
    color: #475569;
    font-size: 12px;
}

.db-topbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }

.db-icon-btn {
    width: 36px; height: 36px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 14px;
    text-decoration: none;
}

.db-icon-btn:hover { background: rgba(167,139,250,0.1); color: #a78bfa; border-color: rgba(167,139,250,0.3); }

.db-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: #fff;
    cursor: pointer;
    border: 2px solid rgba(167,139,250,0.4);
}

/* ‚îÄ‚îÄ Stat Cards ‚îÄ‚îÄ */
.db-stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 22px;
}

@@media (max-width: 640px) { .db-stat-grid { grid-template-columns: 1fr; } }

.db-stat-card {
    border-radius: 18px;
    padding: 26px 24px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
}

.db-stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}

.db-stat-card.purple {
    background: linear-gradient(135deg, #1e1040 0%, #3b1f8c 50%, #6d28d9 100%);
    border: 1px solid rgba(167,139,250,0.25);
    box-shadow: 0 8px 32px rgba(109,40,217,0.3);
}

.db-stat-card.blue {
    background: linear-gradient(135deg, #0c1a3a 0%, #1e3a8a 50%, #1d4ed8 100%);
    border: 1px solid rgba(56,189,248,0.25);
    box-shadow: 0 8px 32px rgba(29,78,216,0.3);
}

/* Dekorativ blob */
.db-stat-blob {
    position: absolute;
    width: 140px; height: 140px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.25;
    top: -30px; right: -30px;
    pointer-events: none;
}

.purple .db-stat-blob { background: #c084fc; }
.blue   .db-stat-blob { background: #38bdf8; }

.db-stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 14px;
    backdrop-filter: blur(8px);
}

.purple .db-stat-badge { background: rgba(192,132,252,0.15); color: #e9d5ff; border: 1px solid rgba(192,132,252,0.3); }
.blue   .db-stat-badge { background: rgba(56,189,248,0.15);  color: #bae6fd; border: 1px solid rgba(56,189,248,0.3); }

.db-stat-num {
    font-size: 44px;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -2px;
    margin-bottom: 6px;
}

.db-stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    font-weight: 500;
}

/* ‚îÄ‚îÄ Bottom panels ‚îÄ‚îÄ */
.db-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 22px;
}

@@media (max-width: 768px) { .db-panel-grid { grid-template-columns: 1fr; } }

.db-panel {
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px;
    padding: 24px;
    position: relative;
    overflow: hidden;
}

/* R…ôngli aksent x…ôtti */
.db-panel::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    border-radius: 0 0 18px 18px;
}

.db-panel.panel-left::after  { background: linear-gradient(90deg, #10b981, #34d399); }
.db-panel.panel-right::after { background: linear-gradient(90deg, #a78bfa, #38bdf8); }

.db-panel-title {
    font-size: 15px;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.db-panel-title-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
}

.panel-left  .db-panel-title-dot { background: #10b981; box-shadow: 0 0 8px #10b981; }
.panel-right .db-panel-title-dot { background: #a78bfa; box-shadow: 0 0 8px #a78bfa; }

/* Progress bars */
.db-level-row { margin-bottom: 16px; }

.db-level-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
}

.db-level-name {
    font-size: 13px;
    font-weight: 600;
    color: #94a3b8;
    display: flex;
    align-items: center;
    gap: 7px;
}

.db-level-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
}

.db-level-pct { font-size: 13px; font-weight: 700; color: #f1f5f9; }

.db-progress-track {
    height: 8px;
    background: rgba(255,255,255,0.06);
    border-radius: 99px;
    overflow: hidden;
}

.db-progress-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 1s ease;
}

/* Donut chart */
.db-donut-wrap {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
}

.db-donut-canvas { flex-shrink: 0; }

.db-legend { display: flex; flex-direction: column; gap: 10px; }

.db-legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #94a3b8;
}

.db-legend-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
}

.db-legend-val { font-weight: 700; color: #f1f5f9; margin-left: auto; }

/* ‚îÄ‚îÄ Student cards ‚îÄ‚îÄ */
.db-students-title {
    font-size: 16px;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.db-student-card {
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 16px 18px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.25s ease;
    border-left: 3px solid transparent;
}

.db-student-card:hover {
    border-color: rgba(167,139,250,0.3);
    background: rgba(167,139,250,0.04);
    transform: translateX(3px);
}

.db-student-card.lv-Beginner     { border-left-color: #10b981; }
.db-student-card.lv-Intermediate { border-left-color: #f59e0b; }
.db-student-card.lv-Advanced     { border-left-color: #ef4444; }

.db-student-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 15px; color: #fff;
    flex-shrink: 0;
    margin-right: 12px;
}

.db-student-name { font-size: 14px; font-weight: 600; color: #f1f5f9; }
.db-student-meta { font-size: 12px; color: #475569; margin-top: 2px; }

.db-student-pct {
    font-size: 20px;
    font-weight: 800;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.db-xp-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 20px;
    background: rgba(255,255,255,0.06);
    color: #94a3b8;
    border: 1px solid rgba(255,255,255,0.08);
    margin-top: 3px;
    display: inline-block;
}

/* Empty state */
.db-empty {
    text-align: center;
    padding: 40px 20px;
    color: #475569;
}

.db-empty i { font-size: 36px; margin-bottom: 12px; display: block; }
</style>
}

<div>

  <!-- Top Bar -->
  <div class="db-topbar">
    <div class="db-search">
      <i class="fa fa-magnifying-glass db-search-icon"></i>
      <input type="text" id="studentSearch" placeholder="T…ôl…ôb…ô axtar..."
             oninput="window.filterStudents && window.filterStudents(this.value)">
    </div>
    <div class="db-topbar-right">
      <a href="/Admin/ContactMessage" class="db-icon-btn" title="Mesajlar">
        <i class="fa fa-envelope"></i>
      </a>
      <div class="db-icon-btn" title="Bildiri≈ül…ôr">
        <i class="fa fa-bell"></i>
      </div>
      <div class="db-avatar">A</div>
    </div>
  </div>

  <!-- Page Title -->
  <div class="db-header">
    <div>
      <div class="db-title">T…ôl…ôb…ô N…ôtic…ôl…ôri Statistikasƒ±</div>
      <div class="db-subtitle">Quiz n…ôtic…ôl…ôri v…ô s…ôviyy…ô analizi</div>
