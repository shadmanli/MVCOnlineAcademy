@model List<Academy.Models.UserAssessmentResult>
@{
    ViewData["Title"] = "Tələbə Nəticələri Statistikası";
    int beginnerCount      = ViewBag.BeginnerCount ?? 0;
    int intermediateCount  = ViewBag.IntermediateCount ?? 0;
    int advancedCount      = ViewBag.AdvancedCount ?? 0;
    int totalStudents      = ViewBag.TotalStudents ?? 0;
    double averageScore    = ViewBag.AverageScore ?? 0;
    int totalForBar        = beginnerCount + intermediateCount + advancedCount;
    double begPct  = totalForBar > 0 ? Math.Round((double)beginnerCount     / totalForBar * 100) : 0;
    double intPct  = totalForBar > 0 ? Math.Round((double)intermediateCount / totalForBar * 100) : 0;
    double advPct  = totalForBar > 0 ? Math.Round((double)advancedCount     / totalForBar * 100) : 0;
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ── Reset for this page ── */
.p-content * { font-family: 'Plus Jakarta Sans', sans-serif !important; }

/* ── Page header ── */
.db-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 12px;
}

.db-title {
    font-size: 22px;
    font-weight: 800;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.4px;
}

.db-subtitle { font-size: 13px; color: #475569; margin-top: 3px; }

/* ── Top bar ── */
.db-topbar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 12px 18px;
    margin-bottom: 24px;
}

.db-search {
    flex: 1;
    max-width: 280px;
    position: relative;
}

.db-search input {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 8px 14px 8px 36px;
    color: #f1f5f9;
    font-size: 13px;
    outline: none;
    transition: all 0.25s ease;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
}

.db-search input:focus {
    border-color: rgba(167,139,250,0.5);
    background: rgba(167,139,250,0.05);
    box-shadow: 0 0 0 3px rgba(167,139,250,0.12);
}

.db-search input::placeholder { color: #475569; }

.db-search-icon {
    position: absolute;
    left: 11px; top: 50%;
    transform: translateY(-50%);
    color: #475569;
    font-size: 12px;
}

.db-topbar-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }

.db-icon-btn {
    width: 36px; height: 36px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 14px;
    text-decoration: none;
}

.db-icon-btn:hover { background: rgba(167,139,250,0.1); color: #a78bfa; border-color: rgba(167,139,250,0.3); }

.db-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px; color: #fff;
    cursor: pointer;
    border: 2px solid rgba(167,139,250,0.4);
}

/* ── Stat Cards ── */
.db-stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 22px;
}

@@media (max-width: 640px) { .db-stat-grid { grid-template-columns: 1fr; } }

.db-stat-card {
    border-radius: 18px;
    padding: 26px 24px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: default;
}

.db-stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}

.db-stat-card.purple {
    background: linear-gradient(135deg, #1e1040 0%, #3b1f8c 50%, #6d28d9 100%);
    border: 1px solid rgba(167,139,250,0.25);
    box-shadow: 0 8px 32px rgba(109,40,217,0.3);
}

.db-stat-card.blue {
    background: linear-gradient(135deg, #0c1a3a 0%, #1e3a8a 50%, #1d4ed8 100%);
    border: 1px solid rgba(56,189,248,0.25);
    box-shadow: 0 8px 32px rgba(29,78,216,0.3);
}

/* Dekorativ blob */
.db-stat-blob {
    position: absolute;
    width: 140px; height: 140px;
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.25;
    top: -30px; right: -30px;
    pointer-events: none;
}

.purple .db-stat-blob { background: #c084fc; }
.blue   .db-stat-blob { background: #38bdf8; }

.db-stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 14px;
    backdrop-filter: blur(8px);
}

.purple .db-stat-badge { background: rgba(192,132,252,0.15); color: #e9d5ff; border: 1px solid rgba(192,132,252,0.3); }
.blue   .db-stat-badge { background: rgba(56,189,248,0.15);  color: #bae6fd; border: 1px solid rgba(56,189,248,0.3); }

.db-stat-num {
    font-size: 44px;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -2px;
    margin-bottom: 6px;
}

.db-stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
    font-weight: 500;
}

/* ── Bottom panels ── */
.db-panel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 22px;
}

@@media (max-width: 768px) { .db-panel-grid { grid-template-columns: 1fr; } }

.db-panel {
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px;
    padding: 24px;
    position: relative;
    overflow: hidden;
}

/* Rəngli aksent xətti */
.db-panel::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    border-radius: 0 0 18px 18px;
}

.db-panel.panel-left::after  { background: linear-gradient(90deg, #10b981, #34d399); }
.db-panel.panel-right::after { background: linear-gradient(90deg, #a78bfa, #38bdf8); }

.db-panel-title {
    font-size: 15px;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.db-panel-title-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
}

.panel-left  .db-panel-title-dot { background: #10b981; box-shadow: 0 0 8px #10b981; }
.panel-right .db-panel-title-dot { background: #a78bfa; box-shadow: 0 0 8px #a78bfa; }

/* Progress bars */
.db-level-row { margin-bottom: 16px; }

.db-level-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 7px;
}

.db-level-name {
    font-size: 13px;
    font-weight: 600;
    color: #94a3b8;
    display: flex;
    align-items: center;
    gap: 7px;
}

.db-level-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
}

.db-level-pct { font-size: 13px; font-weight: 700; color: #f1f5f9; }

.db-progress-track {
    height: 8px;
    background: rgba(255,255,255,0.06);
    border-radius: 99px;
    overflow: hidden;
}

.db-progress-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 1s ease;
}

/* Donut chart */
.db-donut-wrap {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
}

.db-donut-canvas { flex-shrink: 0; }

.db-legend { display: flex; flex-direction: column; gap: 10px; }

.db-legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #94a3b8;
}

.db-legend-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
}

.db-legend-val { font-weight: 700; color: #f1f5f9; margin-left: auto; }

/* ── Student cards ── */
.db-students-title {
    font-size: 16px;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.db-student-card {
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 16px 18px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.25s ease;
    border-left: 3px solid transparent;
}

.db-student-card:hover {
    border-color: rgba(167,139,250,0.3);
    background: rgba(167,139,250,0.04);
    transform: translateX(3px);
}

.db-student-card.lv-Beginner     { border-left-color: #10b981; }
.db-student-card.lv-Intermediate { border-left-color: #f59e0b; }
.db-student-card.lv-Advanced     { border-left-color: #ef4444; }

.db-student-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 15px; color: #fff;
    flex-shrink: 0;
    margin-right: 12px;
}

.db-student-name { font-size: 14px; font-weight: 600; color: #f1f5f9; }
.db-student-meta { font-size: 12px; color: #475569; margin-top: 2px; }

.db-student-pct {
    font-size: 20px;
    font-weight: 800;
    background: linear-gradient(135deg, #a78bfa, #38bdf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.db-xp-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 20px;
    background: rgba(255,255,255,0.06);
    color: #94a3b8;
    border: 1px solid rgba(255,255,255,0.08);
    margin-top: 3px;
    display: inline-block;
}

/* Empty state */
.db-empty {
    text-align: center;
    padding: 40px 20px;
    color: #475569;
}

.db-empty i { font-size: 36px; margin-bottom: 12px; display: block; }
</style>
}

<div>

  <!-- Top Bar -->
  <div class="db-topbar">
    <div class="db-search">
      <i class="fa fa-magnifying-glass db-search-icon"></i>
      <input type="text" placeholder="Tələbə axtar...">
    </div>
    <div class="db-topbar-right">
      <a href="/Admin/ContactMessage" class="db-icon-btn" title="Mesajlar">
        <i class="fa fa-envelope"></i>
      </a>
      <div class="db-icon-btn" title="Bildirişlər">
        <i class="fa fa-bell"></i>
      </div>
      <div class="db-avatar">A</div>
    </div>
  </div>

  <!-- Page Title -->
  <div class="db-header">
    <div>
      <div class="db-title">Tələbə Nəticələri Statistikası</div>
      <div class="db-subtitle">Quiz nəticələri və səviyyə analizi</div>
    </div>
  </div>

  <!-- Stat Cards -->
  <div class="db-stat-grid">

    <div class="db-stat-card purple">
      <div class="db-stat-blob"></div>
      <div class="db-stat-badge">
        <i class="fa fa-users"></i> Tələbələr
      </div>
      <div class="db-stat-num" id="cnt-students">0</div>
      <div class="db-stat-label">Məzun / Quiz Edən Tələbələr</div>
    </div>

    <div class="db-stat-card blue">
      <div class="db-stat-blob"></div>
      <div class="db-stat-badge">
        <i class="fa fa-chart-line"></i> Orta Bal
      </div>
      <div class="db-stat-num">
        <span id="cnt-avg">0</span><span style="font-size:28px;opacity:.7;">%</span>
      </div>
      <div class="db-stat-label">Orta Bal (Faiz)</div>
    </div>

  </div>

  <!-- Panels -->
  <div class="db-panel-grid">

    <!-- Left: Level Distribution -->
    <div class="db-panel panel-left">
      <div class="db-panel-title">
        <span class="db-panel-title-dot"></span>
        Səviyyə Dağılımı
      </div>

      <div class="db-level-row">
        <div class="db-level-header">
          <span class="db-level-name">
            <span class="db-level-dot" style="background:#10b981;box-shadow:0 0 6px #10b981;"></span>
            Beginner
          </span>
          <span class="db-level-pct">@beginnerCount nəfər (@begPct%)</span>
        </div>
        <div class="db-progress-track">
          <div class="db-progress-fill" style="width:0%;background:linear-gradient(90deg,#10b981,#34d399);"
               data-target="@begPct"></div>
        </div>
      </div>

      <div class="db-level-row">
        <div class="db-level-header">
          <span class="db-level-name">
            <span class="db-level-dot" style="background:#f59e0b;box-shadow:0 0 6px #f59e0b;"></span>
            Intermediate
          </span>
          <span class="db-level-pct">@intermediateCount nəfər (@intPct%)</span>
        </div>
        <div class="db-progress-track">
          <div class="db-progress-fill" style="width:0%;background:linear-gradient(90deg,#f59e0b,#fbbf24);"
               data-target="@intPct"></div>
        </div>
      </div>

      <div class="db-level-row">
        <div class="db-level-header">
          <span class="db-level-name">
            <span class="db-level-dot" style="background:#ef4444;box-shadow:0 0 6px #ef4444;"></span>
            Advanced
          </span>
          <span class="db-level-pct">@advancedCount nəfər (@advPct%)</span>
        </div>
        <div class="db-progress-track">
          <div class="db-progress-fill" style="width:0%;background:linear-gradient(90deg,#ef4444,#f87171);"
               data-target="@advPct"></div>
        </div>
      </div>
    </div>

    <!-- Right: Donut Chart -->
    <div class="db-panel panel-right">
      <div class="db-panel-title">
        <span class="db-panel-title-dot"></span>
        Bal Bölgüsü
      </div>
      <div class="db-donut-wrap">
        <canvas id="donutChart" width="160" height="160" class="db-donut-canvas"></canvas>
        <div class="db-legend">
          <div class="db-legend-item">
            <span class="db-legend-dot" style="background:#10b981;"></span>
            Beginner
            <span class="db-legend-val">@beginnerCount</span>
          </div>
          <div class="db-legend-item">
            <span class="db-legend-dot" style="background:#f59e0b;"></span>
            Intermediate
            <span class="db-legend-val">@intermediateCount</span>
          </div>
          <div class="db-legend-item">
            <span class="db-legend-dot" style="background:#ef4444;"></span>
            Advanced
            <span class="db-legend-val">@advancedCount</span>
          </div>
          <div class="db-legend-item" style="margin-top:8px;border-top:1px solid rgba(255,255,255,0.06);padding-top:8px;">
            <span style="color:#94a3b8;">Ümumi</span>
            <span class="db-legend-val">@totalForBar</span>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Student Cards -->
  <div class="db-students-title">
    <i class="fa fa-list" style="color:#a78bfa;"></i>
    Bütün Tələbə Nəticələri
  </div>

  @if (!Model.Any())
  {
    <div class="db-empty">
      <i class="fa fa-inbox"></i>
      Hələ heç bir nəticə yoxdur.
    </div>
  }
  else
  {
    <div class="row">
      @foreach (var res in Model)
      {
        var initial = res.AppUser?.FullName?.Length > 0 ? res.AppUser.FullName[0].ToString().ToUpper() : "?";
        <div class="col-md-6 col-lg-4">
          <div class="db-student-card lv-@res.Level">
            <div class="d-flex align-items-center">
              <div class="db-student-avatar">@initial</div>
              <div>
                <div class="db-student-name">@res.AppUser?.FullName</div>
                <div class="db-student-meta">
                  <i class="fa fa-layer-group" style="font-size:10px;"></i>
                  @res.Level &bull; @res.Category?.Name
                </div>
                <span class="db-xp-badge">@res.XP XP</span>
              </div>
            </div>
            <div class="text-end">
              <div class="db-student-pct">@res.Percentage%</div>
            </div>
          </div>
        </div>
      }
    </div>
  }

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// ── CountUp ──────────────────────────────────────────────
function countUp(el, target, suffix, duration) {
    suffix = suffix || '';
    duration = duration || 1200;
    var start = 0;
    var step = target / (duration / 16);
    var timer = setInterval(function() {
        start += step;
        if (start >= target) {
            el.textContent = target + suffix;
            clearInterval(timer);
        } else {
            el.textContent = Math.floor(start) + suffix;
        }
    }, 16);
}

document.addEventListener('DOMContentLoaded', function() {
    countUp(document.getElementById('cnt-students'), @totalStudents);
    countUp(document.getElementById('cnt-avg'), @Math.Round(averageScore));

    // ── Progress bars animate ──
    setTimeout(function() {
        document.querySelectorAll('.db-progress-fill').forEach(function(bar) {
            bar.style.width = bar.dataset.target + '%';
        });
    }, 300);

    // ── Donut Chart ──
    var ctx = document.getElementById('donutChart').getContext('2d');
    var total = @totalForBar;
    var data  = [@beginnerCount, @intermediateCount, @advancedCount];

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Beginner', 'Intermediate', 'Advanced'],
            datasets: [{
                data: total > 0 ? data : [1, 1, 1],
                backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                borderWidth: 0,
                hoverOffset: 6,
                borderRadius: 4
            }]
        },
        options: {
            responsive: false,
            cutout: '68%',
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            if (total === 0) return ' Məlumat yoxdur';
                            var pct = Math.round(ctx.parsed / total * 100);
                            return ' ' + ctx.label + ': ' + ctx.parsed + ' (' + pct + '%)';
                        }
                    }
                }
            },
            animation: { animateRotate: true, duration: 1000 }
        }
    });
});
</script>
}
