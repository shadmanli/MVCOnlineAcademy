@model ImpactItemDetailVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="mb-4">Ətraflı</h2>

            <div class="card shadow-sm">

              
                <img src="@(Url.Content("~/uploads/impactitem/" + Model.Image))"
                     class="card-img-top"
                     alt="Impact Image" />

                <div class="card-body">

                
                    <strong>Başlıq:</strong><br />
                    <h4 style="color:grey;">@Model.Title</h4>

                    <p class="card-text mt-2">
                        <strong>Təsvir:</strong><br />
                        @Model.Description
                    </p>

              
                    <div class="mt-2">
                        <strong>Section:</strong><br />
                        <span class="badge bg-info">
                            @Model.SectionName
                        </span>
                    </div>

                    <a asp-action="Index" class="btn btn-secondary mt-3">
                        Siyahıya qayıt
                    </a>

                </div>

            </div>

        </div>
    </div>
</div>