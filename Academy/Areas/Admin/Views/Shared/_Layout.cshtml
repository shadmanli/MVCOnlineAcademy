<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8">
    <title>Inzara Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="~/admin/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/admin/css/premium.css" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@inject Microsoft.AspNetCore.Identity.UserManager<Academy.Models.AppUser> UserManager
@{
    var currentUser = await UserManager.GetUserAsync(User);
    var currentRoles = currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
    var isSuperAdmin = currentRoles.Contains("SuperAdmin");
    var isAdmin      = currentRoles.Contains("Admin");
    var isMuellim    = currentRoles.Contains("Muellim");
    var currentPath  = Context.Request.Path.Value?.ToLower() ?? "";
    var userInitial  = currentUser?.FullName?.Length > 0 ? currentUser.FullName[0].ToString().ToUpper() : "A";
    var userRole     = currentRoles.FirstOrDefault() ?? "Admin";
}

<!-- Sidebar Overlay (mobile) -->
<div class="p-sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="p-layout">

  <!-- ===== SIDEBAR ===== -->
  <aside class="p-sidebar" id="sidebar">

    <!-- Logo -->
    <div class="p-sidebar-logo">
      <a asp-area="Admin" asp-controller="DashBoard" asp-action="Index">
        <div class="p-logo-icon"><i class="fa fa-graduation-cap"></i></div>
        <span class="p-logo-text">Inzara</span>
      </a>
    </div>

    <!-- Nav -->
    <nav class="p-sidebar-nav">

      <a asp-area="Admin" asp-controller="DashBoard" asp-action="Index"
         class="p-nav-link @(currentPath == "/admin" || currentPath.Contains("/admin/dashboard") ? "active" : "")">
        <i class="fa fa-gauge-high"></i> Dashboard
      </a>

      @if (isSuperAdmin || isAdmin || isMuellim)
      {
        <div class="p-nav-section">Kurs</div>
        <a asp-area="Admin" asp-controller="Course" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/course") ? "active" : "")">
          <i class="fa fa-book-open"></i> Kurslar
        </a>
        <a asp-area="Admin" asp-controller="Lesson" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/lesson") ? "active" : "")">
          <i class="fa fa-chalkboard"></i> Dərslər
        </a>
        <a asp-area="Admin" asp-controller="DemoLesson" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/demolesson") ? "active" : "")">
          <i class="fa fa-circle-play"></i> Demo Dərslər
        </a>
        <a asp-area="Admin" asp-controller="LiveClass" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/liveclass") ? "active" : "")">
          <i class="fa fa-video"></i> Canlı Dərslər
        </a>
        <a asp-area="Admin" asp-controller="Quiz" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/quiz") ? "active" : "")">
          <i class="fa fa-circle-question"></i> Quiz
        </a>
        <a asp-area="Admin" asp-controller="AssessmentQuestion" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/assessmentquestion") ? "active" : "")">
          <i class="fa fa-list-check"></i> Assessment
        </a>
      }

      @if (isSuperAdmin || isAdmin)
      {
        <div class="p-nav-section">Kateqoriya & Müəllim</div>
        <a asp-area="Admin" asp-controller="Category" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/category") ? "active" : "")">
          <i class="fa fa-tags"></i> Kateqoriyalar
        </a>
        <a asp-area="Admin" asp-controller="Instructor" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/instructor") ? "active" : "")">
          <i class="fa fa-user-tie"></i> Müəllimlər
        </a>
        <a asp-area="Admin" asp-controller="Language" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/language") ? "active" : "")">
          <i class="fa fa-language"></i> Dillər
        </a>

        <div class="p-nav-section">Kurs Xüsusiyyətləri</div>
        <a asp-area="Admin" asp-controller="CourseFeature" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/coursefeature") ? "active" : "")">
          <i class="fa fa-star"></i> Xüsusiyyətlər
        </a>
        <a asp-area="Admin" asp-controller="CourseRequirement" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/courserequirement") ? "active" : "")">
          <i class="fa fa-clipboard-list"></i> Tələblər
        </a>

        <div class="p-nav-section">Məzmun</div>
        <a asp-area="Admin" asp-controller="Slider" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/slider") ? "active" : "")">
          <i class="fa fa-images"></i> Slider
        </a>
        <a asp-area="Admin" asp-controller="Banner" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/banner") ? "active" : "")">
          <i class="fa fa-flag"></i> Banner
        </a>
        <a asp-area="Admin" asp-controller="Blog" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/blog") ? "active" : "")">
          <i class="fa fa-newspaper"></i> Blog
        </a>
        <a asp-area="Admin" asp-controller="Article" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/article") ? "active" : "")">
          <i class="fa fa-file-lines"></i> Məqalələr
        </a>
        <a asp-area="Admin" asp-controller="Topic" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/topic") ? "active" : "")">
          <i class="fa fa-bookmark"></i> Mövzular
        </a>

        <div class="p-nav-section">Haqqımızda</div>
        <a asp-area="Admin" asp-controller="AboutUs" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/aboutus") ? "active" : "")">
          <i class="fa fa-circle-info"></i> Haqqımızda
        </a>
        <a asp-area="Admin" asp-controller="About" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/about") && !currentPath.Contains("/admin/aboutus") ? "active" : "")">
          <i class="fa fa-photo-film"></i> Haqqımızda (Video)
        </a>
        <a asp-area="Admin" asp-controller="Mission" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/mission") ? "active" : "")">
          <i class="fa fa-bullseye"></i> Missiya
        </a>
        <a asp-area="Admin" asp-controller="Statistic" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/statistic") ? "active" : "")">
          <i class="fa fa-chart-bar"></i> Statistika
        </a>
        <a asp-area="Admin" asp-controller="ImpactSection" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/impactsection") ? "active" : "")">
          <i class="fa fa-bolt"></i> Impact Section
        </a>
        <a asp-area="Admin" asp-controller="ImpactItem" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/impactitem") ? "active" : "")">
          <i class="fa fa-list"></i> Impact Items
        </a>
        <a asp-area="Admin" asp-controller="Feature" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/feature") ? "active" : "")">
          <i class="fa fa-paper-plane"></i> Xüsusiyyətlər (Feature)
        </a>

        <div class="p-nav-section">Əlaqə</div>
        <a asp-area="Admin" asp-controller="ContactSection" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/contactsection") ? "active" : "")">
          <i class="fa fa-address-card"></i> Əlaqə Bölməsi
        </a>
        <a asp-area="Admin" asp-controller="ContactItem" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/contactitem") ? "active" : "")">
          <i class="fa fa-phone"></i> Əlaqə Elementləri
        </a>
        <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/contactmessage") ? "active" : "")">
          <i class="fa fa-envelope"></i> Gələn Mesajlar
        </a>

        <div class="p-nav-section">Rəylər</div>
        <a asp-area="Admin" asp-controller="Review" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/review") ? "active" : "")">
          <i class="fa fa-star-half-stroke"></i> Rəy İdarəetmə
        </a>
      }

      @if (isSuperAdmin)
      {
        <div class="p-nav-section">Sistem</div>
        <a asp-area="Admin" asp-controller="Role" asp-action="Index"
           class="p-nav-link @(currentPath.Contains("/admin/role") ? "active" : "")">
          <i class="fa fa-shield-halved"></i> Rol İdarəetmə
        </a>
      }

    </nav>

    <!-- User -->
    <div class="p-sidebar-user">
      <div class="p-user-avatar">
        @if (!string.IsNullOrEmpty(currentUser?.ProfilePicture))
        {
          <img src="/uploads/profiles/@currentUser.ProfilePicture" alt="">
        }
        else
        {
          @userInitial
        }
        <span class="p-user-online"></span>
      </div>
      <div style="flex:1;min-width:0;">
        <div class="p-user-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
          @(currentUser?.FullName ?? "Admin")
        </div>
        <span class="p-user-role">@userRole</span>
      </div>
      <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" style="margin:0;">
        <button type="submit" title="Çıxış"
                style="background:none;border:none;color:#64748b;cursor:pointer;padding:4px;font-size:14px;transition:color 0.2s;"
                onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#64748b'">
          <i class="fa fa-right-from-bracket"></i>
        </button>
      </form>
    </div>

  </aside>
  <!-- ===== SIDEBAR END ===== -->

  <!-- ===== MAIN ===== -->
  <div class="p-main">

    <!-- Header -->
    <header class="p-header">
      <button class="p-hamburger" id="hamburgerBtn" onclick="toggleSidebar()">
        <i class="fa fa-bars"></i>
      </button>

      <div class="p-search">
        <i class="fa fa-magnifying-glass p-search-icon"></i>
        <input type="text" placeholder="Axtar...">
      </div>

      <div class="p-header-right">
        <a href="/" class="p-header-btn" title="Sayta qayıt" target="_blank">
          <i class="fa fa-arrow-up-right-from-square" style="font-size:12px;"></i>
        </a>
        <div class="p-header-btn" title="Bildirişlər">
          <i class="fa fa-bell" style="font-size:13px;"></i>
          <span class="p-notif-dot"></span>
        </div>
        <div class="p-header-avatar">
          @if (!string.IsNullOrEmpty(currentUser?.ProfilePicture))
          {
            <img src="/uploads/profiles/@currentUser.ProfilePicture" alt="">
          }
          else
          {
            @userInitial
          }
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="p-content">
      @RenderBody()
    </div>

  </div>
  <!-- ===== MAIN END ===== -->

</div>

<!-- Toast Container -->
<div class="p-toast-container" id="pToastContainer"></div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // ===== SIDEBAR TOGGLE =====
  function toggleSidebar() {
    var s = document.getElementById('sidebar');
    var o = document.getElementById('sidebarOverlay');
    s.classList.toggle('open');
    o.classList.toggle('show');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('show');
  }

  // ===== HEADER SCROLL BLUR =====
  window.addEventListener('scroll', function() {
    var h = document.querySelector('.p-header');
    if (h) h.classList.toggle('scrolled', window.scrollY > 10);
  });

  // ===== PREMIUM TOAST =====
  function showPToast(message, type, title) {
    type  = type  || 'info';
    title = title || { success:'Uğurlu', danger:'Xəta', info:'Məlumat', warning:'Xəbərdarlıq' }[type];
    var icons = { success:'fa-circle-check', danger:'fa-circle-xmark', info:'fa-circle-info', warning:'fa-triangle-exclamation' };
    var container = document.getElementById('pToastContainer');
    var toast = document.createElement('div');
    toast.className = 'p-toast p-toast-' + type;
    toast.innerHTML =
      '<div class="p-toast-bar"></div>' +
      '<i class="fa ' + (icons[type]||icons.info) + ' p-toast-icon"></i>' +
      '<div class="p-toast-body">' +
        '<div class="p-toast-title">' + title + '</div>' +
        '<div class="p-toast-msg">' + message + '</div>' +
      '</div>' +
      '<button class="p-toast-close" onclick="this.closest(\'.p-toast\').remove()"><i class="fa fa-xmark"></i></button>' +
      '<div class="p-toast-progress"></div>';
    container.appendChild(toast);
    setTimeout(function() {
      toast.style.transition = 'all 0.3s ease';
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(110%)';
      setTimeout(function() { if (toast.parentNode) toast.remove(); }, 300);
    }, 4200);
  }

  // ===== COUNT UP ANIMATION =====
  function countUp(el) {
    var target = parseInt(el.dataset.target || el.textContent) || 0;
    var duration = 1200;
    var start = 0;
    var step = target / (duration / 16);
    var timer = setInterval(function() {
      start += step;
      if (start >= target) { el.textContent = target.toLocaleString(); clearInterval(timer); }
      else { el.textContent = Math.floor(start).toLocaleString(); }
    }, 16);
  }

  document.addEventListener('DOMContentLoaded', function() {
    // TempData toasts
    var s = document.getElementById('_tempSuccess');
    var e = document.getElementById('_tempError');
    if (s) showPToast(s.dataset.msg, 'success');
    if (e) showPToast(e.dataset.msg, 'danger');

    // CountUp for stat numbers
    document.querySelectorAll('[data-countup]').forEach(function(el) {
      setTimeout(function() { countUp(el); }, 300);
    });

    // Stagger animation for cards
    document.querySelectorAll('.p-stagger > *').forEach(function(el, i) {
      el.style.animationDelay = (i * 80) + 'ms';
    });
  });
</script>

@if (TempData["Success"] != null)
{
  <div id="_tempSuccess" data-msg="@TempData["Success"]" style="display:none"></div>
}
@if (TempData["Error"] != null)
{
  <div id="_tempError" data-msg="@TempData["Error"]" style="display:none"></div>
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
