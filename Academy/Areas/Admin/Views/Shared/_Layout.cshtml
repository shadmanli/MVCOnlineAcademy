<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>DarkPan - Bootstrap 5 Admin Template</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <!-- Favicon -->
    <link href="img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Roboto:wght@500;700&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/admin/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/admin/css/style.css" rel="stylesheet">
</head>

<body>
    <div class="container-fluid position-relative d-flex p-0">
        <!-- Spinner Start -->
        <div id="spinner" class="show bg-dark position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="sr-only">Loading...</span>
            </div>
        </div>
        <!-- Spinner End -->
        <!-- Sidebar Start -->
        <div class="sidebar pe-4 pb-3">
            <nav class="navbar bg-secondary navbar-dark">
                <a asp-area="Admin" asp-controller="DashBoard" asp-action="Index" class="navbar-brand mx-4 mb-3">
                    <h3 class="text-primary"><i class="fa fa-user-edit me-2"></i>Inzara</h3>
                </a>
                @inject Microsoft.AspNetCore.Identity.UserManager<Academy.Models.AppUser> UserManager
                @{
                    var currentUser = await UserManager.GetUserAsync(User);
                    var currentRoles = currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
                    var isSuperAdmin = currentRoles.Contains("SuperAdmin");
                    var isAdmin = currentRoles.Contains("Admin");
                    var isMuellim = currentRoles.Contains("Muellim");
                    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
                }
                <div class="d-flex align-items-center ms-4 mb-4">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePicture))
                        {
                            <img class="rounded-circle" src="/uploads/profiles/@currentUser.ProfilePicture"
                                 alt="" style="width:40px;height:40px;object-fit:cover;">
                        }
                        else
                        {
                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                                 style="width:40px;height:40px;font-size:16px;">
                                @(currentUser?.FullName?.Length > 0 ? currentUser.FullName[0].ToString().ToUpper() : "A")
                            </div>
                        }
                        <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0">@(currentUser?.FullName ?? "Admin")</h6>
                        <span class="small">@(currentRoles.FirstOrDefault() ?? "Admin")</span>
                    </div>
                </div>

                <div class="navbar-nav w-100">

                    <!-- Dashboard — hamı görür -->
                    <a asp-area="Admin" asp-controller="DashBoard" asp-action="Index"
                       class="nav-item nav-link @(currentPath.Contains("/admin/dashboard") || currentPath == "/admin" ? "active" : "")">
                        <i class="fa fa-tachometer-alt me-2"></i>Dashboard
                    </a>

                    @if (isSuperAdmin || isAdmin || isMuellim)
                    {
                        <!-- KURS İDARƏETMƏ -->
                        <div class="sidebar-section-title">KURS</div>

                        <a asp-area="Admin" asp-controller="Course" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/course") ? "active" : "")">
                            <i class="fa fa-book me-2"></i>Kurslar
                        </a>

                        <a asp-area="Admin" asp-controller="Lesson" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/lesson") ? "active" : "")">
                            <i class="fa fa-chalkboard me-2"></i>Dərslər
                        </a>

                        <a asp-area="Admin" asp-controller="DemoLesson" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/demolesson") ? "active" : "")">
                            <i class="fa fa-play-circle me-2"></i>Demo Dərslər
                        </a>

                        <a asp-area="Admin" asp-controller="LiveClass" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/liveclass") ? "active" : "")">
                            <i class="fa fa-video me-2"></i>Canlı Dərslər
                        </a>

                        <a asp-area="Admin" asp-controller="Quiz" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/quiz") ? "active" : "")">
                            <i class="fa fa-question-circle me-2"></i>Quiz
                        </a>

                        <a asp-area="Admin" asp-controller="AssessmentQuestion" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/assessmentquestion") ? "active" : "")">
                            <i class="fa fa-tasks me-2"></i>Assessment Sualları
                        </a>
                    }

                    @if (isSuperAdmin || isAdmin)
                    {
                        <!-- KATEQORİYA & MÜƏLLİM -->
                        <div class="sidebar-section-title">KATEQORİYA & MÜƏLLİM</div>

                        <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/category") ? "active" : "")">
                            <i class="fa fa-tags me-2"></i>Kateqoriyalar
                        </a>

                        <a asp-area="Admin" asp-controller="Instructor" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/instructor") ? "active" : "")">
                            <i class="fa fa-user-tie me-2"></i>Müəllimlər
                        </a>

                        <a asp-area="Admin" asp-controller="Language" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/language") ? "active" : "")">
                            <i class="fa fa-language me-2"></i>Dillər
                        </a>

                        <!-- KURS XÜSUSİYYƏTLƏRİ -->
                        <div class="sidebar-section-title">KURS XÜSUSİYYƏTLƏRİ</div>

                        <a asp-area="Admin" asp-controller="CourseFeature" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/coursefeature") ? "active" : "")">
                            <i class="fa fa-list-check me-2"></i>Kurs Xüsusiyyətləri
                        </a>

                        <a asp-area="Admin" asp-controller="CourseRequirement" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/courserequirement") ? "active" : "")">
                            <i class="fa fa-clipboard-list me-2"></i>Kurs Tələbləri
                        </a>

                        <!-- MƏZMUN -->
                        <div class="sidebar-section-title">MƏZMUN</div>

                        <a asp-area="Admin" asp-controller="Slider" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/slider") ? "active" : "")">
                            <i class="fa fa-images me-2"></i>Slider
                        </a>

                        <a asp-area="Admin" asp-controller="Banner" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/banner") ? "active" : "")">
                            <i class="fa fa-flag me-2"></i>Banner
                        </a>

                        <a asp-area="Admin" asp-controller="Blog" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/blog") ? "active" : "")">
                            <i class="fa fa-newspaper me-2"></i>Blog
                        </a>

                        <a asp-area="Admin" asp-controller="Article" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/article") ? "active" : "")">
                            <i class="fa fa-file-alt me-2"></i>Məqalələr
                        </a>

                        <a asp-area="Admin" asp-controller="Topic" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/topic") ? "active" : "")">
                            <i class="fa fa-bookmark me-2"></i>Mövzular
                        </a>

                        <!-- HAQQIMIZDA -->
                        <div class="sidebar-section-title">HAQQIMIZDA</div>

                        <a asp-area="Admin" asp-controller="AboutUs" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/aboutus") ? "active" : "")">
                            <i class="fa fa-info-circle me-2"></i>Haqqımızda
                        </a>

                        <a asp-area="Admin" asp-controller="About" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/about") && !currentPath.Contains("aboutus") ? "active" : "")">
                            <i class="fa fa-building me-2"></i>About
                        </a>

                        <a asp-area="Admin" asp-controller="Mission" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/mission") ? "active" : "")">
                            <i class="fa fa-bullseye me-2"></i>Missiya
                        </a>

                        <a asp-area="Admin" asp-controller="Feature" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/feature") && !currentPath.Contains("coursefeature") ? "active" : "")">
                            <i class="fa fa-star me-2"></i>Xüsusiyyətlər
                        </a>

                        <a asp-area="Admin" asp-controller="Statistic" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/statistic") ? "active" : "")">
                            <i class="fa fa-chart-bar me-2"></i>Statistika
                        </a>

                        <a asp-area="Admin" asp-controller="ImpactSection" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/impactsection") ? "active" : "")">
                            <i class="fa fa-bolt me-2"></i>Impact Section
                        </a>

                        <a asp-area="Admin" asp-controller="ImpactItem" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/impactitem") ? "active" : "")">
                            <i class="fa fa-list me-2"></i>Impact Items
                        </a>

                        <!-- ƏLAQƏ -->
                        <div class="sidebar-section-title">ƏLAQƏ</div>

                        <a asp-area="Admin" asp-controller="ContactSection" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/contactsection") ? "active" : "")">
                            <i class="fa fa-address-card me-2"></i>Əlaqə Bölməsi
                        </a>

                        <a asp-area="Admin" asp-controller="ContactItem" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/contactitem") ? "active" : "")">
                            <i class="fa fa-phone me-2"></i>Əlaqə Elementləri
                        </a>

                        <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/contactmessage") ? "active" : "")">
                            <i class="fa fa-envelope me-2"></i>Gələn Mesajlar
                        </a>

                        <!-- RƏYLƏr -->
                        <div class="sidebar-section-title">RƏYLƏr</div>

                        <a asp-area="Admin" asp-controller="Review" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/review") ? "active" : "")">
                            <i class="fa fa-star-half-alt me-2"></i>Rəy İdarəetmə
                        </a>
                    }

                    @if (isSuperAdmin)
                    {
                        <!-- SİSTEM -->
                        <div class="sidebar-section-title">SİSTEM</div>

                        <a asp-area="Admin" asp-controller="Role" asp-action="Index"
                           class="nav-item nav-link @(currentPath.Contains("/admin/role") ? "active" : "")">
                            <i class="fa fa-shield-alt me-2"></i>Rol İdarəetmə
                        </a>
                    }

                </div>
            </nav>
        </div>
        <!-- Sidebar End -->
        <!-- Content Start -->
        <div class="content">
            <!-- Navbar Start -->
            <nav class="navbar navbar-expand bg-secondary navbar-dark sticky-top px-4 py-0">
                <a href="index.html" class="navbar-brand d-flex d-lg-none me-4">
                    <h2 class="text-primary mb-0"><i class="fa fa-user-edit"></i></h2>
                </a>
                <a href="#" class="sidebar-toggler flex-shrink-0">
                    <i class="fa fa-bars"></i>
                </a>
                <form class="d-none d-md-flex ms-4">
                    <input class="form-control bg-dark border-0" type="search" placeholder="Search">
                </form>
                <div class="navbar-nav align-items-center ms-auto">
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-envelope me-lg-2"></i>
                            <span class="d-none d-lg-inline-flex">Message</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end bg-secondary border-0 rounded-0 rounded-bottom m-0">
                            <a href="#" class="dropdown-item">
                                <div class="d-flex align-items-center">
                                    <img class="rounded-circle" src="img/user.jpg" alt="" style="width: 40px; height: 40px;">
                                    <div class="ms-2">
                                        <h6 class="fw-normal mb-0">Jhon send you a message</h6>
                                        <small>15 minutes ago</small>
                                    </div>
                                </div>
                            </a>
                            <hr class="dropdown-divider">
                            <a href="#" class="dropdown-item">
                                <div class="d-flex align-items-center">
                                    <img class="rounded-circle" src="img/user.jpg" alt="" style="width: 40px; height: 40px;">
                                    <div class="ms-2">
                                        <h6 class="fw-normal mb-0">Jhon send you a message</h6>
                                        <small>15 minutes ago</small>
                                    </div>
                                </div>
                            </a>
                            <hr class="dropdown-divider">
                            <a href="#" class="dropdown-item">
                                <div class="d-flex align-items-center">
                                    <img class="rounded-circle" src="img/user.jpg" alt="" style="width: 40px; height: 40px;">
                                    <div class="ms-2">
                                        <h6 class="fw-normal mb-0">Jhon send you a message</h6>
                                        <small>15 minutes ago</small>
                                    </div>
                                </div>
                            </a>
                            <hr class="dropdown-divider">
                            <a href="#" class="dropdown-item text-center">See all message</a>
                        </div>
                    </div>
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fa fa-bell me-lg-2"></i>
                            <span class="d-none d-lg-inline-flex">Notificatin</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end bg-secondary border-0 rounded-0 rounded-bottom m-0">
                            <a href="#" class="dropdown-item">
                                <h6 class="fw-normal mb-0">Profile updated</h6>
                                <small>15 minutes ago</small>
                            </a>
                            <hr class="dropdown-divider">
                            <a href="#" class="dropdown-item">
                                <h6 class="fw-normal mb-0">New user added</h6>
                                <small>15 minutes ago</small>
                            </a>
                            <hr class="dropdown-divider">
                            <a href="#" class="dropdown-item">
                                <h6 class="fw-normal mb-0">Password changed</h6>
                                <small>15 minutes ago</small>
                            </a>
                            <hr class="dropdown-divider">
                            <a href="#" class="dropdown-item text-center">See all notifications</a>
                        </div>
                    </div>
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <img class="rounded-circle me-lg-2" src="img/user.jpg" alt="" style="width: 40px; height: 40px;">
                            <span class="d-none d-lg-inline-flex">John Doe</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end bg-secondary border-0 rounded-0 rounded-bottom m-0">
                            <a href="#" class="dropdown-item">My Profile</a>
                            <a href="#" class="dropdown-item">Settings</a>
                            <a href="#" class="dropdown-item">Log Out</a>
                        </div>
                    </div>
                </div>
            </nav>
            <!-- Navbar End -->
        @RenderBody()


            <!-- Footer Start -->
          
            <!-- Footer End -->
        </div>
        <!-- Content End -->
        <!-- Back to Top -->
        <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>
    </div>

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/admin/lib/chart/chart.min.js"></script>
    <script src="~/admin/lib/easing/easing.min.js"></script>
    <script src="~/admin/lib/waypoints/waypoints.min.js"></script>
    <script src="~/admin/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="lib/tempusdominus/js/moment.min.js"></script>
    <script src="lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/admin/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>