
@model IEnumerable<ContactItemVM>

<div class="container-fluid px-4 mt-5 st-4">

    <h2 class="mb-4" style="margin-top: 70px;">Contact Items</h2>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-secondary">Əlavə et</a>
    </div>

    <div class="row">

        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4" data-id="@item.Id">
                    <div class="card shadow-sm mb-4">

                        <div class="card-body text-center">

                            <h5 style="color:black;">@item.Description</h5>

                            <p>@item.Address</p>

                            <span class="badge bg-info">
                                @item.SectionName
                            </span>

                            <div class="mt-3">

                                <a asp-action="Detail"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">
                                    Ətraflı
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm ms-1">
                                    Redaktə
                                </a>

                                <button type="button"
                                        class="btn btn-danger btn-sm ms-1 delete-btn"
                                        data-id="@item.Id">
                                    Sil
                                </button>

                            </div>

                        </div>
                    </div>
                </div>
            }
        }

    </div>
</div>

<script>
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            if (!confirm('Silinsin?')) return;

            const id = this.dataset.id;

            fetch(`/Admin/ContactItem/Delete/${id}`)
            .then(res => {
                if (res.ok) {
                    this.closest('[data-id]').remove();
                } else {
                    alert('Xəta baş verdi!');
                }
            });
        });
    });
</script>