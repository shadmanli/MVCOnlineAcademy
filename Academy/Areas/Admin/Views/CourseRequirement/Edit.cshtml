@model Academy.ViewModels.CourseRequirement.CourseRequirementEditVM

<div class="container mt-5">

    <h2 class="mb-4">Tələbi dəyiş</h2>

    <form method="post">

        <input type="hidden" asp-for="Id" />

     
        <div class="mb-3">
            <label class="form-label">Tələb</label>
            <input asp-for="Text" class="form-control" />
        </div>

       
        <div class="mb-3">
            <label class="form-label">Course</label>
            <select asp-for="CourseId"
                    asp-items="Model.Courses"
                    class="form-control">
            </select>
        </div>

        <button class="btn btn-primary">Yadda saxla</button>
        <a asp-action="Index" class="btn btn-secondary">Geri</a>

    </form>

</div>