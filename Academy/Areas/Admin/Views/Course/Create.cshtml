@using Academy.ViewModels.Course
@model CourseCreateVM

<form method="post" enctype="multipart/form-data">

    <input asp-for="Title" class="form-control mb-2" placeholder="Title" />
    <textarea asp-for="Description" class="form-control mb-2"></textarea>

    <input asp-for="Price" class="form-control mb-2" placeholder="Price" />

    <input type="file" asp-for="Image" class="form-control mb-2" />

    <select asp-for="LanguageId" asp-items="Model.Languages" class="form-control mb-2"></select>
    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control mb-2"></select>
    <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-control mb-2"></select>
    
    <select asp-for="Level" class="form-control mb-2">
        <option value="Beginner">Beginner</option>
        <option value="Intermediate">Intermediate</option>
        <option value="Advanced">Advanced</option>
    </select>

    <input asp-for="Duration" class="form-control mb-2" placeholder="Duration" />

    <h4 class="mt-4">Videos</h4>
    <div id="videos-container">
        <div class="video-item border p-3 mb-3">
            <input name="VideoTitles" class="form-control mb-2" placeholder="Video Title" />
            <input type="file" name="VideoFiles" accept="video/*" class="form-control mb-2" />
            <select name="VideoLevels" class="form-control mb-2">
                <option value="1">Beginner</option>
                <option value="2">Intermediate</option>
                <option value="3">Advanced</option>
            </select>
        </div>
    </div>
    <button type="button" class="btn btn-info mb-3" onclick="addVideo()">Add Another Video</button>

    <button type="submit" class="btn btn-success mt-3 d-block">Create</button>

</form>

@section Scripts {
    <script>
        function addVideo() {
            var container = document.getElementById('videos-container');
            var item = document.querySelector('.video-item').cloneNode(true);

            var inputs = item.querySelectorAll('input');
            inputs.forEach(input => input.value = '');

            container.appendChild(item);
        }
    </script>
}