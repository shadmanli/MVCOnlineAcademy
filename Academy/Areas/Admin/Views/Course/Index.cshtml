@using Academy.ViewModels.Course
@model IEnumerable<CourseVM>

<div class="container mt-5">

    <div class="d-flex justify-content-between mb-4">
        <h2 class="fw-bold">Courses</h2>
        <a asp-action="Create" class="btn btn-success">+ Əlavə et</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4" data-id="@item.Id">
                <div class="card shadow-sm border-0 h-100">

                    <img src="~/uploads/course/@item.ImageUrl"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">

                        <h5>@item.Title</h5>

                        <p class="text-muted mb-1">@item.InstructorName</p>

                        <span class="badge bg-info">@item.LanguageName</span>
                        <span class="badge bg-secondary">@item.CategoryName</span>

                        <h6 class="mt-2 text-success">$@item.Price</h6>

                        <div class="mt-3 d-flex gap-2">
                            <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Detail</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <button class="btn btn-outline-danger btn-sm delete-btn" data-id="@item.Id">Sil</button>
                        </div>

                    </div>

                </div>
            </div>
        }
    </div>

</div>

<script>
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            if (!confirm('Silinsin?')) return;

            fetch(`/Admin/Course/Delete/${this.dataset.id}`)
            .then(res => {
                if (res.ok) {
                    this.closest('[data-id]').remove();
                }
            });
        });
    });
</script>