@using Academy.ViewModels.About
@model AboutCreateVM
@{ ViewData["Title"] = "Yeni About"; }
<partial name="~/Areas/Admin/Views/Shared/_AdminFormStyles.cshtml" />

<div class="p-page-header">
    <div class="p-page-title">Yeni About</div>
    <div class="p-breadcrumb"><a asp-area="Admin" asp-controller="About" asp-action="Index">About</a> / Yeni</div>
</div>

<div class="p-card" style="max-width:640px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="af-field">
            <label class="af-label">Başlıq <span class="req">*</span></label>
            <input asp-for="Title" class="form-control" placeholder="Başlıq" data-no-whitespace />
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Təsvir <span class="req">*</span></label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Məzmun..."></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Şəkil <span class="req">*</span> <small style="color:#64748b;">(jpg, jpeg, png, webp — max 5MB)</small></label>
            <input asp-for="Image" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control"
                   data-file-type="image" data-err-target="imgErr" />
            <span asp-validation-for="Image" class="field-validation-error"></span>
            <span id="imgErr" class="field-validation-error" style="display:none;"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Video <small style="color:#64748b;">(mp4, mov, avi — max 500MB, isteğe bağlı)</small></label>
            <input asp-for="Video" type="file" accept=".mp4,.mov,.avi" class="form-control"
                   data-file-type="video" data-err-target="vidErr" />
            <span id="vidErr" class="field-validation-error" style="display:none;"></span>
        </div>
        <div style="display:flex;gap:10px;margin-top:20px;">
            <button type="submit" class="af-submit"><i class="fa fa-check"></i> Yarat</button>
            <a asp-action="Index" class="af-cancel"><i class="fa fa-arrow-left"></i> Geri</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="~/Areas/Admin/Views/Shared/_AdminFormScripts.cshtml" /> }
