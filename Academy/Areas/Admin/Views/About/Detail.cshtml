@model AboutDetailVM

<div class="container mt-10">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="mb-4"> Ətraflı</h2>

            <div class="card shadow-sm">

               
                <img src="@(Url.Content("~/uploads/about/" + Model.Image))"
                     class="card-img-top mt-0"
                     alt="About Image" />

                <div class="card-body">

                    <strong>Başlıq:</strong><br />
                    <h4 class="card-title" style="color:grey;">@Model.Title</h4>

           
                    <p class="card-text">
                        <strong>Təsvir:</strong><br />
                        @Model.Description
                    </p>

                

             
                    @if (!string.IsNullOrEmpty(Model.Video))
                    {
                        <div class="mt-3">
                            <strong>Video:</strong><br />
                            <video width="100%" controls>
                                <source src="@(Url.Content("~/uploads/about/" + Model.Video))" type="video/mp4">
                                Sizin brauzer video dəstəkləmir.
                            </video>
                        </div>
                    }

                    <a asp-action="Index" class="btn btn-secondary mt-3">Siyahıya qayıt</a>

                </div>

            </div>

        </div>
    </div>
</div>