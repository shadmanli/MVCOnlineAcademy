@using Academy.ViewModels.Article
@model ArticleCreateVM
@{ ViewData["Title"] = "Yeni Məqalə"; }
<partial name="~/Areas/Admin/Views/Shared/_AdminFormStyles.cshtml" />

<div class="p-page-header">
    <div class="p-page-title">Yeni Məqalə</div>
    <div class="p-breadcrumb"><a asp-area="Admin" asp-controller="Article" asp-action="Index">Məqalələr</a> / Yeni</div>
</div>

<div class="p-card" style="max-width:720px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="af-field">
            <label class="af-label">Qısa Təsvir <span class="req">*</span></label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Məqalənin qısa təsviri..." data-no-whitespace></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Tam Mətn <span class="req">*</span></label>
            <textarea asp-for="Text" class="form-control" rows="6" placeholder="Məqalənin tam mətni..." data-no-whitespace></textarea>
            <span asp-validation-for="Text" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Mövzu <span class="req">*</span></label>
            <select asp-for="TopicId" asp-items="Model.Topics" class="form-select">
                <option value="0">-- Mövzu seçin --</option>
            </select>
            <span asp-validation-for="TopicId" class="field-validation-error"></span>
        </div>
        <div class="af-field">
            <label class="af-label">Şəkil <span class="req">*</span> <small style="color:#64748b;">(jpg, jpeg, png, webp — max 5MB)</small></label>
            <input asp-for="Image" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control"
                   data-file-type="image" data-err-target="imgErr" />
            <span asp-validation-for="Image" class="field-validation-error"></span>
            <span id="imgErr" class="field-validation-error" style="display:none;"></span>
        </div>
        <div style="display:flex;gap:10px;margin-top:20px;">
            <button type="submit" class="af-submit"><i class="fa fa-check"></i> Yarat</button>
            <a asp-action="Index" class="af-cancel"><i class="fa fa-arrow-left"></i> Geri</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="~/Areas/Admin/Views/Shared/_AdminFormScripts.cshtml" /> }
