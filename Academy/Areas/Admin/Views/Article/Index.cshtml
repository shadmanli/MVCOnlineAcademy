@using Academy.ViewModels.Article
@model IEnumerable<ArticleVM>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Articles</h2>
        <a asp-action="Create" class="btn btn-secondary">Əlavə et</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4">
                    <div class="card mb-4 shadow-sm">

                        <img src="~/uploads/article/@item.Image"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;" />

                        <div class="card-body text-center">

                            <p>@item.Description</p>
                            <p>@item.Text</p>
                           
                            <span class="badge bg-info mb-2">
                                @item.TopicName
                            </span>
                            <div class="mt-2">
                                <a asp-action="Detail"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">
                                    Ətraflı
                                </a>

                                <a asp-area="Admin"
                                   asp-controller="Article"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm ms-1">
                                    Yenilə
                                </a>

                                <button type="button"
                                        class="btn btn-danger btn-sm ms-1 delete-article-btn"
                                        data-id="@item.Id">
                                    Sil
                                </button>
                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>Heç bir article yoxdur</p>
    }

</div>

<script>
    document.querySelectorAll('.delete-article-btn').forEach(btn => {
        btn.addEventListener('click', function () {

            if (!confirm('Article silinsin?')) return;

            const id = this.getAttribute('data-id');
            const card = this.closest('.col-md-4');

            fetch(`/Admin/Article/Delete/${id}`)
                .then(res => {
                    if (res.ok) {
                        card.remove();
                    } else {
                        alert('Silinmə zamanı xəta baş verdi!');
                    }
                })
                .catch(() => alert('Xəta baş verdi!'));
        });
    });
</script>