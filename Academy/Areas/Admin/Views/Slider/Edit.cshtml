@model SliderEditVM
@{ ViewData["Title"] = "Slider Redaktə"; }
<partial name="~/Areas/Admin/Views/Shared/_AdminFormStyles.cshtml" />

<div class="p-page-header">
    <div class="p-page-title">Slider Redaktə</div>
    <div class="p-breadcrumb"><a asp-area="Admin" asp-controller="Slider" asp-action="Index">Slider</a> / Redaktə</div>
</div>

<div class="p-card" style="max-width:640px;">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="Image" type="hidden" />

        <div class="af-field">
            <label class="af-label">Başlıq <span class="req">*</span></label>
            <input asp-for="Title" class="form-control" data-no-whitespace />
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>

        <div class="af-field">
            <label class="af-label">Təsvir</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>

        @if (!string.IsNullOrEmpty(Model?.Image))
        {
            <div class="af-field">
                <label class="af-label">Mövcud Şəkil</label>
                <img src="/uploads/sliders/@Model.Image" style="max-height:120px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);" />
            </div>
        }

        <div class="af-field">
            <label class="af-label">Yeni Şəkil <small style="color:#64748b;">(jpg, jpeg, png, webp — max 5MB)</small></label>
            <input asp-for="Photo" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control"
                   data-file-type="image" data-err-target="imgErr" />
            <span id="imgErr" class="field-validation-error" style="display:none;"></span>
        </div>

        <div style="display:flex;gap:10px;margin-top:20px;">
            <button type="submit" class="af-submit"><i class="fa fa-floppy-disk"></i> Yadda Saxla</button>
            <a asp-action="Index" class="af-cancel"><i class="fa fa-arrow-left"></i> Geri</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="~/Areas/Admin/Views/Shared/_AdminFormScripts.cshtml" /> }
