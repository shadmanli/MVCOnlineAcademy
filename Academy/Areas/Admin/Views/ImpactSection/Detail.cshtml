@model ImpactSectionDetailVM

<div class="container mt-5">

 
    <div class="mb-4">
        <h2>@Model.Title</h2>
        <p class="text-muted">@Model.SubTitle</p>
    </div>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-secondary">Geri qayıt</a>
    </div>

  
    <div class="row">
        @if (Model.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="col-md-4">
                    <div class="card mb-4 shadow-sm">

                        <img src="@Url.Content("~/uploads/impactitem/" + item.Image)"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;" />

                        <div class="card-body text-center">
                            <h5>@item.Title</h5>
                            <p>@item.Description</p>

                            <div class="mt-2">
                                <a asp-area="Admin"
                                   asp-controller="ImpactItem"
                                   asp-action="Detail"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">Ətraflı</a>

                                <a asp-area="Admin"
                                   asp-controller="ImpactItem"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm ms-1">Yenilə</a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <p>Bu section üçün item yoxdur</p>
        }
    </div>

</div>