@model Academy.ViewModels.ImpactSection.ImpactSectionEditVM

<div class="container mt-5">
    <h2 class="fw-bold mb-4">Edit Impact Section</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

  
        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" class="form-control" placeholder="Title yaz" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SubTitle" class="form-label">SubTitle</label>
            <input asp-for="SubTitle" class="form-control" placeholder="SubTitle yaz" />
            <span asp-validation-for="SubTitle" class="text-danger"></span>
        </div>

   
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </div>
    </form>
</div>